{% assign journey_class = 'aura-glow-journey-' | append: section.id %}

<section
  class="aura-glow-journey full-width {{ journey_class }} aura-glow-journey--{{ section.settings.card_alignment }}"
  style="
    --aura-glow-journey-background: {{ section.settings.background_color }};
    --aura-glow-journey-card-background: {{ section.settings.card_background }};
    --aura-glow-journey-card-text: {{ section.settings.card_text_color }};
    --aura-glow-journey-highlight-background: {{ section.settings.highlight_background }};
    --aura-glow-journey-highlight-text: {{ section.settings.highlight_text_color }};
    --aura-glow-journey-heading-size: {{ section.settings.heading_size }}px;
    --aura-glow-journey-subheading-size: {{ section.settings.subheading_size }}px;
    --aura-glow-journey-body-size: {{ section.settings.body_size }}px;
    --aura-glow-journey-padding-top: {{ section.settings.padding_top }}px;
    --aura-glow-journey-padding-bottom: {{ section.settings.padding_bottom }}px;
    --aura-glow-journey-gap: {{ section.settings.card_gap }}px;
  "
>
  <div class="aura-glow-journey__inner">
    <div class="aura-glow-journey__grid">
      <div class="aura-glow-journey__intro">
        {% if section.settings.heading != blank %}
          <h2 class="aura-glow-journey__heading">{{ section.settings.heading | escape | newline_to_br }}</h2>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <p class="aura-glow-journey__subheading">{{ section.settings.subheading | escape }}</p>
        {% endif %}
      </div>

      {% for block in section.blocks %}
        {% assign list_items = block.settings.list_items | newline_to_br | split: '<br />' %}
        <article class="aura-glow-journey__card{% if block.settings.highlight %} aura-glow-journey__card--highlight{% endif %}" {{ block.shopify_attributes }}>
          <div class="aura-glow-journey__card-top">
            <div class="aura-glow-journey__icon">
              {% if block.settings.custom_svg != blank %}
                {{ block.settings.custom_svg }}
              {% else %}
                {% render 'aura-icon', icon: block.settings.icon %}
              {% endif %}
            </div>

            {% if block.settings.label != blank %}
              <span class="aura-glow-journey__label">{{ block.settings.label | escape }}</span>
            {% endif %}
          </div>

          {% if block.settings.tier_name != blank %}
            <h3 class="aura-glow-journey__tier-name">{{ block.settings.tier_name | escape }}</h3>
          {% endif %}

          {% if block.settings.description != blank %}
            <p class="aura-glow-journey__description">{{ block.settings.description | escape }}</p>
          {% endif %}

          <ul class="aura-glow-journey__list" role="list">
            {% for item in list_items %}
              {% assign item_text = item | strip %}
              {% if item_text != blank %}
                <li class="aura-glow-journey__list-item">
                  <span class="aura-glow-journey__list-icon">{% render 'aura-icon', icon: 'check' %}</span>
                  <span>{{ item_text }}</span>
                </li>
              {% endif %}
            {% endfor %}
          </ul>

          {% if block.settings.button_text != blank %}
            <a class="aura-glow-journey__button" href="{{ block.settings.button_link | default: '#' }}">
              {{ block.settings.button_text | escape }}
            </a>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% style %}
  .{{ journey_class }} {
    background: linear-gradient(90deg, #fff8f5, #fffefe, var(--aura-glow-journey-background));
  }

  .{{ journey_class }} .aura-glow-journey__inner {
    width: min(1160px, calc(100% - 48px));
    margin: 0 auto;
    padding-top: var(--aura-glow-journey-padding-top);
    padding-bottom: var(--aura-glow-journey-padding-bottom);
  }

  .{{ journey_class }} .aura-glow-journey__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) repeat(3, minmax(0, 1fr));
    gap: var(--aura-glow-journey-gap);
    align-items: center;
  }

  .{{ journey_class }} .aura-glow-journey__intro {
    padding-right: 0.5rem;
  }

  .{{ journey_class }} .aura-glow-journey__heading {
    font-family: var(--font-heading--family);
    font-size: var(--aura-glow-journey-heading-size);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--aura-heading-color);
  }

  .{{ journey_class }} .aura-glow-journey__subheading {
    margin-top: 0.9rem;
    color: #6f5b63;
    font-size: var(--aura-glow-journey-subheading-size);
    line-height: 1.65;
  }

  .{{ journey_class }} .aura-glow-journey__card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 16rem;
    padding: 2rem 1.65rem;
    border: 1px solid rgba(129, 57, 82, 0.14);
    border-radius: 1.35rem;
    background: var(--aura-glow-journey-card-background);
    color: var(--aura-glow-journey-card-text);
    box-shadow: 0 12px 32px rgba(150, 92, 104, 0.06);
  }

  .{{ journey_class }}.aura-glow-journey--center .aura-glow-journey__card {
    text-align: center;
  }

  .{{ journey_class }} .aura-glow-journey__card--highlight {
    background: linear-gradient(135deg, var(--aura-secondary-color), var(--aura-glow-journey-highlight-background));
    color: var(--aura-glow-journey-highlight-text);
    transform: translateY(-1.25rem);
    box-shadow: 0 22px 45px rgba(142, 49, 84, 0.22);
  }

  .{{ journey_class }} .aura-glow-journey__card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .{{ journey_class }} .aura-glow-journey__icon {
    display: grid;
    place-items: center;
    width: 3.2rem;
    height: 3.2rem;
    padding: 0.75rem;
    border-radius: 999px;
    background: #fff0f3;
    color: var(--aura-primary-color);
  }

  .{{ journey_class }} .aura-glow-journey__card--highlight .aura-glow-journey__icon {
    background: rgba(255, 255, 255, 0.16);
    color: #ffffff;
  }

  .{{ journey_class }} .aura-glow-journey__card--highlight .aura-icon,
  .{{ journey_class }} .aura-glow-journey__card--highlight .aura-glow-journey__list-icon,
  .{{ journey_class }} .aura-glow-journey__card--highlight .aura-glow-journey__list-icon .aura-icon {
    color: #ffffff;
  }

  .{{ journey_class }} .aura-glow-journey__label {
    align-self: flex-end;
    padding: 0.38rem 0.82rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.22);
    font-size: 0.62rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .{{ journey_class }} .aura-glow-journey__card:not(.aura-glow-journey__card--highlight) .aura-glow-journey__label {
    background: var(--aura-primary-color-08);
    color: var(--aura-primary-color);
  }

  .{{ journey_class }} .aura-glow-journey__tier-name {
    margin: 0 0 0.6rem;
    color: var(--aura-heading-color);
    font-size: clamp(1.65rem, 2vw, 2rem);
    font-weight: 600;
  }

  .{{ journey_class }} .aura-glow-journey__card--highlight .aura-glow-journey__tier-name {
    color: #ffffff;
  }

  .{{ journey_class }} .aura-glow-journey__description {
    margin: 0 0 0.8rem;
    font-size: var(--aura-glow-journey-body-size);
    line-height: 1.55;
    opacity: 0.88;
  }

  .{{ journey_class }} .aura-glow-journey__list {
    margin: 0 0 1rem;
    padding: 0;
    list-style: none;
  }

  .{{ journey_class }} .aura-glow-journey__list-item {
    display: flex;
    gap: 0.55rem;
    line-height: 1.8;
    font-size: var(--aura-glow-journey-body-size);
  }

  .{{ journey_class }}.aura-glow-journey--center .aura-glow-journey__list-item {
    justify-content: center;
    text-align: left;
  }

  .{{ journey_class }} .aura-glow-journey__list-icon {
    width: 1rem;
    height: 1rem;
    margin-top: 0.35rem;
    flex: 0 0 auto;
  }

  .{{ journey_class }} .aura-glow-journey__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.9rem;
    margin-top: auto;
    padding: 0.75rem 1rem;
    color: inherit;
    text-decoration: none;
    font-weight: 700;
  }

  @media (max-width: 989px) {
    .{{ journey_class }} .aura-glow-journey__grid {
      grid-template-columns: 1fr;
    }

    .{{ journey_class }} .aura-glow-journey__card--highlight {
      transform: none;
    }
  }

  @media (max-width: 767px) {
    .{{ journey_class }} .aura-glow-journey__inner {
      width: min(1160px, calc(100% - 32px));
    }

    .{{ journey_class }} .aura-glow-journey__heading {
      font-size: min(calc(var(--aura-glow-journey-heading-size) * 0.84), 2.3rem);
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Aura glow journey",
  "tag": "section",
  "class": "section-aura-glow-journey",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Choose your glow journey"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "The more you glow, the more you unlock."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#fff8f7"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#fff4f3"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card text color",
      "default": "#4a2435"
    },
    {
      "type": "color",
      "id": "highlight_background",
      "label": "Highlighted card background",
      "default": "#EC008C"
    },
    {
      "type": "color",
      "id": "highlight_text_color",
      "label": "Highlighted card text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 56,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body size",
      "min": 13,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "select",
      "id": "card_alignment",
      "label": "Card alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Card spacing",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "tier",
      "name": "Tier card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "sparkle",
          "options": [
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "crown", "label": "Crown" },
            { "value": "diamond", "label": "Diamond" },
            { "value": "star", "label": "Star" }
          ]
        },
        {
          "type": "textarea",
          "id": "custom_svg",
          "label": "Custom SVG code"
        },
        {
          "type": "text",
          "id": "tier_name",
          "label": "Tier name",
          "default": "Glow"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Earn points for every beauty move."
        },
        {
          "type": "textarea",
          "id": "list_items",
          "label": "List items",
          "default": "Free to join\nBeauty news first"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Free to join"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "checkbox",
          "id": "highlight",
          "label": "Highlight card",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aura glow journey",
      "blocks": [
        {
          "type": "tier",
          "settings": {
            "icon": "sparkle",
            "tier_name": "Glow",
            "description": "Earn 1 point for every dollar spent.",
            "list_items": "Beauty rewards\nProduct drops\nReferral points",
            "button_text": "Free to join"
          }
        },
        {
          "type": "tier",
          "settings": {
            "icon": "crown",
            "tier_name": "Muse",
            "description": "A tier for your most-loved beauty rituals.",
            "list_items": "2x points on select launches\nVIP offers\nExclusive gifts",
            "label": "Most popular",
            "button_text": "Free to join",
            "highlight": true
          }
        },
        {
          "type": "tier",
          "settings": {
            "icon": "diamond",
            "tier_name": "Elite",
            "description": "For high-glow members who want the full experience.",
            "list_items": "3x points events\nPriority rewards\nBirthday surprise",
            "button_text": "Start earning"
          }
        }
      ]
    }
  ]
}
{% endschema %}
