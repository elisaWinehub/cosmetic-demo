{% liquid
  if section.settings.background_style == 'gradient'
    capture section_background
      echo 'radial-gradient(circle at 83% 40%, rgba(219, 112, 137, 0.38), transparent 28%), radial-gradient(circle at 70% 18%, rgba(255, 185, 198, 0.7), transparent 34%), linear-gradient(100deg, '
      echo section.settings.background_color
      echo ' 0%, '
      echo section.settings.accent_color
      echo ' 56%, #ffdfe7 100%)'
    endcapture
  else
    assign section_background = section.settings.background_color
  endif

  assign hero_class = 'aura-hero-' | append: section.id
%}

<section
  class="aura-hero full-width {{ hero_class }}{% if section.settings.desktop_image != blank %} aura-hero--has-banner-image{% endif %}{% if section.settings.reverse_layout %} aura-hero--reverse{% endif %} aura-hero--{{ section.settings.text_alignment }}"
  style="
    --aura-hero-background: {{ section_background }};
    --aura-hero-content-width: {{ section.settings.content_width }}px;
    --aura-hero-padding-top: {{ section.settings.padding_top_desktop }}px;
    --aura-hero-padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    --aura-hero-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --aura-hero-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --aura-hero-heading-size: {{ section.settings.heading_font_size }}px;
    --aura-hero-heading-weight: {{ section.settings.heading_font_weight }};
    --aura-hero-heading-line-height: {{ section.settings.heading_line_height | divided_by: 100.0 }};
    --aura-hero-heading-letter-spacing: {{ section.settings.heading_letter_spacing }}px;
    --aura-hero-body-size: {{ section.settings.body_font_size }}px;
    --aura-hero-body-weight: {{ section.settings.body_font_weight }};
    --aura-hero-body-line-height: {{ section.settings.body_line_height | divided_by: 100.0 }};
    --aura-hero-body-letter-spacing: {{ section.settings.body_letter_spacing }}px;
    --aura-hero-button-size: {{ section.settings.button_font_size }}px;
    --aura-hero-button-weight: {{ section.settings.button_font_weight }};
    --aura-hero-button-letter-spacing: {{ section.settings.button_letter_spacing }}px;
    --aura-hero-card-background: {{ section.settings.card_background }};
    --aura-hero-card-foreground: {{ section.settings.card_foreground }};
    --aura-hero-button-background: {{ section.settings.primary_button_background }};
    --aura-hero-button-foreground: {{ section.settings.primary_button_foreground }};
    --aura-hero-secondary-background: {{ section.settings.secondary_button_background }};
    --aura-hero-secondary-foreground: {{ section.settings.secondary_button_foreground }};
    --aura-hero-min-height: {{ section.settings.min_height_desktop }}px;
    --aura-hero-min-height-mobile: {{ section.settings.min_height_mobile }}px;
  "
>
  {% if section.settings.desktop_image != blank %}
    <div class="aura-hero__banner-background" aria-hidden="true">
      <picture class="aura-hero__banner-picture">
        {% if section.settings.mobile_image != blank %}
          <source media="(max-width: 767px)" srcset="{{ section.settings.mobile_image | image_url: width: 1200 }}">
        {% endif %}
        {{ section.settings.desktop_image | image_url: width: 2200 | image_tag: class: 'aura-hero__banner-image', loading: 'eager' }}
      </picture>
      <div class="aura-hero__banner-fade"></div>
    </div>
  {% endif %}

  <div class="aura-hero__shell">
    <div class="aura-hero__grid">
      <div class="aura-hero__content">
        {% if section.settings.eyebrow != blank %}
          <p class="aura-hero__eyebrow">
            <span class="aura-hero__eyebrow-icon">{% render 'aura-icon', icon: 'sparkle' %}</span>
            {{ section.settings.eyebrow | escape }}
          </p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h1 class="aura-hero__heading">{{ section.settings.heading | escape | newline_to_br }}</h1>
        {% endif %}

        {% if section.settings.body != blank %}
          <div class="aura-hero__body rte">{{ section.settings.body }}</div>
        {% endif %}

        <div class="aura-hero__actions">
          {% if section.settings.primary_button_text != blank %}
            <a class="aura-hero__button aura-hero__button--primary" href="{{ section.settings.primary_button_link | default: '#' }}">
              {{ section.settings.primary_button_text | escape }}
            </a>
          {% endif %}

          {% if section.settings.secondary_button_text != blank %}
            <a class="aura-hero__button aura-hero__button--secondary" href="{{ section.settings.secondary_button_link | default: '#' }}">
              {{ section.settings.secondary_button_text | escape }}
            </a>
          {% endif %}
        </div>

        {% if section.settings.social_proof != blank %}
          <div class="aura-hero__social-proof">
            <div class="aura-hero__avatars" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
              <span></span>
            </div>
            <div class="aura-hero__social-text rte">{{ section.settings.social_proof }}</div>
          </div>
        {% endif %}
      </div>

      <div class="aura-hero__media">
        <div class="aura-hero__media-shell">
          <div class="aura-hero__decor" aria-hidden="true">
            <div class="aura-hero__stage"></div>
            <div class="aura-hero__orb aura-hero__orb--one"></div>
            <div class="aura-hero__orb aura-hero__orb--two"></div>
          </div>

          {% if section.settings.desktop_image == blank %}
            <div class="aura-hero__mock-products" aria-hidden="true">
              <div class="aura-hero__product aura-hero__product--bottle">
                <span>Aura<br>Society</span>
              </div>
              <div class="aura-hero__product aura-hero__product--tube">
                <span>Aura<br>Society</span>
              </div>
              <div class="aura-hero__product aura-hero__product--jar">
                <span>Aura Society</span>
              </div>
            </div>
          {% endif %}

          {% if section.settings.show_floating_cards and section.blocks.size > 0 %}
            <div class="aura-hero__floating-cards">
              {% for block in section.blocks %}
                <div class="aura-hero__floating-card aura-hero__floating-card--{{ block.settings.position }}" {{ block.shopify_attributes }}>
                  <div class="aura-hero__floating-icon">
                    {% render 'aura-icon', icon: block.settings.icon %}
                  </div>
                  <div class="aura-hero__floating-copy">
                    {% if block.settings.eyebrow != blank %}
                      <p class="aura-hero__floating-eyebrow">{{ block.settings.eyebrow | escape }}</p>
                    {% endif %}
                    {% if block.settings.heading != blank %}
                      <p class="aura-hero__floating-heading">{{ block.settings.heading | escape }}</p>
                    {% endif %}
                    {% if block.settings.text != blank %}
                      <p class="aura-hero__floating-text">{{ block.settings.text | escape }}</p>
                    {% endif %}
                  </div>
                </div>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% style %}
  .{{ hero_class }} {
    position: relative;
    background: var(--aura-hero-background);
    color: #171012;
    overflow: hidden;
  }

  .{{ hero_class }} .aura-hero__shell {
    position: relative;
    z-index: 1;
    width: min(1160px, calc(100% - 48px));
    margin: 0 auto;
    padding-top: var(--aura-hero-padding-top);
    padding-bottom: var(--aura-hero-padding-bottom);
  }

  .{{ hero_class }} .aura-hero__banner-background {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .{{ hero_class }} .aura-hero__banner-picture,
  .{{ hero_class }} .aura-hero__banner-image {
    width: 100%;
    height: 100%;
  }

  .{{ hero_class }} .aura-hero__banner-image {
    object-fit: cover;
    object-position: right center;
  }

  .{{ hero_class }} .aura-hero__banner-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(255, 248, 245, 0.98) 0%, rgba(255, 248, 245, 0.95) 34%, rgba(255, 248, 245, 0.66) 54%, rgba(255, 248, 245, 0.18) 74%, rgba(255, 248, 245, 0.04) 100%);
  }

  .{{ hero_class }}.aura-hero--reverse .aura-hero__banner-fade {
    background: linear-gradient(270deg, rgba(255, 248, 245, 0.98) 0%, rgba(255, 248, 245, 0.95) 34%, rgba(255, 248, 245, 0.66) 54%, rgba(255, 248, 245, 0.18) 74%, rgba(255, 248, 245, 0.04) 100%);
  }

  .{{ hero_class }} .aura-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.45fr) minmax(0, 0.55fr);
    align-items: center;
    gap: clamp(2rem, 4vw, 4rem);
    min-height: var(--aura-hero-min-height);
  }

  .{{ hero_class }}.aura-hero--reverse .aura-hero__grid {
    grid-template-columns: minmax(0, 0.55fr) minmax(0, 0.45fr);
  }

  .{{ hero_class }} .aura-hero__content {
    max-width: min(100%, var(--aura-hero-content-width));
  }

  .{{ hero_class }} .aura-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.6rem 0.95rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.68);
    color: var(--aura-primary-color);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .{{ hero_class }} .aura-hero__eyebrow-icon {
    width: 0.9rem;
    height: 0.9rem;
  }

  .{{ hero_class }} .aura-hero__heading {
    margin: 1.6rem 0 1.3rem;
    font-family: var(--font-heading--family);
    font-size: clamp(3.5rem, var(--aura-hero-heading-size), 5.9rem);
    font-weight: var(--aura-hero-heading-weight);
    line-height: var(--aura-hero-heading-line-height);
    letter-spacing: var(--aura-hero-heading-letter-spacing);
    color: var(--aura-heading-color);
    text-wrap: balance;
  }

  .{{ hero_class }} .aura-hero__body {
    max-width: 34rem;
    color: #3c3035;
    font-size: var(--aura-hero-body-size);
    font-weight: var(--aura-hero-body-weight);
    line-height: var(--aura-hero-body-line-height);
    letter-spacing: var(--aura-hero-body-letter-spacing);
  }

  .{{ hero_class }} .aura-hero__body p + p {
    margin-top: 0.8rem;
  }

  .{{ hero_class }} .aura-hero__actions {
    display: flex;
    gap: 1rem;
    margin: 1.8rem 0 1.9rem;
    flex-wrap: wrap;
  }

  .{{ hero_class }} .aura-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.25rem;
    padding: 0 2rem;
    border-radius: 0.3rem;
    border: 1px solid transparent;
    font-size: var(--aura-hero-button-size);
    font-weight: 900;
    letter-spacing: var(--aura-hero-button-letter-spacing);
    text-decoration: none;
    text-transform: uppercase;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .{{ hero_class }} .aura-hero__button:hover {
    transform: translateY(-1px);
  }

  .{{ hero_class }} .aura-hero__button--primary {
    background: var(--aura-hero-button-background);
    color: var(--aura-hero-button-foreground);
    border-color: var(--aura-primary-color);
    box-shadow: 0 18px 45px rgba(129, 57, 82, 0.16);
  }

  .{{ hero_class }} .aura-hero__button--secondary {
    background: var(--aura-hero-secondary-background);
    color: var(--aura-hero-secondary-foreground);
    border-color: var(--aura-hero-secondary-foreground);
  }

  .{{ hero_class }} .aura-hero__social-proof {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: #6f5b63;
    font-size: 0.9rem;
  }

  .{{ hero_class }} .aura-hero__avatars {
    display: flex;
  }

  .{{ hero_class }} .aura-hero__avatars span {
    width: 2.2rem;
    height: 2.2rem;
    margin-left: -0.5rem;
    border-radius: 50%;
    border: 2px solid #fff;
    background: linear-gradient(135deg, #6d3b2e, #f2c3b1);
    box-shadow: 0 8px 18px rgba(129, 57, 82, 0.12);
  }

  .{{ hero_class }} .aura-hero__avatars span:first-child {
    margin-left: 0;
  }

  .{{ hero_class }} .aura-hero__avatars span:nth-child(2) {
    background: linear-gradient(135deg, #8b4d3f, #f3d0c3);
  }

  .{{ hero_class }} .aura-hero__avatars span:nth-child(3) {
    background: linear-gradient(135deg, #5a2f27, #f4b1ac);
  }

  .{{ hero_class }} .aura-hero__avatars span:nth-child(4) {
    background: linear-gradient(135deg, #7d4a42, #f0c9be);
  }

  .{{ hero_class }} .aura-hero__social-text strong {
    color: #171012;
  }

  .{{ hero_class }} .aura-hero__media {
    min-width: 0;
  }

  .{{ hero_class }} .aura-hero__media-shell {
    position: relative;
    min-height: 30rem;
    isolation: isolate;
  }

  .{{ hero_class }} .aura-hero__decor {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .{{ hero_class }}.aura-hero--has-banner-image .aura-hero__stage,
  .{{ hero_class }}.aura-hero--has-banner-image .aura-hero__orb {
    display: none;
  }

  .{{ hero_class }}.aura-hero--has-banner-image .aura-hero__media-shell {
    min-height: 26rem;
  }

  .{{ hero_class }} .aura-hero__stage {
    position: absolute;
    width: 29rem;
    height: 29rem;
    right: 1.5rem;
    top: 50%;
    transform: translateY(-50%);
    border-radius: 50%;
    background:
      radial-gradient(circle at 36% 34%, rgba(255, 255, 255, 0.62), rgba(255, 255, 255, 0) 32%),
      linear-gradient(135deg, rgba(247, 209, 224, 0.92), rgba(238, 189, 212, 0.72));
    opacity: 0.78;
  }

  .{{ hero_class }} .aura-hero__orb {
    position: absolute;
    border-radius: 50%;
    box-shadow: 0 14px 34px rgba(129, 57, 82, 0.08);
    z-index: 1;
  }

  .{{ hero_class }} .aura-hero__orb--one {
    width: 6.4rem;
    height: 6.4rem;
    left: 1.8rem;
    bottom: 3rem;
    background: linear-gradient(135deg, rgba(191, 71, 127, 0.42), rgba(236, 148, 189, 0.22));
    opacity: 0.92;
  }

  .{{ hero_class }} .aura-hero__orb--two {
    width: 8rem;
    height: 8rem;
    right: 2rem;
    top: 8.6rem;
    background: linear-gradient(135deg, rgba(255, 229, 222, 0.86), rgba(250, 201, 216, 0.36));
    opacity: 0.88;
  }

  .{{ hero_class }} .aura-hero__picture {
    position: relative;
    z-index: 2;
    display: block;
    width: 100%;
    max-width: 38rem;
    margin: 0 auto;
  }

  .{{ hero_class }} .aura-hero__image {
    width: 100%;
    max-height: 35rem;
    object-fit: contain;
    filter: drop-shadow(0 28px 60px rgba(80, 40, 45, 0.16));
  }

  .{{ hero_class }} .aura-hero__mock-products {
    position: relative;
    z-index: 2;
    min-height: 30rem;
  }

  .{{ hero_class }} .aura-hero__product {
    position: absolute;
    display: grid;
    place-items: center;
    border: 1px solid rgba(134, 72, 74, 0.16);
    color: rgba(60, 25, 30, 0.62);
    font-family: var(--font-heading--family);
    letter-spacing: 0.12em;
    text-align: center;
    background: linear-gradient(90deg, #f7c1b4, #fff6ee 38%, #c77d73 100%);
    box-shadow: 0 30px 70px rgba(80, 40, 45, 0.16);
  }

  .{{ hero_class }} .aura-hero__product span {
    pointer-events: none;
    font-size: 0.75rem;
    text-transform: uppercase;
  }

  .{{ hero_class }} .aura-hero__product--bottle {
    width: 6.75rem;
    height: 16rem;
    left: 8.5rem;
    bottom: 3.6rem;
    border-radius: 1.1rem 1.1rem 1.7rem 1.7rem;
  }

  .{{ hero_class }} .aura-hero__product--bottle::before {
    content: "";
    position: absolute;
    top: -4.35rem;
    width: 2.9rem;
    height: 4.4rem;
    border-radius: 1.45rem 1.45rem 0 0;
    background: linear-gradient(90deg, #be8d62, #fff0d6, #9f6744);
  }

  .{{ hero_class }} .aura-hero__product--tube {
    width: 8.2rem;
    height: 20rem;
    left: 17.1rem;
    bottom: 4.7rem;
    border-radius: 4.3rem 4.3rem 1.35rem 1.35rem;
    background: linear-gradient(90deg, #d08382, #f8c4bb, #b46568);
  }

  .{{ hero_class }} .aura-hero__product--jar {
    width: 15rem;
    height: 7.4rem;
    right: 4.5rem;
    bottom: 4.35rem;
    border-radius: 1.45rem 1.45rem 2.8rem 2.8rem;
    background: linear-gradient(90deg, #f8d8c8, #fff9f3, #d7a786);
  }

  .{{ hero_class }} .aura-hero__product--jar::before {
    content: "";
    position: absolute;
    top: -2.15rem;
    width: 13.7rem;
    height: 2.9rem;
    border-radius: 1rem;
    background: linear-gradient(90deg, #a8754f, #ffe8bd, #8d5b40);
  }

  .{{ hero_class }} .aura-hero__floating-cards {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
  }

  .{{ hero_class }} .aura-hero__floating-card {
    position: absolute;
    min-width: 11rem;
    max-width: 13.5rem;
    padding: 1rem 1.15rem;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.7);
    background: var(--aura-hero-card-background);
    box-shadow: 0 18px 45px rgba(129, 57, 82, 0.12);
    backdrop-filter: blur(12px);
    color: var(--aura-hero-card-foreground);
  }

  .{{ hero_class }} .aura-hero__floating-card--top-right {
    top: 1.6rem;
    right: 2rem;
  }

  .{{ hero_class }} .aura-hero__floating-card--middle-left {
    top: 9.8rem;
    right: 2.4rem;
  }

  .{{ hero_class }} .aura-hero__floating-card--bottom-right {
    right: 0.2rem;
    bottom: 3.4rem;
  }

  .{{ hero_class }} .aura-hero__floating-card--bottom-left {
    left: 0;
    bottom: 3rem;
  }

  .{{ hero_class }} .aura-hero__floating-icon {
    width: 1.65rem;
    height: 1.65rem;
    margin-bottom: 0.45rem;
    color: var(--aura-primary-color);
  }

  .{{ hero_class }} .aura-hero__floating-eyebrow {
    color: var(--aura-primary-color);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .{{ hero_class }} .aura-hero__floating-heading {
    margin-top: 0.15rem;
    font-family: var(--font-heading--family);
    font-size: 1.9rem;
    line-height: 1;
    color: var(--aura-heading-color);
  }

  .{{ hero_class }} .aura-hero__floating-card--middle-left .aura-hero__floating-heading,
  .{{ hero_class }} .aura-hero__floating-card--bottom-right .aura-hero__floating-heading,
  .{{ hero_class }} .aura-hero__floating-card--bottom-left .aura-hero__floating-heading {
    font-family: var(--font-primary--family);
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .{{ hero_class }} .aura-hero__floating-text {
    margin-top: 0.1rem;
    color: #6f5b63;
    font-size: 0.88rem;
    line-height: 1.4;
  }

  @media (max-width: 989px) {
    .{{ hero_class }} .aura-hero__grid,
    .{{ hero_class }}.aura-hero--reverse .aura-hero__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
      min-height: auto;
    }

    .{{ hero_class }} .aura-hero__content {
      max-width: none;
    }

    .{{ hero_class }} .aura-hero__media-shell {
      min-height: 26rem;
    }

    .{{ hero_class }} .aura-hero__stage {
      width: 23rem;
      height: 23rem;
      right: 2rem;
    }

    .{{ hero_class }} .aura-hero__product--bottle {
      left: 4.2rem;
    }

    .{{ hero_class }} .aura-hero__product--tube {
      left: 12.5rem;
    }

    .{{ hero_class }} .aura-hero__product--jar {
      right: 2rem;
    }

    .{{ hero_class }} .aura-hero__floating-card--middle-left {
      top: 8.9rem;
      right: 1rem;
      left: auto;
    }
  }

  @media (max-width: 767px) {
    .{{ hero_class }} .aura-hero__shell {
      width: min(1160px, calc(100% - 32px));
      padding-top: var(--aura-hero-padding-top-mobile);
      padding-bottom: var(--aura-hero-padding-bottom-mobile);
    }

    .{{ hero_class }} .aura-hero__grid {
      min-height: var(--aura-hero-min-height-mobile);
    }

    .{{ hero_class }} .aura-hero__heading {
      font-size: min(calc(var(--aura-hero-heading-size) * 0.7), 4rem);
    }

    .{{ hero_class }} .aura-hero__button {
      width: 100%;
    }

    .{{ hero_class }} .aura-hero__social-proof {
      align-items: flex-start;
      flex-wrap: wrap;
    }

    .{{ hero_class }} .aura-hero__media-shell {
      min-height: 20rem;
      transform: scale(0.9);
      transform-origin: top center;
    }

    .{{ hero_class }} .aura-hero__decor {
      opacity: 0.55;
    }

    .{{ hero_class }} .aura-hero__stage {
      width: 16rem;
      height: 16rem;
      right: 50%;
      top: 52%;
      transform: translate(50%, -50%);
    }

    .{{ hero_class }} .aura-hero__orb {
      box-shadow: none;
    }

    .{{ hero_class }} .aura-hero__orb--one {
      width: 4.5rem;
      height: 4.5rem;
      left: 1rem;
      bottom: 1.2rem;
    }

    .{{ hero_class }} .aura-hero__orb--two {
      width: 5rem;
      height: 5rem;
      right: 1rem;
      top: 3rem;
    }

    .{{ hero_class }}.aura-hero--has-banner-image .aura-hero__media {
      display: none;
    }

    .{{ hero_class }} .aura-hero__banner-image {
      object-position: center;
    }

    .{{ hero_class }} .aura-hero__floating-cards {
      display: none;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Aura hero banner",
  "tag": "section",
  "class": "section-aura-hero-banner",
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Loyalty. Rewards. Beauty."
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Glow more.\nEarn more."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Rich text",
      "default": "<p>Join Aura Society and unlock exclusive rewards, VIP perks, birthday gifts, referrals, and member-only beauty drops.</p>"
    },
