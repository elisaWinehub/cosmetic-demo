{% liquid
  assign rec_class = 'aura-recommend-products-' | append: section.id
  assign shown = 0
  assign limit_n = section.settings.product_limit
  assign source_collection = section.settings.collection
  if source_collection == blank
    assign source_collection = collections.all
  endif
  assign use_real = false
  if source_collection != blank
    if source_collection.products_count > 0
      assign use_real = true
    endif
  endif
%}

<section
  class="aura-recommend-products full-width {{ rec_class }}{% if section.settings.mobile_scroll %} aura-recommend-products--scroll{% endif %}"
  style="
    --arp-bg: {{ section.settings.background_color }};
    --arp-accent: {{ section.settings.accent_color }};
    --arp-badge-bg: {{ section.settings.badge_background }};
    --arp-badge-text: {{ section.settings.points_badge_color }};
    --arp-title: {{ section.settings.heading_color }};
    --arp-columns-d: {{ section.settings.columns_desktop }};
    --arp-columns-t: {{ section.settings.columns_tablet }};
    --arp-columns-m: {{ section.settings.columns_mobile }};
    --arp-gap: {{ section.settings.grid_gap }}px;
    --arp-pad-t: {{ section.settings.padding_top }}px;
    --arp-pad-b: {{ section.settings.padding_bottom }}px;
    --arp-title-size: {{ section.settings.heading_size }}px;
    --arp-card-title: {{ section.settings.card_title_size }}px;
    --arp-price-size: {{ section.settings.price_size }}px;
    --arp-radius: {{ section.settings.image_radius }}px;
    --arp-image-ratio: {{ section.settings.image_ratio }};
  "
>
  <div class="aura-recommend-products__inner">
    {% if section.settings.heading != blank %}
      <h2 class="aura-recommend-products__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}

    <div class="aura-recommend-products__grid">
      {% if use_real %}
        {% for rec_product in source_collection.products %}
          {% if rec_product.id == product.id %}
            {% continue %}
          {% endif %}
          {% if shown >= limit_n %}
            {% break %}
          {% endif %}
          {% liquid
            assign shown = shown | plus: 1
            assign p_points = rec_product.price | divided_by: 100.0 | times: section.settings.points_multiplier | round
            assign placeholder_variant = forloop.index | modulo: 6
          %}
          <article class="aura-recommend-products__card">
            <a class="aura-recommend-products__media-link" href="{{ rec_product.url }}">
              {% if section.settings.show_points_badge %}
                <span class="aura-recommend-products__badge">
                  {{ 'sections.aura_recommend_products.earn_points' | t: points: p_points, label: section.settings.points_label }}
                </span>
              {% endif %}
              {% if section.settings.show_image %}
                {% if rec_product.featured_media %}
                  {{ rec_product.featured_media | image_url: width: 800 | image_tag: class: 'aura-recommend-products__img', loading: 'lazy', alt: rec_product.title }}
                {% else %}
                  <div class="aura-recommend-products__mock">
                    <span class="aura-recommend-products__mock-shape{% if placeholder_variant == 0 %} aura-recommend-products__mock-shape--jar{% elsif placeholder_variant == 1 %} aura-recommend-products__mock-shape--tall{% endif %}"></span>
                  </div>
                {% endif %}
              {% endif %}
            </a>
            <div class="aura-recommend-products__body">
              {% if section.settings.show_title %}
                <h3 class="aura-recommend-products__title">
                  <a href="{{ rec_product.url }}">{{ rec_product.title | escape }}</a>
                </h3>
              {% endif %}
              {% if section.settings.show_price %}
                <p class="aura-recommend-products__price">{{ rec_product.price | money }}</p>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      {% endif %}

      {% if shown == 0 %}
        {% for i in (1..limit_n) %}
          {% assign placeholder_variant = i | modulo: 6 %}
          {% assign faux_points = 24 | times: i | times: section.settings.points_multiplier %}
          <article class="aura-recommend-products__card aura-recommend-products__card--placeholder">
            <div class="aura-recommend-products__media-link" tabindex="-1" aria-hidden="true">
              {% if section.settings.show_points_badge %}
                <span class="aura-recommend-products__badge">
                  {{ 'sections.aura_recommend_products.earn_points' | t: points: faux_points, label: section.settings.points_label }}
                </span>
              {% endif %}
              {% if section.settings.show_image %}
                <div class="aura-recommend-products__mock">
                  <span class="aura-recommend-products__mock-shape{% if placeholder_variant == 0 %} aura-recommend-products__mock-shape--jar{% elsif placeholder_variant == 1 %} aura-recommend-products__mock-shape--tall{% endif %}"></span>
                </div>
              {% endif %}
            </div>
            <div class="aura-recommend-products__body">
              {% if section.settings.show_title %}
                <h3 class="aura-recommend-products__title">{{ section.settings.placeholder_title | escape }}</h3>
              {% endif %}
              {% if section.settings.show_price %}
                <p class="aura-recommend-products__price">{{ 2400 | times: i | money }}</p>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .{{ rec_class }} {
    background: var(--arp-bg);
    border-bottom: 1px solid #eee1dc;
  }

  .{{ rec_class }} .aura-recommend-products__inner {
    width: min(1240px, calc(100% - 48px));
    margin: 0 auto;
    padding-top: var(--arp-pad-t);
    padding-bottom: var(--arp-pad-b);
  }

  .{{ rec_class }} .aura-recommend-products__heading {
    font-family: var(--font-heading--family, Georgia, serif);
    font-size: var(--arp-title-size);
    font-weight: 500;
    color: var(--arp-title);
    margin: 0 0 1.25rem;
    letter-spacing: -0.02em;
  }

  .{{ rec_class }} .aura-recommend-products__grid {
    display: grid;
    grid-template-columns: repeat(var(--arp-columns-d), minmax(0, 1fr));
    gap: var(--arp-gap);
  }

  .{{ rec_class }}.aura-recommend-products--scroll .aura-recommend-products__grid {
    overflow-x: auto;
    grid-auto-flow: column;
    grid-template-columns: unset;
    grid-auto-columns: minmax(160px, 1fr);
    padding-bottom: 0.35rem;
    scroll-snap-type: x mandatory;
  }

  .{{ rec_class }}.aura-recommend-products--scroll .aura-recommend-products__card {
    scroll-snap-align: start;
  }

  .{{ rec_class }} .aura-recommend-products__media-link {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 11rem;
    border-radius: var(--arp-radius);
    background: linear-gradient(135deg, #f7d1c9, #fff0eb);
    border: 1px solid #efd7d0;
    overflow: hidden;
    text-decoration: none;
    aspect-ratio: var(--arp-image-ratio);
  }

  .{{ rec_class }} .aura-recommend-products__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .{{ rec_class }} .aura-recommend-products__badge {
    position: absolute;
    left: 10px;
    bottom: 10px;
    z-index: 1;
    background: var(--arp-badge-bg);
    color: var(--arp-badge-text);
    border-radius: 999px;
    padding: 5px 9px;
    font-size: 0.625rem;
    font-weight: 900;
    letter-spacing: 0.02em;
    max-width: calc(100% - 20px);
  }

  .{{ rec_class }} .aura-recommend-products__mock {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    min-height: 10rem;
  }

  .{{ rec_class }} .aura-recommend-products__mock-shape {
    width: 44%;
    height: 58%;
    border-radius: 38% 38% 42% 42%;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.75), rgba(236, 0, 140, 0.16));
    border: 1px solid rgba(236, 0, 140, 0.18);
  }

  .{{ rec_class }} .aura-recommend-products__mock-shape--jar {
    width: 48%;
    height: 52%;
    border-radius: 18px 18px 26px 26px;
  }

  .{{ rec_class }} .aura-recommend-products__mock-shape--tall {
    width: 34%;
    height: 68%;
    border-radius: 14px 14px 18px 18px;
  }

  .{{ rec_class }} .aura-recommend-products__body {
    padding-top: 0.65rem;
  }

  .{{ rec_class }} .aura-recommend-products__title {
    margin: 0 0 0.35rem;
    font-size: var(--arp-card-title);
    line-height: 1.25;
  }

  .{{ rec_class }} .aura-recommend-products__title a {
    color: var(--arp-title);
    text-decoration: none;
    font-weight: 700;
  }

  .{{ rec_class }} .aura-recommend-products__title a:hover {
    color: var(--arp-accent);
  }

  .{{ rec_class }} .aura-recommend-products__price {
    margin: 0;
    font-size: var(--arp-price-size);
    font-weight: 800;
    color: #1f2937;
  }

  @media (max-width: 980px) {
    .{{ rec_class }} .aura-recommend-products__grid {
      grid-template-columns: repeat(var(--arp-columns-t), minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .{{ rec_class }} .aura-recommend-products__inner {
      width: min(100% - 28px, 1240px);
    }

    .{{ rec_class }}:not(.aura-recommend-products--scroll) .aura-recommend-products__grid {
      grid-template-columns: repeat(var(--arp-columns-m), minmax(0, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Aura recommended products",
  "tag": "section",
  "class": "aura-recommend-products-section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You may also love"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Leave empty to use the All collection (still excludes current product)."
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Product limit",
      "default": 6
    },
    {
      "type": "range",
      "id": "points_multiplier",
      "min": 0,
      "max": 20,
      "step": 1,
      "label": "Points per $1",
      "default": 1
    },
    {
      "type": "text",
      "id": "points_label",
      "label": "Points label",
      "default": "Glow Points"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Show image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show title",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_points_badge",
      "label": "Show points pill",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "mobile_scroll",
      "label": "Horizontal scroll on mobile",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Title color",
      "default": "#1B2C58"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent (hover)",
      "default": "#EC008C"
    },
    {
      "type": "color",
      "id": "badge_background",
      "label": "Points pill background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "points_badge_color",
      "label": "Points pill text",
      "default": "#EC008C"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "default": "1 / 1",
      "options": [
        { "value": "1 / 1", "label": "Square" },
        { "value": "4 / 5", "label": "Portrait" },
        { "value": "3 / 4", "label": "Tall" }
      ]
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 28,
      "step": 2,
      "unit": "px",
      "label": "Image radius",
      "default": 10
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns desktop",
      "default": "6",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" },
        { "value": "6", "label": "6" }
      ]
    },
    {
      "type": "select",
      "id": "columns_tablet",
      "label": "Columns tablet",
      "default": "3",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ]
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns mobile",
      "default": "2",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ]
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Grid gap",
      "default": 24
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 34
    },
    {
      "type": "range",
      "id": "card_title_size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Card title size",
      "default": 13
    },
    {
      "type": "range",
      "id": "price_size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Price size",
      "default": 13
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 52
    },
    {
      "type": "text",
      "id": "placeholder_title",
      "label": "Placeholder product title",
      "default": "Aura favorite"
    }
  ],
  "presets": [
    {
      "name": "Aura recommended products"
    }
  ]
}
{% endschema %}
