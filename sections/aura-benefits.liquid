{% assign benefits_class = 'aura-benefits-' | append: section.id %}

<section
  class="aura-benefits full-width {{ benefits_class }}"
  style="
    --aura-benefits-background: {{ section.settings.background_color }};
    --aura-benefits-card-background: {{ section.settings.card_background }};
    --aura-benefits-icon-color: {{ section.settings.icon_color }};
    --aura-benefits-text-color: {{ section.settings.text_color }};
    --aura-benefits-columns-desktop: {{ section.settings.columns_desktop }};
    --aura-benefits-columns-tablet: {{ section.settings.columns_tablet }};
    --aura-benefits-columns-mobile: {{ section.settings.columns_mobile }};
    --aura-benefits-gap: {{ section.settings.grid_gap }}px;
    --aura-benefits-padding-top: {{ section.settings.padding_top }}px;
    --aura-benefits-padding-bottom: {{ section.settings.padding_bottom }}px;
    --aura-benefits-heading-size: {{ section.settings.heading_size }}px;
    --aura-benefits-card-title-size: {{ section.settings.card_title_size }}px;
    --aura-benefits-body-size: {{ section.settings.body_size }}px;
  "
>
  <div class="aura-benefits__inner">
    {% if section.settings.heading != blank %}
      <div class="aura-benefits__header">
        <h2 class="aura-benefits__heading">{{ section.settings.heading | escape }}</h2>
      </div>
    {% endif %}

    <div class="aura-benefits__grid">
      {% for block in section.blocks %}
        <article class="aura-benefits__card" {{ block.shopify_attributes }}>
          <div class="aura-benefits__icon">
            {% if block.settings.custom_svg != blank %}
              {{ block.settings.custom_svg }}
            {% else %}
              {% render 'aura-icon', icon: block.settings.icon %}
            {% endif %}
          </div>

          {% if block.settings.heading != blank %}
            <h3 class="aura-benefits__card-heading">{{ block.settings.heading | escape }}</h3>
          {% endif %}

          {% if block.settings.text != blank %}
            <p class="aura-benefits__card-text">{{ block.settings.text | escape }}</p>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% style %}
  .{{ benefits_class }} {
    background: var(--aura-benefits-background);
    color: var(--aura-benefits-text-color);
  }

  .{{ benefits_class }} .aura-benefits__inner {
    width: min(1160px, calc(100% - 48px));
    margin: 0 auto;
    padding-top: var(--aura-benefits-padding-top);
    padding-bottom: var(--aura-benefits-padding-bottom);
  }

  .{{ benefits_class }} .aura-benefits__header {
    margin-bottom: 1.7rem;
    text-align: center;
  }

  .{{ benefits_class }} .aura-benefits__heading {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: var(--aura-benefits-heading-size);
    font-weight: 500;
    letter-spacing: -0.04em;
    color: #171012;
  }

  .{{ benefits_class }} .aura-benefits__grid {
    display: grid;
    grid-template-columns: repeat(var(--aura-benefits-columns-desktop), minmax(0, 1fr));
    gap: var(--aura-benefits-gap);
  }

  .{{ benefits_class }} .aura-benefits__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    min-height: 100%;
    padding: 2.25rem 1.5rem;
    text-align: center;
    border: 1px solid rgba(129, 57, 82, 0.12);
    border-radius: 1rem;
    background: var(--aura-benefits-card-background);
    box-shadow: 0 12px 32px rgba(150, 92, 104, 0.06);
  }

  .{{ benefits_class }} .aura-benefits__icon {
    display: grid;
    place-items: center;
    width: 3.75rem;
    height: 3.75rem;
    margin-bottom: 1rem;
    padding: 0.95rem;
    border-radius: 999px;
    background: #fff0f3;
    color: var(--aura-benefits-icon-color);
  }

  .{{ benefits_class }} .aura-benefits__icon .aura-icon,
  .{{ benefits_class }} .aura-benefits__icon svg {
    width: 100%;
    height: 100%;
  }

  .{{ benefits_class }} .aura-benefits__card-heading {
    margin: 0 0 0.75rem;
    font-size: var(--aura-benefits-card-title-size);
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .{{ benefits_class }} .aura-benefits__card-text {
    margin: 0;
    color: #4c3940;
    font-size: var(--aura-benefits-body-size);
    line-height: 1.55;
  }

  @media (max-width: 989px) {
    .{{ benefits_class }} .aura-benefits__grid {
      grid-template-columns: repeat(var(--aura-benefits-columns-tablet), minmax(0, 1fr));
    }
  }

  @media (max-width: 767px) {
    .{{ benefits_class }} .aura-benefits__inner {
      width: min(1160px, calc(100% - 32px));
    }

    .{{ benefits_class }} .aura-benefits__heading {
      font-size: min(calc(var(--aura-benefits-heading-size) * 0.82), 2.2rem);
    }

    .{{ benefits_class }} .aura-benefits__grid {
      grid-template-columns: repeat(var(--aura-benefits-columns-mobile), minmax(0, 1fr));
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Aura benefits",
  "tag": "section",
  "class": "section-aura-benefits",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "More benefits. More glow."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f9f2f1"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#fffaf9"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#b35a76"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#4a2435"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 56,
      "step": 2,
      "unit": "px",
      "default": 34
    },
    {
      "type": "range",
      "id": "card_title_size",
      "label": "Card heading size",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body size",
      "min": 13,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns desktop",
      "default": "4",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ]
    },
    {
      "type": "select",
      "id": "columns_tablet",
      "label": "Columns tablet",
      "default": "2",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ]
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns mobile",
      "default": "1",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ]
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Card spacing",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "points",
          "options": [
            { "value": "points", "label": "Points" },
            { "value": "crown", "label": "Crown" },
            { "value": "community", "label": "Community" },
            { "value": "gift", "label": "Gift" },
            { "value": "sparkle", "label": "Sparkle" }
          ]
        },
        {
          "type": "textarea",
          "id": "custom_svg",
          "label": "Custom SVG code"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Earn points"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Earn points every time you shop and redeem them for exclusive rewards."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aura benefits",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon": "points",
            "heading": "Earn points",
            "text": "Earn points every time you shop and redeem them for exclusive rewards."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "crown",
            "heading": "VIP tiers",
            "text": "Unlock Glow, Muse, and Elite tiers for early access, perks, and special surprises."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "community",
            "heading": "Referral rewards",
            "text": "Invite your beauty circle and earn bonus credits when friends place their first order."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "gift",
            "heading": "Birthday gifts",
            "text": "Celebrate your month with bonus points and curated rewards delivered automatically."
          }
        }
      ]
    }
  ]
}
{% endschema %}
