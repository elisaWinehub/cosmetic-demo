{% comment %}
  Aura Society — /cart template. All styles scoped under .aura-cart-page.
{% endcomment %}

{% liquid
  assign order_pts = cart.total_price | times: section.settings.points_multiplier | divided_by: 100.0 | round
  assign tax_cents = 0
  for tl in cart.tax_lines
    assign tax_cents = tax_cents | plus: tl.price
  endfor

  assign rec_coll = section.settings.rec_collection
  if rec_coll == blank and section.settings.show_recommendations
    if collections['all'] != blank
      assign rec_coll = collections['all']
    endif
  endif

  assign hero_img = section.settings.hero_image
  if section.settings.hero_image_mobile != blank
    assign hero_img_m = section.settings.hero_image_mobile
  else
    assign hero_img_m = section.settings.hero_image
  endif
%}

<div
  id="AuraCartPage-{{ section.id }}"
  class="aura-cart-page"
  data-aura-cart-page
  data-section-id="{{ section.id }}"
  data-cart-change-url="{{ routes.cart_change_url | append: '.js' | escape }}"
  data-cart-update-url="{{ routes.cart_update_url | escape }}"
  data-cart-json-url="{{ routes.cart_url | append: '.js' | escape }}"
  data-cart-add-url="{{ routes.cart_add_url | append: '.js' | escape }}"
  data-money-format="{{ shop.money_format | escape }}"
  data-currency-symbol="{{ cart.currency.symbol | escape }}"
  data-points-mult="{{ section.settings.points_multiplier }}"
  data-points-label="{{ section.settings.points_label | escape }}"
  data-i18n-banner="{{ 'sections.aura_cart_page.js_points_banner_html' | t | escape }}"
  data-i18n-pts-sub="{{ 'sections.aura_cart_page.js_points_summary' | t | escape }}"
  data-i18n-earn-line="{{ 'sections.aura_cart_page.js_earn_line' | t | escape }}"
  data-i18n-pts-val="{{ 'sections.aura_cart_page.js_pts_val' | t | escape }}"
  data-pts-abbr="{{ 'sections.aura_cart_page.pts_abbr' | t | escape }}"
  style="
    --acp-radius: {{ section.settings.card_radius }}px;
    --acp-heading: {{ section.settings.heading_color }};
    --acp-text: {{ section.settings.text_color }};
    --acp-accent: {{ section.settings.accent_pink }};
    --acp-border: {{ section.settings.border_color }};
    --acp-blush: {{ section.settings.blush_bg }};
    --acp-blush-deep: {{ section.settings.blush_hero_start }};
    --acp-card-bg: {{ section.settings.card_bg }};
    --acp-navy-btn: {{ section.settings.button_navy }};
    --acp-g1: {{ section.settings.gradient_start }};
    --acp-g2: {{ section.settings.gradient_end }};
    --acp-pad-y: {{ section.settings.padding_y }}px;
  "
>
  <div class="aura-cart-page__hero">
    <div class="aura-cart-page__hero-inner">
      <div class="aura-cart-page__hero-copy">
        <p class="aura-cart-page__hero-heading">{{ section.settings.hero_heading | escape }}</p>
        <p class="aura-cart-page__hero-text">{{ section.settings.hero_text | escape }}</p>
      </div>
      <div class="aura-cart-page__hero-visual" aria-hidden="true">
        {% if hero_img != blank %}
          {{
            hero_img
            | image_url: width: 900
            | image_tag:
              loading: 'lazy',
              class: 'aura-cart-page__hero-img aura-cart-page__hero-img--desktop',
              widths: '400, 600, 900',
              alt: section.settings.hero_image_alt | default: section.settings.hero_heading
          }}
          {% if hero_img_m != blank and hero_img_m.id != hero_img.id %}
            {{
              hero_img_m
              | image_url: width: 700
              | image_tag:
                loading: 'lazy',
                class: 'aura-cart-page__hero-img aura-cart-page__hero-img--mobile',
                widths: '360, 500, 700',
                alt: section.settings.hero_image_alt | default: section.settings.hero_heading
            }}
          {% endif %}
        {% endif %}
      </div>
    </div>
  </div>

  <div class="aura-cart-page__wrap">
    {% if cart.item_count == 0 %}
      <div class="aura-cart-page__empty">
        <p class="aura-cart-page__empty-title">{{ 'sections.aura_cart_page.empty_title' | t }}</p>
        <p class="aura-cart-page__empty-text">{{ 'sections.aura_cart_page.empty_text' | t }}</p>
        <a class="aura-cart-page__empty-btn" href="{{ routes.root_url }}">{{ 'sections.aura_cart_page.continue_shopping' | t }}</a>
      </div>
    {% else %}
      <div class="aura-cart-page__grid">
        <div class="aura-cart-page__main-col">
          <div class="aura-cart-page__table-head" aria-hidden="true">
            <span>{{ 'sections.aura_cart_page.col_product' | t }}</span>
            <span>{{ 'sections.aura_cart_page.col_price' | t }}</span>
            <span>{{ 'sections.aura_cart_page.col_qty' | t }}</span>
            <span>{{ 'sections.aura_cart_page.col_total' | t }}</span>
            <span class="aura-cart-page__table-head-spacer"></span>
          </div>

          <div class="aura-cart-page__items" data-aura-cart-items>
            {% for item in cart.items %}
              {% assign lp = item.final_line_price | times: section.settings.points_multiplier | divided_by: 100.0 | round %}
              {% render 'aura-cart-item', item: item, section: section, line_points: lp %}
            {% endfor %}
          </div>

          <div class="aura-cart-page__points-banner">
            <span class="aura-cart-page__points-banner-ic" aria-hidden="true">✦</span>
            <p class="aura-cart-page__points-banner-text">
              {{ 'sections.aura_cart_page.points_order_notice_html' | t: points: order_pts, label: section.settings.points_label }}
            </p>
          </div>

          {% if section.settings.show_recommendations and rec_coll != blank %}
            <section class="aura-cart-page__recommendations">
              <div class="aura-cart-page__rec-head">
                <p class="aura-cart-page__rec-title">{{ 'sections.aura_cart_page.rec_title' | t }}</p>
                <a class="aura-cart-page__rec-all" href="{{ rec_coll.url }}">{{ 'sections.aura_cart_page.rec_view_all' | t }}</a>
              </div>
              <div class="aura-cart-page__rec-grid">
                {% for product in rec_coll.products limit: section.settings.rec_limit %}
                  {% render 'aura-cart-recommendation-card', product: product, section: section %}
                {% else %}
                  <p class="aura-cart-page__rec-fallback">{{ 'sections.aura_cart_page.rec_empty' | t }}</p>
                {% endfor %}
              </div>
            </section>
          {% endif %}
        </div>

        <aside class="aura-cart-page__aside">
          <div class="aura-cart-page__summary">
            <p class="aura-cart-page__summary-title">{{ 'sections.aura_cart_page.order_summary' | t }}</p>

            <dl class="aura-cart-page__summary-rows">
              <div class="aura-cart-page__summary-row">
                <dt>{{ 'sections.aura_cart_page.subtotal' | t }}</dt>
                <dd data-aura-cart-subtotal>{{ cart.items_subtotal_price | money }}</dd>
              </div>
              <div class="aura-cart-page__summary-row">
                <dt>{{ 'sections.aura_cart_page.taxes' | t }}</dt>
                <dd data-aura-cart-tax>
                  {% if section.settings.tax_mode == 'note' %}
                    {{ section.settings.tax_note | escape }}
                  {% elsif tax_cents > 0 %}
                    {{ tax_cents | money }}
                  {% else %}
                    {{ section.settings.tax_note | escape }}
                  {% endif %}
                </dd>
              </div>
              <div class="aura-cart-page__summary-row aura-cart-page__summary-row--total">
                <dt>{{ 'sections.aura_cart_page.estimated_total' | t }}</dt>
                <dd data-aura-cart-total>{{ cart.total_price | money }}</dd>
              </div>
            </dl>

            {% form 'cart', cart, class: 'aura-cart-page__checkout-form' %}
              <button type="submit" name="checkout" class="aura-cart-page__summary-checkout">
                {{ 'sections.aura_cart_page.checkout' | t }}
              </button>
              {% if section.settings.show_dynamic_checkout %}
                <div class="aura-cart-page__summary-wallet">
                  {{ form | payment_button }}
                </div>
              {% endif %}
            {% endform %}

            {% if section.settings.show_summary_points %}
              <div class="aura-cart-page__summary-points">
                <div class="aura-cart-page__summary-points-top">
                  <span class="aura-cart-page__summary-points-lbl">
                    <span aria-hidden="true">✦</span> {{ section.settings.points_label | escape }}
                  </span>
                  <span class="aura-cart-page__summary-points-val" data-aura-cart-pts-val>{{ order_pts }} {{ 'sections.aura_cart_page.pts_abbr' | t }}</span>
                </div>
                <p class="aura-cart-page__summary-points-sub" data-aura-cart-pts-sub>
                  {{ 'sections.aura_cart_page.points_summary_sub' | t: points: order_pts, label: section.settings.points_label }}
                </p>
              </div>
            {% endif %}

            {% if section.settings.show_promo %}
              <details class="aura-cart-page__promo">
                <summary class="aura-cart-page__promo-sum">{{ 'sections.aura_cart_page.promo_toggle' | t }}</summary>
                <div class="aura-cart-page__promo-body">
                  <label class="visually-hidden" for="AuraCartPromo-{{ section.id }}">{{ 'sections.aura_cart_page.promo_label' | t }}</label>
                  <input
                    type="text"
                    id="AuraCartPromo-{{ section.id }}"
                    class="aura-cart-page__promo-input"
                    data-aura-cart-promo-input
                    placeholder="{{ 'sections.aura_cart_page.promo_placeholder' | t }}"
                    autocomplete="off"
                  >
                  <button type="button" class="aura-cart-page__promo-apply" data-aura-cart-promo-apply>
                    {{ 'sections.aura_cart_page.promo_apply' | t }}
                  </button>
                  <p class="aura-cart-page__promo-msg" data-aura-cart-promo-msg hidden></p>
                </div>
              </details>
            {% endif %}

            {% if section.settings.show_secure_card %}
              <div class="aura-cart-page__secure">
                <div class="aura-cart-page__secure-head">
                  <span class="aura-cart-page__secure-ic" aria-hidden="true">🛡</span>
                  <p>{{ 'sections.aura_cart_page.secure_title' | t }}</p>
                </div>
                <p class="aura-cart-page__secure-text">{{ 'sections.aura_cart_page.secure_text' | t }}</p>
                <div class="aura-cart-page__secure-pay" aria-hidden="true">
                  {% for type in shop.enabled_payment_types limit: 8 %}
                    {{ type | payment_type_svg_tag: class: 'aura-cart-page__pay-ic' }}
                  {% endfor %}
                </div>
              </div>
            {% endif %}
          </div>
        </aside>
      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .aura-cart-page {
    --acp-font-heading: var(--font-heading--family, Georgia, 'Times New Roman', serif);
    --acp-font-body: var(--font-body--family, system-ui, sans-serif);
    box-sizing: border-box;
    color: var(--acp-text);
    padding-bottom: var(--acp-pad-y);
    overflow-x: hidden;
  }

  .aura-cart-page *,
  .aura-cart-page *::before,
  .aura-cart-page *::after {
    box-sizing: border-box;
  }

  .aura-cart-page .visually-hidden {
    position: absolute !important;
    height: 1px;
    width: 1px;
    overflow: hidden;
    clip: rect(1px, 1px, 1px, 1px);
    white-space: nowrap;
  }

  .aura-cart-page__hero {
    background: linear-gradient(120deg, var(--acp-blush-deep) 0%, var(--acp-blush) 55%, #fff 100%);
    margin-bottom: clamp(1.25rem, 3vw, 2.5rem);
  }

  .aura-cart-page__hero-inner {
    width: min(1200px, calc(100% - 40px));
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    align-items: center;
    padding: clamp(1.5rem, 4vw, 2.75rem) 0;
  }

  @media (min-width: 840px) {
    .aura-cart-page__hero-inner {
      grid-template-columns: minmax(0, 1fr) minmax(240px, 42%);
      gap: 2rem;
    }
  }

  .aura-cart-page__hero-heading {
    font-family: var(--acp-font-heading);
    color: var(--acp-heading);
    font-size: clamp(1.85rem, 4.5vw, 2.75rem);
    font-weight: 600;
    margin: 0 0 0.5rem;
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .aura-cart-page__hero-text {
    font-family: var(--acp-font-body);
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.5;
    color: var(--acp-text);
    max-width: 36ch;
  }

  .aura-cart-page__hero-visual {
    border-radius: var(--acp-radius);
    overflow: hidden;
    min-height: 160px;
    background: color-mix(in srgb, var(--acp-accent) 8%, transparent);
  }

  .aura-cart-page__hero-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    max-height: 280px;
  }

  .aura-cart-page__hero-img--mobile {
    display: block;
  }

  .aura-cart-page__hero-img--desktop {
    display: none;
  }

  @media (min-width: 840px) {
    .aura-cart-page__hero-img--desktop {
      display: block;
    }
    .aura-cart-page__hero-img--mobile {
      display: none;
    }
  }

  .aura-cart-page__wrap {
    width: min(1200px, calc(100% - 40px));
    margin: 0 auto;
  }

  .aura-cart-page__empty {
    text-align: center;
    padding: 3rem 1rem 4rem;
    border: 1px solid var(--acp-border);
    border-radius: var(--acp-radius);
    background: var(--acp-card-bg);
  }

  .aura-cart-page__empty-title {
    font-family: var(--acp-font-heading);
    font-size: 1.5rem;
    color: var(--acp-heading);
    margin: 0 0 0.5rem;
  }

  .aura-cart-page__empty-text {
    margin: 0 0 1.25rem;
  }

  .aura-cart-page__empty-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.65rem 1.35rem;
    border-radius: var(--acp-radius);
    background: linear-gradient(90deg, var(--acp-g1), var(--acp-g2));
    color: #fff;
    font-weight: 700;
    text-decoration: none;
    font-size: 0.9rem;
  }

  .aura-cart-page__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.75rem;
    align-items: start;
  }

  @media (min-width: 990px) {
    .aura-cart-page__grid {
      grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
      gap: 2.25rem;
    }
  }

  .aura-cart-page__table-head {
    display: none;
    grid-template-columns: minmax(0, 2fr) 100px 120px minmax(6.5rem, 1fr) 40px;
    gap: 0.75rem;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--acp-heading);
    padding: 0 0.25rem 0.5rem;
    border-bottom: 1px solid var(--acp-border);
    margin-bottom: 0.75rem;
  }

  @media (min-width: 990px) {
    .aura-cart-page__table-head {
      display: grid;
    }
  }

  .aura-cart-page__items {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .aura-cart-page__item {
    padding: 1rem;
    border: 1px solid var(--acp-border);
    border-radius: var(--acp-radius);
    background: var(--acp-card-bg);
    display: grid;
    gap: 0.65rem 0.75rem;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      'product product'
      'price price'
      'qty qty'
      'total remove';
    align-items: center;
  }

  @media (min-width: 990px) {
    .aura-cart-page__item {
      grid-template-columns: minmax(0, 2fr) 100px 120px minmax(6.5rem, 1fr) 40px;
      grid-template-areas: 'product price qty total remove';
      padding: 1.1rem 1.15rem;
      align-items: center;
      column-gap: 0.75rem;
      row-gap: 0.5rem;
    }
  }

  .aura-cart-page__item-product {
    grid-area: product;
    display: grid;
    grid-template-columns: 88px minmax(0, 1fr);
    gap: 1rem;
    min-width: 0;
    align-items: start;
  }

  @media (min-width: 990px) {
    .aura-cart-page__item-product {
      grid-template-columns: 100px minmax(0, 1fr);
    }
  }

  .aura-cart-page__item-copy {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .aura-cart-page__item-price-col {
    grid-area: price;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }

  @media (min-width: 990px) {
    .aura-cart-page__item-price-col {
      justify-self: stretch;
      text-align: center;
      align-items: center;
    }
  }

  .aura-cart-page__item-qty-col {
    grid-area: qty;
    min-width: 0;
  }

  @media (min-width: 990px) {
    .aura-cart-page__item-qty-col {
      justify-self: center;
      display: flex;
      justify-content: center;
      width: 100%;
    }
  }

  .aura-cart-page__item-total-col {
    grid-area: total;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }

  @media (min-width: 990px) {
    .aura-cart-page__item-total-col {
      justify-self: stretch;
      text-align: right;
      align-items: flex-end;
    }
  }

  .aura-cart-page__item-img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: calc(var(--acp-radius) * 0.65);
    background: var(--acp-blush);
  }

  .aura-cart-page__item-img-link {
    display: block;
    text-decoration: none;
  }

  .aura-cart-page__item-img-fallback {
    aspect-ratio: 1;
    border-radius: calc(var(--acp-radius) * 0.65);
    background: var(--acp-blush);
    display: grid;
    place-items: center;
  }

  .aura-cart-page__item-ph {
    width: 60%;
    opacity: 0.35;
  }

  .aura-cart-page__item-title {
    font-family: var(--acp-font-body);
    font-weight: 700;
    color: var(--acp-heading);
    text-decoration: none;
    font-size: 1rem;
    line-height: 1.3;
  }

  .aura-cart-page__item-title:hover {
    text-decoration: underline;
  }

  .aura-cart-page__item-variant {
    margin: 0;
    font-size: 0.8125rem;
    color: #6b7280;
  }

  .aura-cart-page__item-pill {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    width: fit-content;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--acp-accent);
    background: color-mix(in srgb, var(--acp-accent) 12%, #fff);
  }

  .aura-cart-page__item-price-label,
  .aura-cart-page__item-total-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #7d8491;
  }

  @media (min-width: 990px) {
    .aura-cart-page__item-price-label,
    .aura-cart-page__item-total-label {
      display: none;
    }

    .aura-cart-page__item-price {
      text-align: center;
    }
  }

  .aura-cart-page__item-price,
  .aura-cart-page__item-line {
    font-weight: 700;
    color: var(--acp-heading);
    font-variant-numeric: tabular-nums;
  }

  .aura-cart-page__qty {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--acp-border);
    border-radius: 999px;
    overflow: hidden;
    background: #fff;
    width: fit-content;
  }

  .aura-cart-page__qty-btn {
    width: 40px;
    height: 40px;
    border: 0;
    background: #faf7f8;
    color: var(--acp-heading);
    font-size: 1.1rem;
    line-height: 1;
    cursor: pointer;
    padding: 0;
    display: grid;
    place-items: center;
  }

  .aura-cart-page__qty-btn:hover {
    background: #f0e8ec;
  }

  .aura-cart-page__qty-input {
    width: 44px;
    border: 0;
    text-align: center;
    font-weight: 700;
    font-size: 0.95rem;
    background: #fff;
    color: var(--acp-heading);
    -moz-appearance: textfield;
  }

  .aura-cart-page__qty-input::-webkit-outer-spin-button,
  .aura-cart-page__qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  @media (max-width: 989px) {
    .aura-cart-page__item-price-col {
      justify-self: center;
      text-align: center;
      align-items: center;
    }

    .aura-cart-page__item-qty-col {
      justify-self: center;
      display: flex;
      justify-content: center;
      grid-column: 1 / -1;
    }

    .aura-cart-page__item-total-col {
      justify-self: start;
      align-self: center;
    }
  }

  .aura-cart-page__item-remove {
    grid-area: remove;
    width: 44px;
    height: 44px;
    border: 0;
    border-radius: 50%;
    background: transparent;
    color: var(--acp-heading);
    cursor: pointer;
    display: grid;
    place-items: center;
    justify-self: end;
    align-self: center;
    margin: 0;
    padding: 0;
  }

  .aura-cart-page__item-remove:hover {
    background: #f4f0f2;
  }

  @media (min-width: 990px) {
    .aura-cart-page__item-remove {
      justify-self: center;
    }
  }

  .aura-cart-page__points-banner {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
    margin-top: 1.25rem;
    padding: 1.1rem 1.25rem;
    border-radius: var(--acp-radius);
    border: 1px solid color-mix(in srgb, var(--acp-accent) 18%, transparent);
    background: color-mix(in srgb, var(--acp-accent) 7%, #fff);
  }

  .aura-cart-page__points-banner-ic {
    flex-shrink: 0;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    border: 2px solid var(--acp-accent);
    display: grid;
    place-items: center;
    color: var(--acp-accent);
    font-size: 0.85rem;
  }

  .aura-cart-page__points-banner-text {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.45;
  }

  .aura-cart-page__points-banner-text strong {
    color: var(--acp-accent);
    font-weight: 800;
  }

  .aura-cart-page__recommendations {
    margin-top: 2.5rem;
  }

  .aura-cart-page__rec-head {
