{% javascript %}
  (function () {
    const root = document.querySelector('[data-aura-cart-page]');
    if (!root) return;

    function formatMoney(cents, moneyFormat, currencySymbol) {
      let formatted;
      if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
        formatted = Shopify.formatMoney(cents, moneyFormat);
      } else {
        formatted = (cents / 100).toFixed(2);
      }
      const sym = currencySymbol || '';
      const t = String(formatted).trim();
      if (sym && t.length && t.charAt(0) >= '0' && t.charAt(0) <= '9') {
        return sym + t;
      }
      return formatted;
    }

    function parseMoneyAttr() {
      const attrFormat = root.getAttribute('data-money-format');
      const currencySymbol = root.getAttribute('data-currency-symbol') || '';
      const moneyFormat =
        attrFormat ||
        (typeof window !== 'undefined' && window.Shopify && window.Shopify.money_format
          ? window.Shopify.money_format
          : '${{amount}}');
      return { moneyFormat, currencySymbol };
    }

    const changeUrl = root.getAttribute('data-cart-change-url');
    const updateUrl = root.getAttribute('data-cart-update-url');
    const cartJsonUrl = root.getAttribute('data-cart-json-url');
    const addUrl = root.getAttribute('data-cart-add-url');
    const ptsMult = parseFloat(root.getAttribute('data-points-mult')) || 1;
    const ptsLabel = root.getAttribute('data-points-label') || 'Glow Points';
    const ptsAbbr = root.getAttribute('data-pts-abbr') || 'PTS';
    const tplBanner = root.getAttribute('data-i18n-banner') || '';
    const tplPtsSub = root.getAttribute('data-i18n-pts-sub') || '';
    const tplEarnLine = root.getAttribute('data-i18n-earn-line') || '';
    const tplPtsVal = root.getAttribute('data-i18n-pts-val') || '';
    const { moneyFormat, currencySymbol } = parseMoneyAttr();

    function fillPtsTpl(tpl, pts, lbl) {
      return String(tpl || '')
        .replace(/__PTS__/g, String(pts))
        .replace(/__LBL__/g, String(lbl))
        .replace(/__ABBR__/g, String(ptsAbbr));
    }

    function clampRecQty(n) {
      let x = parseInt(String(n), 10);
      if (isNaN(x) || x < 1) return 1;
      if (x > 99) return 99;
      return x;
    }

    function dispatchCartUpdate(cart) {
      document.dispatchEvent(
        new CustomEvent('cart:update', {
          bubbles: true,
          detail: {
            resource: cart,
            data: {
              itemCount: cart.item_count,
              source: 'aura-cart-page',
            },
          },
        })
      );
    }

    function updateTotalsFromCart(cart) {
      const subEl = root.querySelector('[data-aura-cart-subtotal]');
      const taxEl = root.querySelector('[data-aura-cart-tax]');
      const totEl = root.querySelector('[data-aura-cart-total]');
      const ptsVal = root.querySelector('[data-aura-cart-pts-val]');
      const ptsSub = root.querySelector('[data-aura-cart-pts-sub]');
      const banner = root.querySelector('.aura-cart-page__points-banner-text');

      if (subEl && typeof cart.items_subtotal_price === 'number') {
        subEl.textContent = formatMoney(cart.items_subtotal_price, moneyFormat, currencySymbol);
      }
      if (totEl && typeof cart.total_price === 'number') {
        totEl.textContent = formatMoney(cart.total_price, moneyFormat, currencySymbol);
      }
      const taxSum =
        cart.tax_lines && Array.isArray(cart.tax_lines)
          ? cart.tax_lines.reduce(function (a, l) {
              return a + (parseInt(l.price, 10) || 0);
            }, 0)
          : 0;
      if (taxEl && taxSum > 0) {
        taxEl.textContent = formatMoney(taxSum, moneyFormat, currencySymbol);
      }

      const orderPts = Math.round((cart.total_price * ptsMult) / 100);
      if (ptsVal) {
        ptsVal.textContent = tplPtsVal
          ? fillPtsTpl(tplPtsVal, orderPts, ptsLabel)
          : orderPts + ' ' + ptsAbbr;
      }
      if (ptsSub) {
        ptsSub.textContent = tplPtsSub
          ? fillPtsTpl(tplPtsSub, orderPts, ptsLabel)
          : "You'll earn " + orderPts + ' ' + ptsLabel + ' on this order';
      }
      if (banner) {
        banner.innerHTML = tplBanner
          ? fillPtsTpl(tplBanner, orderPts, ptsLabel)
          : "You'll earn <strong>" +
            orderPts +
            ' ' +
            ptsLabel +
            '</strong> on this order! Points will be added after your order is delivered.';
      }

      const itemsRoot = root.querySelector('[data-aura-cart-items]');
      if (!itemsRoot) return;

      const keysInCart = {};
      (cart.items || []).forEach(function (it) {
        keysInCart[String(it.key)] = it;
      });

      itemsRoot.querySelectorAll('[data-aura-cart-line-key]').forEach(function (row) {
        const key = row.getAttribute('data-aura-cart-line-key');
        const it = keysInCart[key];
        if (!it) {
          row.remove();
          return;
        }
        const qIn = row.querySelector('[data-aura-line-qty]');
        const uIn = row.querySelector('[data-aura-line-unit]');
        if (qIn) qIn.value = String(it.quantity);
        row.querySelectorAll('[data-aura-line-total]').forEach(function (tEl) {
          if (tEl && typeof it.final_line_price === 'number') {
            tEl.textContent = formatMoney(it.final_line_price, moneyFormat, currencySymbol);
          }
        });
        if (uIn && typeof it.final_price === 'number') {
          uIn.textContent = formatMoney(it.final_price, moneyFormat, currencySymbol);
        }
        const linePts = Math.round((it.final_line_price * ptsMult) / 100);
        const pill = row.querySelector('.aura-cart-page__item-pill');
        if (pill) {
          pill.textContent = tplEarnLine
            ? fillPtsTpl(tplEarnLine, linePts, ptsLabel)
            : '✦ Earn ' + linePts + ' pts';
        }
      });

      if (!cart.items || cart.items.length === 0) {
        window.location.reload();
      }
    }

    function changeLine(lineKey, quantity) {
      if (!changeUrl) return Promise.reject();
      return fetch(changeUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({ id: lineKey, quantity: quantity }),
      }).then(function (res) {
        return res.json().then(function (body) {
          if (!res.ok) throw new Error(body.message || 'Cart error');
          return body;
        });
      });
    }

    root.querySelectorAll('[data-aura-cart-line-key]').forEach(function (row) {
      const key = row.getAttribute('data-aura-cart-line-key');
      const qtyInput = row.querySelector('[data-aura-line-qty]');
      const dec = row.querySelector('[data-aura-cart-qty-dec]');
      const inc = row.querySelector('[data-aura-cart-qty-inc]');
      const removeBtn = row.querySelector('[data-aura-cart-remove]');

      function setBusy(on) {
        row.classList.toggle('is-updating', on);
      }

      function applyQty(next) {
        if (next < 1) {
          setBusy(true);
          changeLine(key, 0)
            .then(function (cart) {
              dispatchCartUpdate(cart);
              updateTotalsFromCart(cart);
            })
            .catch(function () {
              window.location.reload();
            });
          return;
        }
        setBusy(true);
        changeLine(key, next)
          .then(function (cart) {
            dispatchCartUpdate(cart);
            updateTotalsFromCart(cart);
          })
          .catch(function () {
            window.location.reload();
          })
          .finally(function () {
            setBusy(false);
          });
      }

      if (dec) {
        dec.addEventListener('click', function () {
          const n = parseInt(qtyInput.value, 10) || 1;
          applyQty(n - 1);
        });
      }
      if (inc) {
        inc.addEventListener('click', function () {
          const n = parseInt(qtyInput.value, 10) || 1;
          applyQty(n + 1);
        });
      }
      if (removeBtn) {
        removeBtn.addEventListener('click', function () {
          applyQty(0);
        });
      }
    });

    const promoBtn = root.querySelector('[data-aura-cart-promo-apply]');
    const promoInput = root.querySelector('[data-aura-cart-promo-input]');
    const promoMsg = root.querySelector('[data-aura-cart-promo-msg]');
    if (promoBtn && promoInput && updateUrl) {
      promoBtn.addEventListener('click', function () {
        const code = (promoInput.value || '').trim();
        if (!code) return;
        promoBtn.disabled = true;
        fetch(updateUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({ discount: code }),
        })
          .then(function (res) {
            return res.json().then(function (body) {
              if (!res.ok) throw new Error(body.description || body.message || 'Discount error');
              return body;
            });
          })
          .then(function (cart) {
            dispatchCartUpdate(cart);
            if (promoMsg) {
              promoMsg.hidden = true;
              promoMsg.textContent = '';
            }
            window.location.reload();
          })
          .catch(function (err) {
            if (promoMsg) {
              promoMsg.hidden = false;
              promoMsg.textContent = err.message || 'Invalid code';
            }
          })
          .finally(function () {
            promoBtn.disabled = false;
          });
      });
    }

    const WISHLIST_KEY = 'aura-plp-wishlist-v2';
      function readWishlist() {
        try {
          let raw = localStorage.getItem(WISHLIST_KEY);
          if (!raw) return [];
          const parsed = JSON.parse(raw);
          return Array.isArray(parsed) ? parsed : [];
        } catch {
          return [];
        }
      }
      function writeWishlist(entries) {
        try {
          localStorage.setItem(WISHLIST_KEY, JSON.stringify(entries));
        } catch {}
      }
      function syncRecWish(btn) {
        const id = btn.getAttribute('data-product-id');
        const h = (btn.getAttribute('data-product-handle') || '').trim();
        const entries = readWishlist();
        const on = entries.some(function (e) {
          return (id && String(e.i || e.id || '') === String(id)) || (h && e.h === h);
        });
        btn.setAttribute('aria-pressed', on ? 'true' : 'false');
      }

    root.querySelectorAll('[data-aura-cart-rec-wish]').forEach(function (btn) {
      syncRecWish(btn);
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        const id = btn.getAttribute('data-product-id');
        const h = (btn.getAttribute('data-product-handle') || '').trim();
        let entries = readWishlist();
        const sid = id ? String(id) : '';
        const on = entries.some(function (e) {
          return (sid && String(e.i || '') === sid) || (h && e.h === h);
        });
        if (on) {
          entries = entries.filter(function (e) {
            return !((sid && String(e.i || '') === sid) || (h && e.h === h));
          });
        } else {
          entries = entries.concat([{ i: sid, h: h || '' }]);
        }
        writeWishlist(entries);
        root.querySelectorAll('[data-aura-cart-rec-wish]').forEach(syncRecWish);
      });
    });

    root.querySelectorAll('[data-aura-cart-rec-qty]').forEach(function (wrap) {
      const input = wrap.querySelector('[data-aura-cart-rec-qty-input]');
      const dec = wrap.querySelector('[data-aura-cart-rec-qty-dec]');
      const inc = wrap.querySelector('[data-aura-cart-rec-qty-inc]');
      if (!input || !dec || !inc) return;

      dec.addEventListener('click', function () {
        input.value = String(clampRecQty((parseInt(input.value, 10) || 1) - 1));
      });
      inc.addEventListener('click', function () {
        input.value = String(clampRecQty((parseInt(input.value, 10) || 1) + 1));
      });
    });

    root.querySelectorAll('[data-aura-cart-rec-add]').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        if (btn.disabled || !addUrl) return;
        const vid = btn.getAttribute('data-variant-id');
        if (!vid) return;

        const card = btn.closest('[data-aura-cart-rec-card]');
        const qtyInput = card ? card.querySelector('[data-aura-cart-rec-qty-input]') : null;
        const q = qtyInput ? clampRecQty(qtyInput.value) : 1;

        btn.classList.add('is-loading');
        btn.setAttribute('aria-busy', 'true');
        fetch(addUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({ items: [{ id: Number(vid), quantity: q }] }),
        })
          .then(function (res) {
            return res.json().then(function (body) {
              return { ok: res.ok, body };
            });
          })
          .then(function (r) {
            if (!r.ok) throw new Error();
            return fetch(cartJsonUrl || '/cart.js', { headers: { Accept: 'application/json' } }).then(function (x) {
              return x.json();
            });
          })
          .then(function (cart) {
            dispatchCartUpdate(cart);
            window.location.reload();
          })
          .catch(function () {
            window.location.reload();
          })
          .finally(function () {
            btn.classList.remove('is-loading');
            btn.removeAttribute('aria-busy');
          });
      });
    });
  })();
{% endjavascript %}

