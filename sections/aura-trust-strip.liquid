{% assign ts_class = 'aura-trust-strip-' | append: section.id %}

<section
  class="aura-trust-strip {{ ts_class }} full-width"
  style="
    --ats-background: {{ section.settings.background_color }};
    --ats-icon-bg: {{ section.settings.icon_background }};
    --ats-icon: {{ section.settings.icon_color }};
    --ats-heading: {{ section.settings.heading_color }};
    --ats-text: {{ section.settings.text_color }};
    --ats-columns-d: {{ section.settings.columns_desktop }};
    --ats-columns-t: {{ section.settings.columns_tablet }};
    --ats-columns-m: {{ section.settings.columns_mobile }};
    --ats-padding-t: {{ section.settings.padding_top }}px;
    --ats-padding-b: {{ section.settings.padding_bottom }}px;
    --ats-heading-size: {{ section.settings.heading_size }}px;
    --ats-body-size: {{ section.settings.body_size }}px;
  "
>
  <div class="aura-trust-strip__inner">
    <div class="aura-trust-strip__grid">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'trust_item' %}
            <div class="aura-trust-strip__item" {{ block.shopify_attributes }}>
              <div class="aura-trust-strip__icon" aria-hidden="true">
                {% if block.settings.custom_svg != blank %}
                  {{ block.settings.custom_svg }}
                {% else %}
                  {% render 'aura-icon', icon: block.settings.icon, class: 'aura-trust-strip__icon-svg' %}
                {% endif %}
              </div>
              <div>
                {% if block.settings.heading != blank %}
                  <strong class="aura-trust-strip__heading">{{ block.settings.heading | escape }}</strong>
                {% endif %}
                {% if block.settings.text != blank %}
                  <p class="aura-trust-strip__text">{{ block.settings.text | escape }}</p>
                {% endif %}
              </div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .{{ ts_class }} {
    background: var(--ats-background);
    border-top: 1px solid rgba(234, 216, 210, 0.75);
    border-bottom: 1px solid rgba(234, 216, 210, 0.75);
  }

  .{{ ts_class }} .aura-trust-strip__inner {
    width: min(1240px, calc(100% - 48px));
    margin: 0 auto;
    padding-top: var(--ats-padding-t);
    padding-bottom: var(--ats-padding-b);
  }

  .{{ ts_class }} .aura-trust-strip__grid {
    display: grid;
    grid-template-columns: repeat(var(--ats-columns-d), minmax(0, 1fr));
    gap: clamp(1.25rem, 3vw, 2.25rem);
  }

  .{{ ts_class }} .aura-trust-strip__item {
    display: grid;
    grid-template-columns: 54px 1fr;
    gap: 1rem;
    align-items: center;
  }

  .{{ ts_class }} .aura-trust-strip__icon {
    width: 54px;
    height: 54px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--ats-icon-bg);
    color: var(--ats-icon);
    overflow: hidden;
  }

  .{{ ts_class }} .aura-trust-strip__icon svg {
    width: 52%;
    height: 52%;
  }

  .{{ ts_class }} .aura-trust-strip__icon-svg {
    width: 52%;
    height: 52%;
  }

  .{{ ts_class }} .aura-trust-strip__heading {
    display: block;
    font-size: var(--ats-heading-size);
    color: var(--ats-heading);
    margin-bottom: 0.2rem;
    line-height: 1.2;
  }

  .{{ ts_class }} .aura-trust-strip__text {
    margin: 0;
    color: var(--ats-text);
    font-size: var(--ats-body-size);
    line-height: 1.45;
  }

  @media (max-width: 980px) {
    .{{ ts_class }} .aura-trust-strip__grid {
      grid-template-columns: repeat(var(--ats-columns-t), minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .{{ ts_class }} .aura-trust-strip__inner {
      width: min(100% - 28px, 1240px);
    }

    .{{ ts_class }} .aura-trust-strip__grid {
      grid-template-columns: repeat(var(--ats-columns-m), minmax(0, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Aura trust strip",
  "tag": "section",
  "class": "aura-trust-strip-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "icon_background",
      "label": "Icon background",
      "default": "#fff1f8"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#EC008C"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1B2C58"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#626b7d"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "default": "4",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ]
    },
    {
      "type": "select",
      "id": "columns_tablet",
      "label": "Columns (tablet)",
      "default": "2",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ]
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "default": "1",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ]
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 13,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Heading size",
      "default": 15
    },
    {
      "type": "range",
      "id": "body_size",
      "min": 11,
      "max": 16,
      "step": 1,
      "unit": "px",
      "label": "Body size",
      "default": 13
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 16,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 16,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "heart",
          "options": [
            { "value": "heart", "label": "Heart" },
            { "value": "community", "label": "Person" },
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "diamond", "label": "Diamond" },
            { "value": "points", "label": "Check circle" },
            { "value": "gift", "label": "Gift" },
            { "value": "star", "label": "Star" }
          ]
        },
        {
          "type": "textarea",
          "id": "custom_svg",
          "label": "Custom SVG code (optional)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Clean & effective"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Thoughtfully formulated with safe ingredients."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aura trust strip",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "heart",
            "heading": "Clean & effective",
            "text": "Thoughtfully formulated with safe ingredients."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "community",
            "heading": "Dermatologist tested",
            "text": "Gentle and effective for daily use."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "sparkle",
            "heading": "Cruelty free",
            "text": "Never tested on animals. Always ethical."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "diamond",
            "heading": "Vegan friendly",
            "text": "No animal-derived ingredients."
          }
        }
      ]
    }
  ]
}
{% endschema %}
