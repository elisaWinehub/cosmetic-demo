{% comment %}
  Aura Society — collection listing hero. Scoped to .aura-collection-page; assign template collection.aura to use.
{% endcomment %}

{% liquid
  assign align = section.settings.text_alignment | default: 'center'
  assign overlay_op = section.settings.overlay_opacity | times: 1.0 | divided_by: 100
  assign hero_has_media = false
  if section.settings.desktop_hero_image != blank or section.settings.mobile_hero_image != blank
    assign hero_has_media = true
  endif
  assign hero_mobile_img = section.settings.mobile_hero_image | default: section.settings.desktop_hero_image
%}

<section
  class="aura-collection-page aura-collection-hero"
  style="
    --ach-max: 1440px;
    --ach-padding-top: {{ section.settings.padding_top }}px;
    --ach-padding-bottom: {{ section.settings.padding_bottom }}px;
    --ach-padding-top-m: {{ section.settings.padding_top_mobile }}px;
    --ach-padding-bottom-m: {{ section.settings.padding_bottom_mobile }}px;
    --ach-radius: {{ section.settings.banner_radius }}px;
    --ach-min-h: {{ section.settings.hero_min_height }}px;
    --ach-min-h-m: {{ section.settings.hero_min_height_mobile }}px;
    --ach-bg: {{ section.settings.background_color }};
    --ach-bg-end: {{ section.settings.gradient_end_color }};
    --ach-overlay: {{ section.settings.overlay_color | color_modify: 'alpha', overlay_op }};
    --ach-align: {{ align }};
    --ach-heading: {{ section.settings.heading_color }};
    --ach-sub: {{ section.settings.subtitle_color }};
  "
>
  <div class="aura-collection-hero__shell">
    <div class="aura-collection-hero__banner{% if hero_has_media %} aura-collection-hero__banner--has-media{% endif %}">
      <div class="aura-collection-hero__overlay" aria-hidden="true"></div>

      {% if section.settings.desktop_hero_image != blank %}
        <div class="aura-collection-hero__bg-media aura-collection-hero__bg-media--desktop">
          {{
            section.settings.desktop_hero_image
            | image_url: width: 2400
            | image_tag:
              loading: 'lazy',
              class: 'aura-collection-hero__bg-img',
              widths: '800, 1200, 1600, 2000, 2400'
          }}
        </div>
      {% endif %}
      {% if hero_mobile_img != blank %}
        <div class="aura-collection-hero__bg-media aura-collection-hero__bg-media--mobile">
          {{
            hero_mobile_img
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              class: 'aura-collection-hero__bg-img',
              widths: '400, 600, 800, 1200'
          }}
        </div>
      {% endif %}

      <div class="aura-collection-hero__inner{% if hero_has_media %} aura-collection-hero__inner--on-media{% endif %}">
        {% if section.settings.heading != blank %}
          <h1 class="aura-collection-hero__heading">{{ section.settings.heading | escape }}</h1>
        {% endif %}
        {% if section.settings.subtitle != blank %}
          <p class="aura-collection-hero__subtitle">{{ section.settings.subtitle | escape }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .aura-collection-page.aura-collection-hero {
    width: 100%;
    box-sizing: border-box;
  }

  .aura-collection-page .aura-collection-hero__shell {
    max-width: var(--ach-max);
    margin: 0 auto;
    padding: var(--ach-padding-top-m) 1.25rem var(--ach-padding-bottom-m);
    box-sizing: border-box;
  }

  @media (min-width: 750px) {
    .aura-collection-page .aura-collection-hero__shell {
      padding: var(--ach-padding-top) 2rem var(--ach-padding-bottom);
    }
  }

  .aura-collection-page .aura-collection-hero__banner {
    position: relative;
    min-height: var(--ach-min-h-m);
    border-radius: var(--ach-radius);
    overflow: hidden;
    background: linear-gradient(
      135deg,
      var(--ach-bg) 0%,
      var(--ach-bg-end) 100%
    );
    display: flex;
    align-items: center;
    justify-content: center;
    isolation: isolate;
  }

  @media (min-width: 750px) {
    .aura-collection-page .aura-collection-hero__banner {
      min-height: var(--ach-min-h);
    }

    .aura-collection-page .aura-collection-hero__banner--has-media {
      min-height: max(var(--ach-min-h), 22vw);
    }
  }

  .aura-collection-page .aura-collection-hero__overlay {
    position: absolute;
    inset: 0;
    background: var(--ach-overlay);
    pointer-events: none;
    z-index: 1;
  }

  .aura-collection-page .aura-collection-hero__bg-media {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .aura-collection-page .aura-collection-hero__bg-media--desktop {
    display: none;
  }

  @media (min-width: 750px) {
    .aura-collection-page .aura-collection-hero__bg-media--desktop {
      display: block;
    }

    .aura-collection-page .aura-collection-hero__bg-media--mobile {
      display: none;
    }
  }

  .aura-collection-page .aura-collection-hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .aura-collection-page .aura-collection-hero__banner--has-media .aura-collection-hero__bg-img {
    opacity: 1;
  }

  .aura-collection-page .aura-collection-hero__inner {
    position: relative;
    z-index: 3;
    text-align: var(--ach-align);
    padding: 2.5rem 1.5rem;
    max-width: 40rem;
    margin-inline: auto;
    animation: aura-collection-hero-in 0.7s ease-out both;
  }

  @media (min-width: 750px) {
    .aura-collection-page .aura-collection-hero__inner {
      padding: 3rem 2rem;
    }
  }

  .aura-collection-page .aura-collection-hero__inner--on-media .aura-collection-hero__heading,
  .aura-collection-page .aura-collection-hero__inner--on-media .aura-collection-hero__subtitle {
    text-shadow:
      0 0 1.25rem rgba(255, 255, 255, 0.95),
      0 0 2.5rem rgba(255, 255, 255, 0.65),
      0 2px 12px rgba(253, 238, 244, 0.9);
  }

  .aura-collection-page .aura-collection-hero__heading {
    margin: 0 0 0.65rem;
    font-family: var(--font-heading-family, inherit);
    font-style: var(--font-heading-style, inherit);
    font-weight: var(--font-heading-weight, 600);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    color: var(--ach-heading);
    letter-spacing: -0.02em;
  }

  .aura-collection-page .aura-collection-hero__subtitle {
    margin: 0;
    font-family: var(--font-body-family, inherit);
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--ach-sub);
    max-width: 36rem;
    margin-inline: auto;
  }

  @media (min-width: 750px) {
    .aura-collection-page .aura-collection-hero__subtitle {
      font-size: 1.125rem;
    }
  }

  @keyframes aura-collection-hero-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Aura collection hero",
  "tag": "section",
  "class": "aura-collection-hero-section",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop All"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Clean formulas. Real results. Glow with rewards."
    },
    {
      "type": "header",
      "content": "Hero banner images"
    },
    {
      "type": "image_picker",
      "id": "desktop_hero_image",
      "label": "Desktop hero image"
    },
    {
      "type": "image_picker",
      "id": "mobile_hero_image",
      "label": "Mobile hero image",
      "info": "Falls back to desktop image when empty."
    },
    {
      "type": "header",
      "content": "Colors and banner"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1b2c58"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#4a5568"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background gradient start",
      "default": "#fdeef4"
    },
    {
      "type": "color",
      "id": "gradient_end_color",
      "label": "Background gradient end",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay tint",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 90,
      "step": 2,
      "unit": "%",
      "default": 22
    },
    {
      "type": "range",
      "id": "banner_radius",
      "label": "Banner corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "hero_min_height",
      "label": "Minimum height (desktop)",
      "min": 220,
      "max": 520,
      "step": 10,
      "unit": "px",
      "default": 320
    },
    {
      "type": "range",
      "id": "hero_min_height_mobile",
      "label": "Minimum height (mobile)",
      "min": 180,
      "max": 420,
      "step": 10,
      "unit": "px",
      "default": 260
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 28
    }
  ],
  "presets": [
    {
      "name": "Aura collection hero"
    }
  ]
}
{% endschema %}
