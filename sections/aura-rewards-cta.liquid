{% assign cta_class = 'aura-rewards-cta-' | append: section.id %}

<section
  class="aura-rewards-cta full-width {{ cta_class }}"
  style="
    --arc-bg-start: {{ section.settings.background_start }};
    --arc-bg-end: {{ section.settings.background_end }};
    --arc-heading: {{ section.settings.heading_color }};
    --arc-text: {{ section.settings.text_color }};
    --arc-pill-start: {{ section.settings.primary_button_start }};
    --arc-pill-end: {{ section.settings.primary_button_end }};
    --arc-pill-text: {{ section.settings.primary_button_text }};
    --arc-outline-border: {{ section.settings.secondary_button_border }};
    --arc-outline-text: {{ section.settings.secondary_button_text }};
    --arc-icon-bg: {{ section.settings.icon_background }};
    --arc-icon: {{ section.settings.icon_color }};
    --arc-padding-t: {{ section.settings.padding_top }}px;
    --arc-padding-b: {{ section.settings.padding_bottom }}px;
    --arc-title: {{ section.settings.heading_size }}px;
    --arc-body: {{ section.settings.body_size }}px;
  "
>
  <div class="aura-rewards-cta__inner">
    <div class="aura-rewards-cta__grid">
      <div class="aura-rewards-cta__intro">
        {% if section.settings.heading != blank %}
          <h2 class="aura-rewards-cta__heading">{{ section.settings.heading | escape }}</h2>
        {% endif %}
        {% if section.settings.text != blank %}
          <p class="aura-rewards-cta__text">{{ section.settings.text | escape }}</p>
        {% endif %}
        <div class="aura-rewards-cta__actions">
          {% if section.settings.primary_label != blank %}
            <a class="aura-rewards-cta__btn aura-rewards-cta__btn--primary" href="{{ section.settings.primary_link | default: '#' }}">
              {{ section.settings.primary_label | escape }}
            </a>
          {% endif %}
          {% if section.settings.secondary_label != blank %}
            <a class="aura-rewards-cta__btn aura-rewards-cta__btn--outline" href="{{ section.settings.secondary_link | default: '#' }}">
              {{ section.settings.secondary_label | escape }}
            </a>
          {% endif %}
        </div>
      </div>

      <div class="aura-rewards-cta__perks">
        {% for block in section.blocks %}
          {% if block.type == 'perk' %}
            <div class="aura-rewards-cta__perk" {{ block.shopify_attributes }}>
              <div class="aura-rewards-cta__icon">
                {% if block.settings.custom_svg != blank %}
                  {{ block.settings.custom_svg }}
                {% else %}
                  {% render 'aura-icon', icon: block.settings.icon, class: 'aura-rewards-cta__icon-svg' %}
                {% endif %}
              </div>
              <div>
                {% if block.settings.heading != blank %}
                  <strong class="aura-rewards-cta__perk-title">{{ block.settings.heading | escape }}</strong>
                {% endif %}
                {% if block.settings.text != blank %}
                  <p class="aura-rewards-cta__perk-text">{{ block.settings.text | escape }}</p>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .{{ cta_class }} {
    background: linear-gradient(90deg, var(--arc-bg-start), var(--arc-bg-end));
  }

  .{{ cta_class }} .aura-rewards-cta__inner {
    width: min(1240px, calc(100% - 48px));
    margin: 0 auto;
    padding-top: var(--arc-padding-t);
    padding-bottom: var(--arc-padding-b);
  }

  .{{ cta_class }} .aura-rewards-cta__grid {
    display: grid;
    grid-template-columns: 0.95fr 1.35fr;
    gap: clamp(2rem, 5vw, 4.4rem);
    align-items: center;
  }

  .{{ cta_class }} .aura-rewards-cta__heading {
    font-family: var(--font-heading--family, Georgia, serif);
    font-size: var(--arc-title);
    font-weight: 500;
    color: var(--arc-heading);
    margin: 0 0 1rem;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .{{ cta_class }} .aura-rewards-cta__text {
    margin: 0;
    color: var(--arc-text);
    font-size: var(--arc-body);
    line-height: 1.55;
    max-width: 460px;
  }

  .{{ cta_class }} .aura-rewards-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-top: 1.35rem;
  }

  .{{ cta_class }} .aura-rewards-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 1.75rem;
    border-radius: 8px;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: 0.72rem;
    text-decoration: none;
    transition: filter 0.2s ease, transform 0.2s ease;
  }

  .{{ cta_class }} .aura-rewards-cta__btn--primary {
    background: linear-gradient(90deg, var(--arc-pill-start), var(--arc-pill-end));
    color: var(--arc-pill-text);
    border: 0;
  }

  .{{ cta_class }} .aura-rewards-cta__btn--primary:hover {
    filter: brightness(1.05);
  }

  .{{ cta_class }} .aura-rewards-cta__btn--outline {
    background: transparent;
    color: var(--arc-outline-text);
    border: 1px solid var(--arc-outline-border);
  }

  .{{ cta_class }} .aura-rewards-cta__btn--outline:hover {
    background: rgba(27, 44, 88, 0.05);
  }

  .{{ cta_class }} .aura-rewards-cta__perks {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.35rem;
  }

  .{{ cta_class }} .aura-rewards-cta__perk {
    display: grid;
    grid-template-columns: 54px 1fr;
    gap: 1rem;
    align-items: center;
  }

  .{{ cta_class }} .aura-rewards-cta__icon {
    width: 54px;
    height: 54px;
    border-radius: 50%;
    background: var(--arc-icon-bg);
    color: var(--arc-icon);
    display: grid;
    place-items: center;
    overflow: hidden;
  }

  .{{ cta_class }} .aura-rewards-cta__icon svg {
    width: 52%;
    height: 52%;
  }

  .{{ cta_class }} .aura-rewards-cta__perk-title {
    display: block;
    color: var(--arc-heading);
    font-size: 0.9375rem;
    margin-bottom: 0.2rem;
  }

  .{{ cta_class }} .aura-rewards-cta__perk-text {
    margin: 0;
    color: var(--arc-text);
    font-size: 0.8125rem;
    line-height: 1.45;
  }

  @media (max-width: 980px) {
    .{{ cta_class }} .aura-rewards-cta__grid {
      grid-template-columns: 1fr;
    }

    .{{ cta_class }} .aura-rewards-cta__perks {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .{{ cta_class }} .aura-rewards-cta__inner {
      width: min(100% - 28px, 1240px);
    }

    .{{ cta_class }} .aura-rewards-cta__perks {
      grid-template-columns: 1fr;
    }

    .{{ cta_class }} .aura-rewards-cta__actions {
      flex-direction: column;
      align-items: stretch;
    }

    .{{ cta_class }} .aura-rewards-cta__btn {
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Aura rewards CTA",
  "tag": "section",
  "class": "aura-rewards-cta-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "color",
      "id": "background_start",
      "label": "Background (start)",
      "default": "#fff6f2"
    },
    {
      "type": "color",
      "id": "background_end",
      "label": "Background (end)",
      "default": "#fff0f8"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1B2C58"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#626b7d"
    },
    {
      "type": "color",
      "id": "primary_button_start",
      "label": "Primary button gradient start",
      "default": "#43318F"
    },
    {
      "type": "color",
      "id": "primary_button_end",
      "label": "Primary button gradient end",
      "default": "#EC008C"
    },
    {
      "type": "color",
      "id": "primary_button_text",
      "label": "Primary button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "secondary_button_border",
      "label": "Secondary button border",
      "default": "#dac8c3"
    },
    {
      "type": "color",
      "id": "secondary_button_text",
      "label": "Secondary button text",
      "default": "#252b36"
    },
    {
      "type": "color",
      "id": "icon_background",
      "label": "Icon background",
      "default": "#fff1f8"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#EC008C"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "More glow. More rewards."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Join Aura Society for exclusive perks, member-only rewards, and more."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Join Aura Society"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 32
    },
    {
      "type": "range",
      "id": "body_size",
      "min": 13,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Body size",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 44
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 44
    }
  ],
  "blocks": [
    {
      "type": "perk",
      "name": "Perk",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "sparkle",
          "options": [
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "points", "label": "Points" },
            { "value": "gift", "label": "Gift" },
            { "value": "crown", "label": "Crown" },
            { "value": "bag", "label": "Bag" },
            { "value": "star", "label": "Star" },
            { "value": "diamond", "label": "Diamond" }
          ]
        },
        {
          "type": "textarea",
          "id": "custom_svg",
          "label": "Custom SVG (optional)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Earn points"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "On every order"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aura rewards CTA",
      "blocks": [
        {
          "type": "perk",
          "settings": {
            "icon": "sparkle",
            "heading": "Earn points",
            "text": "On every order"
          }
        },
        {
          "type": "perk",
          "settings": {
            "icon": "crown",
            "heading": "Unlock perks",
            "text": "VIP access & surprises"
          }
        },
        {
          "type": "perk",
          "settings": {
            "icon": "gift",
            "heading": "Birthday gifts",
            "text": "Celebrate with rewards"
          }
        },
        {
          "type": "perk",
          "settings": {
            "icon": "bag",
            "heading": "Members only",
            "text": "Exclusive drops"
          }
        }
      ]
