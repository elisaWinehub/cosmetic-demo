{% liquid
  assign overlay_alpha = section.settings.overlay_opacity | divided_by: 100.0

  if section.settings.background_style == 'gradient'
    capture section_background
      echo 'linear-gradient(135deg, '
      echo section.settings.background_color
      echo ', '
      echo section.settings.accent_color
      echo ')'
    endcapture
  else
    assign section_background = section.settings.background_color
  endif

  assign cta_class = 'aura-cta-' | append: section.id
%}

<section
  class="aura-cta full-width {{ cta_class }} aura-cta--{{ section.settings.alignment }} aura-cta--{{ section.settings.section_height }}"
  style="
    --aura-cta-background: {{ section_background }};
    --aura-cta-overlay: {{ section.settings.overlay_color | color_modify: 'alpha', overlay_alpha }};
    --aura-cta-heading-size: {{ section.settings.heading_size }}px;
    --aura-cta-subheading-size: {{ section.settings.subheading_size }}px;
    --aura-cta-padding-top: {{ section.settings.padding_top }}px;
    --aura-cta-padding-bottom: {{ section.settings.padding_bottom }}px;
    --aura-cta-button-background: {{ section.settings.button_background }};
    --aura-cta-button-text: {{ section.settings.button_text_color }};
    --aura-cta-link-color: {{ section.settings.link_color }};
  "
>
  <div class="aura-cta__background">
    {% if section.settings.desktop_image != blank %}
      <picture>
        {% if section.settings.mobile_image != blank %}
          <source media="(max-width: 767px)" srcset="{{ section.settings.mobile_image | image_url: width: 900 }}">
        {% endif %}
        {{ section.settings.desktop_image | image_url: width: 1800 | image_tag: class: 'aura-cta__background-image' }}
      </picture>
    {% endif %}
  </div>

  <div class="aura-cta__overlay"></div>

  <div class="aura-cta__inner">
    <div class="aura-cta__content">
      {% if section.settings.heading != blank %}
        <h2 class="aura-cta__heading">{{ section.settings.heading | escape | newline_to_br }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <div class="aura-cta__subheading rte">{{ section.settings.subheading }}</div>
      {% endif %}

      {% if section.settings.button_text != blank %}
        <a class="aura-cta__button" href="{{ section.settings.button_link | default: '#' }}">
          {{ section.settings.button_text | escape }}
        </a>
      {% endif %}

      {% if section.settings.secondary_link_text != blank %}
        <a class="aura-cta__secondary-link" href="{{ section.settings.secondary_link_url | default: '#' }}">
          {{ section.settings.secondary_link_text | escape }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% style %}
  .{{ cta_class }} {
    position: relative;
    overflow: hidden;
    color: #fff;
    background: radial-gradient(circle at 15% 80%, rgba(255, 255, 255, 0.34), transparent 22%), radial-gradient(circle at 95% 50%, rgba(255, 255, 255, 0.22), transparent 28%), var(--aura-cta-background);
  }

  .{{ cta_class }} .aura-cta__background,
  .{{ cta_class }} .aura-cta__overlay {
    position: absolute;
    inset: 0;
  }

  .{{ cta_class }} .aura-cta__background-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .{{ cta_class }} .aura-cta__overlay {
    background: var(--aura-cta-overlay);
  }

  .{{ cta_class }} .aura-cta__inner {
    position: relative;
    z-index: 1;
    width: min(1160px, calc(100% - 48px));
    margin: 0 auto;
    padding-top: var(--aura-cta-padding-top);
    padding-bottom: var(--aura-cta-padding-bottom);
  }

  .{{ cta_class }} .aura-cta__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    width: min(100%, 42rem);
    margin: 0 auto;
    text-align: center;
  }

  .{{ cta_class }}.aura-cta--left .aura-cta__content {
    align-items: flex-start;
    margin-inline: 0 auto;
    text-align: left;
  }

  .{{ cta_class }}.aura-cta--medium {
    min-height: 22rem;
  }

  .{{ cta_class }}.aura-cta--large {
    min-height: 26rem;
  }

  .{{ cta_class }}.aura-cta--screen {
    min-height: 32rem;
  }

  .{{ cta_class }} .aura-cta__heading {
    font-family: var(--font-heading--family);
    font-size: var(--aura-cta-heading-size);
    font-weight: 500;
    line-height: 1.06;
    letter-spacing: -0.04em;
    color: var(--aura-heading-color);
  }

  .{{ cta_class }} .aura-cta__subheading {
    color: rgba(255, 255, 255, 0.82);
    font-size: var(--aura-cta-subheading-size);
    line-height: 1.7;
  }

  .{{ cta_class }} .aura-cta__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.25rem;
    min-width: 16rem;
    margin-top: 0.35rem;
    padding: 0.85rem 1.5rem;
    border-radius: 0.3rem;
    background: var(--aura-cta-button-background);
    color: var(--aura-cta-button-text);
    text-decoration: none;
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .{{ cta_class }} .aura-cta__secondary-link {
    margin-top: 0.6rem;
    color: #fff;
    text-decoration: none;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  @media (max-width: 767px) {
    .{{ cta_class }} .aura-cta__inner {
      width: min(1160px, calc(100% - 32px));
    }

    .{{ cta_class }} .aura-cta__heading {
      font-size: min(calc(var(--aura-cta-heading-size) * 0.82), 2.4rem);
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Aura CTA",
  "tag": "section",
  "class": "section-aura-cta",
  "settings": [
    {
      "type": "select",
      "id": "background_style",
      "label": "Background style",
      "default": "gradient",
      "options": [
        { "value": "gradient", "label": "Gradient" },
        { "value": "solid", "label": "Solid" }
      ]
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#d68aa2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#f1c0cf"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop background image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile background image"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#6a3248"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 25
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Section height",
      "default": "medium",
      "options": [
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "screen", "label": "Extra tall" }
      ]
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Ready to unlock\nyour glow?"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Join Aura Society and discover rewards for every beauty ritual.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Join Aura Society free"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "secondary_link_text",
      "label": "Secondary link text",
      "default": "Learn about membership"
    },
    {
      "type": "url",
      "id": "secondary_link_url",
      "label": "Secondary link URL"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 42
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#7b3f58"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Secondary link color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 24,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 24,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "Aura CTA"
    }
  ]
}
{% endschema %}
