{% javascript %}
  (function () {
    function parseJson(el) {
      if (!el) return null;
      try {
        return JSON.parse(el.textContent);
      } catch (e) {
        return null;
      }
    }

    function formatMoney(cents, moneyFormat) {
      if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
        return Shopify.formatMoney(cents, moneyFormat);
      }
      return (cents / 100).toFixed(2);
    }

    const roots = document.querySelectorAll('[data-aura-product-main]');
    roots.forEach(function (root) {
      const slides = root.querySelectorAll('[data-aura-gallery-slide]');
      const thumbs = root.querySelectorAll('[data-aura-gallery-thumb]');
      const mainEl = root.querySelector('[data-aura-gallery-main]');
      const prevBtn = root.querySelector('[data-aura-gallery-prev]');
      const nextBtn = root.querySelector('[data-aura-gallery-next]');
      const zoomOpen = root.querySelector('[data-aura-zoom-open]');
      const lightbox = root.querySelector('[data-aura-lightbox]');
      const lightboxImg = lightbox ? lightbox.querySelector('[data-aura-lightbox-img]') : null;
      const lightboxPrev = lightbox ? lightbox.querySelector('[data-aura-lightbox-prev]') : null;
      const lightboxNext = lightbox ? lightbox.querySelector('[data-aura-lightbox-next]') : null;
      const lightboxCloses = lightbox ? lightbox.querySelectorAll('[data-aura-lightbox-close]') : [];

      function getImageSlides() {
        return Array.from(slides).filter(function (s) {
          return (
            s.getAttribute('data-media-type') === 'image' &&
            s.getAttribute('data-zoom-src')
          );
        });
      }

      function syncZoomButton() {
        if (!zoomOpen) return;
        const active = root.querySelector('[data-aura-gallery-slide].is-active');
        if (
          active &&
          active.getAttribute('data-media-type') === 'image' &&
          active.getAttribute('data-zoom-src')
        ) {
          zoomOpen.hidden = false;
        } else {
          zoomOpen.hidden = true;
        }
      }

      function setGalleryByMediaId(mediaId) {
        if (!mediaId) return;
        const idStr = String(mediaId);
        slides.forEach(function (slide) {
          slide.classList.toggle('is-active', slide.getAttribute('data-media-id') === idStr);
        });
        thumbs.forEach(function (thumb) {
          thumb.classList.toggle('is-active', thumb.getAttribute('data-media-id') === idStr);
        });
        if (mainEl) mainEl.setAttribute('data-active-id', idStr);
        syncZoomButton();
      }

      function activateAdjacent(dir) {
        if (slides.length <= 1) return;
        const activeSlide = root.querySelector('[data-aura-gallery-slide].is-active');
        if (!activeSlide) return;
        const id = activeSlide.getAttribute('data-media-id');
        const ids = Array.from(slides)
          .map(function (s) {
            return s.getAttribute('data-media-id');
          })
          .filter(function (mid) {
            return mid != null && mid !== '';
          });
        const i = ids.indexOf(id);
        if (i < 0) return;
        const next = (i + dir + ids.length) % ids.length;
        setGalleryByMediaId(ids[next]);
      }

      var lightboxIndex = 0;
      var onDocKeydown = null;

      function showLightboxImage() {
        const imgs = getImageSlides();
        if (!lightboxImg || imgs.length === 0) return;
        const slide = imgs[lightboxIndex];
        const src = slide.getAttribute('data-zoom-src');
        const alt = slide.getAttribute('data-zoom-alt') || '';
        if (src) lightboxImg.setAttribute('src', src);
        lightboxImg.setAttribute('alt', alt);
        if (lightboxPrev) lightboxPrev.hidden = imgs.length <= 1;
        if (lightboxNext) lightboxNext.hidden = imgs.length <= 1;
      }

      function closeLightbox() {
        if (!lightbox) return;
        lightbox.setAttribute('hidden', 'hidden');
        lightbox.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        if (onDocKeydown) {
          document.removeEventListener('keydown', onDocKeydown);
          onDocKeydown = null;
        }
      }

      function openLightbox() {
        const imgs = getImageSlides();
        if (!lightbox || !lightboxImg || imgs.length === 0) return;
        const active = root.querySelector('[data-aura-gallery-slide].is-active');
        var idx = 0;
        if (active && active.getAttribute('data-media-type') === 'image') {
          const curId = active.getAttribute('data-media-id');
          const found = imgs.findIndex(function (s) {
            return s.getAttribute('data-media-id') === curId;
          });
          if (found >= 0) idx = found;
        }
        lightboxIndex = idx;
        showLightboxImage();
        lightbox.removeAttribute('hidden');
        lightbox.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        onDocKeydown = function (e) {
          if (e.key === 'Escape') closeLightbox();
        };
        document.addEventListener('keydown', onDocKeydown);
      }

      function lightboxAdjacent(dir) {
        const imgs = getImageSlides();
        if (imgs.length <= 1) return;
        lightboxIndex = (lightboxIndex + dir + imgs.length) % imgs.length;
        showLightboxImage();
      }

      thumbs.forEach(function (thumb) {
        thumb.addEventListener('click', function () {
          setGalleryByMediaId(thumb.getAttribute('data-media-id'));
        });
      });

      if (prevBtn) prevBtn.addEventListener('click', function () { activateAdjacent(-1); });
      if (nextBtn) nextBtn.addEventListener('click', function () { activateAdjacent(1); });

      if (zoomOpen) {
        zoomOpen.addEventListener('click', function (e) {
          e.preventDefault();
          openLightbox();
        });
      }

      if (lightbox && lightboxPrev) {
        lightboxPrev.addEventListener('click', function () { lightboxAdjacent(-1); });
      }
      if (lightbox && lightboxNext) {
        lightboxNext.addEventListener('click', function () { lightboxAdjacent(1); });
      }

      lightboxCloses.forEach(function (btn) {
        btn.addEventListener('click', function () { closeLightbox(); });
      });

      syncZoomButton();

      const variantScript = root.querySelector('[data-aura-variant-json]');
      const variants = parseJson(variantScript) || [];
      const form = root.querySelector('.aura-product-main__form');
      const idInput = root.querySelector('[data-aura-variant-id]');
      const priceEl = root.querySelector('[data-aura-price]');
      const compareEl = root.querySelector('[data-aura-compare]');
      const optionButtons = root.querySelectorAll('[data-aura-option]');
      const qtyInput = root.querySelector('[data-aura-qty]');
      const addBtn = root.querySelector('[data-aura-add]');
      const pointsWrap = root.querySelector('[data-aura-points-wrap]');
      const pointsTextEl = root.querySelector('[data-aura-points-text]');
      const oneTimePriceEl = root.querySelector('[data-aura-one-time-price]');
      const qtyDec = root.querySelector('[data-aura-qty-dec]');
      const qtyInc = root.querySelector('[data-aura-qty-inc]');
      const attrFormat = root.getAttribute('data-money-format');
      const moneyFormat =
        attrFormat ||
        (typeof window !== 'undefined' && window.Shopify && window.Shopify.money_format
          ? window.Shopify.money_format
          : '${{amount}}');

      if (!form || !idInput || variants.length === 0) return;

      const optionButtonCount = root.querySelectorAll('[data-aura-option]').length;
      const optionCount =
        optionButtonCount === 0
          ? 0
          : variants[0] && variants[0].options
            ? variants[0].options.length
            : 0;

      function getSelectedOptions() {
        const selected = [];
        for (let i = 0; i < optionCount; i++) {
          const active = root.querySelector(
            '[data-aura-option][data-option-index="' + i + '"].is-active'
          );
          selected.push(active ? active.getAttribute('data-value') : null);
        }
        return selected;
      }

      function findVariant() {
        if (optionCount === 0) return variants[0];
        const selected = getSelectedOptions();
        return variants.find(function (v) {
          if (!v.options || v.options.length !== selected.length) return false;
          return v.options.every(function (opt, idx) {
            return opt === selected[idx];
          });
        });
      }

      function applyVariant(v) {
        if (!v) return;
        idInput.value = v.id;
        if (priceEl) priceEl.textContent = formatMoney(v.price, moneyFormat);
        if (compareEl) {
          if (v.compare_at_price && v.compare_at_price > v.price) {
            compareEl.removeAttribute('hidden');
            compareEl.textContent = formatMoney(v.compare_at_price, moneyFormat);
          } else {
            compareEl.setAttribute('hidden', 'hidden');
            compareEl.textContent = '';
          }
        }
        if (v.featured_media_id) setGalleryByMediaId(v.featured_media_id);
        if (oneTimePriceEl) oneTimePriceEl.textContent = formatMoney(v.price, moneyFormat);

        if (addBtn) {
          if (v.available) {
            addBtn.disabled = false;
            addBtn.textContent = addBtn.getAttribute('data-label-available') || addBtn.textContent;
          } else {
            addBtn.disabled = true;
            addBtn.textContent = addBtn.getAttribute('data-label-soldout') || addBtn.textContent;
          }
        }

        const mult = parseFloat(pointsWrap ? pointsWrap.getAttribute('data-points-mult') || root.getAttribute('data-points-mult') : root.getAttribute('data-points-mult')) || 1;
        const fmt = pointsWrap ? pointsWrap.getAttribute('data-points-format') : '';
        if (pointsTextEl && fmt) {
          const pts = Math.round((v.price / 100) * mult);
          pointsTextEl.textContent = fmt.split('__POINTS__').join(String(pts));
        }
      }

      optionButtons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          const idx = btn.getAttribute('data-option-index');
          root.querySelectorAll('[data-aura-option][data-option-index="' + idx + '"]').forEach(function (b) {
            b.classList.remove('is-active');
          });
          btn.classList.add('is-active');
          const v = findVariant();
          applyVariant(v);
        });
      });

      if (qtyInput && qtyDec) {
        qtyDec.addEventListener('click', function () {
          const n = parseInt(qtyInput.value, 10) || 1;
          qtyInput.value = Math.max(1, n - 1);
        });
      }
      if (qtyInput && qtyInc) {
        qtyInc.addEventListener('click', function () {
          const n = parseInt(qtyInput.value, 10) || 1;
          qtyInput.value = n + 1;
        });
      }

      const initial = variants.find(function (v) { return String(v.id) === String(idInput.value); });
      if (initial) applyVariant(initial);
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Aura product main",
  "tag": "section",
  "class": "aura-product-main-section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "range",
      "id": "section_width",
      "min": 960,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "label": "Max content width",
      "default": 1240
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body text color",
      "default": "#171012"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1B2C58"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#EC008C"
    },
    {
