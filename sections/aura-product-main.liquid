{% comment %}
  Aura Society — product hero (PDP). Uses product object; enable on product templates only.
{% endcomment %}
{% liquid
  assign root_class = 'aura-product-main-' | append: section.id
  assign current_variant = product.selected_or_first_available_variant
  assign media_list = product.media
  assign first_media = media_list | first
  assign eyebrow = product.type
  if section.settings.eyebrow_override != blank
    assign eyebrow = section.settings.eyebrow_override
  endif

  assign mf_ns = section.settings.benefits_metafield_namespace | default: 'custom'
  assign mf_key = section.settings.benefits_metafield_key | default: 'benefits'
  assign benefits_meta = blank
  if mf_ns != blank and mf_key != blank and product.metafields[mf_ns][mf_key] != blank
    assign benefits_meta = product.metafields[mf_ns][mf_key]
  endif

  assign fallback_benefits = 'Boosts natural glow||Improves texture and radiance||Hydrates and soothes||Safe for sensitive skin' | split: '||'

  assign gallery_has_image = false
  if media_list.size > 0
    for media in media_list
      if media.media_type == 'image'
        assign gallery_has_image = true
        break
      endif
    endfor
  endif

  assign product_subtitle_meta = product.metafields.custom.product_subtitle
  assign display_subtitle = blank
  if product_subtitle_meta.value != blank
    assign display_subtitle = product_subtitle_meta.value | strip
  elsif product_subtitle_meta != blank
    assign display_subtitle = product_subtitle_meta | metafield_text | strip
  endif
%}
{% if display_subtitle == blank %}
  {% capture display_subtitle %}
    {%- render 'aura-product-type-fallback', product: product, part: 'subtitle' -%}
  {% endcapture %}
  {% assign display_subtitle = display_subtitle | strip %}
{% endif %}
{% if display_subtitle == blank %}
  {% assign display_subtitle = section.settings.subtitle %}
{% endif %}
{% liquid
  assign cart_modal_pts_mult = section.settings.cart_modal_points_multiplier | default: 0
  if cart_modal_pts_mult == 0
    assign cart_modal_pts_mult = section.settings.points_multiplier
  endif
  assign cart_modal_lbl = section.settings.cart_modal_reward_label | strip
  if cart_modal_lbl == blank
    assign cart_modal_lbl = section.settings.points_label
  endif
  assign reward_goal_raw = section.settings.cart_modal_reward_spend_goal | default: 100
  assign reward_goal_cents = reward_goal_raw | times: 100
  assign cart_modal_pts_cap = section.settings.cart_modal_points_cap | default: 100
  assign pdp_variant_on_sale = false
  if current_variant.compare_at_price > current_variant.price
    assign pdp_variant_on_sale = true
  endif
%}

<section
  class="aura-product-main {{ root_class }}"
  data-aura-product-main
  data-product-title="{{ product.title | escape }}"
  data-points-mult="{{ section.settings.points_multiplier }}"
  data-money-format="{{ shop.money_format | escape }}"
  data-currency-symbol="{{ cart.currency.symbol | escape }}"
  data-cart-url="{{ routes.cart_url | escape }}"
  data-cart-add-url="{{ routes.cart_add_url | append: '.js' | escape }}"
  data-cart-json-url="{{ routes.cart_url | append: '.js' | escape }}"
  data-checkout-url="{{ shop.url }}/checkout"
  data-added-error-msg="{{ 'sections.aura_product_main.added_error' | t | escape }}"
  data-cart-modal-show-rewards="{% if section.settings.cart_modal_show_rewards == false %}false{% else %}true{% endif %}"
  data-reward-spend-goal-cents="{{ reward_goal_cents }}"
  data-reward-points-max="{{ cart_modal_pts_cap }}"
  data-cart-modal-points-mult="{{ cart_modal_pts_mult }}"
  data-reward-label="{{ cart_modal_lbl | escape }}"
  data-reward-message-template="{{ section.settings.cart_modal_reward_message | escape }}"
  data-reward-message-fallback="{{ 'sections.aura_product_main.cart_modal_reward_away' | t | escape }}"
  data-reward-complete-msg="{{ 'sections.aura_product_main.cart_modal_reward_complete' | t | escape }}"
  data-cart-modal-subtotal-one="{{ 'sections.aura_product_main.cart_modal_subtotal_one' | t | escape }}"
  data-cart-modal-subtotal-other="{{ 'sections.aura_product_main.cart_modal_subtotal_other' | t | escape }}"
  data-cart-modal-line-qty-template="{{ 'sections.aura_product_main.cart_modal_line_in_cart' | t | escape }}"
  style="
    --apm-max-width: {{ section.settings.section_width }}px;
    --apm-background: {{ section.settings.background_color }};
    --apm-text: {{ section.settings.text_color }};
    --apm-heading: {{ section.settings.heading_color }};
    --apm-accent: {{ section.settings.accent_color }};
    --apm-border: {{ section.settings.border_color }};
    --apm-gradient: linear-gradient(90deg, {{ section.settings.button_gradient_start }} 0%, {{ section.settings.button_gradient_end }} 100%);
    --apm-secondary-btn: {{ section.settings.button_gradient_start }};
    --apm-gallery-radius: {{ section.settings.gallery_radius }}px;
    --apm-thumb-radius: {{ section.settings.thumbnail_radius }}px;
    --apm-thumb-size: {{ section.settings.thumbnail_size }}px;
    --apm-thumb-fit: {{ section.settings.thumbnail_object_fit }};
    --apm-button-radius: {{ section.settings.button_radius }}px;
    --apm-title-desktop: {{ section.settings.title_size_desktop }}px;
    --apm-title-mobile: {{ section.settings.title_size_mobile }}px;
    --apm-body: {{ section.settings.body_size }}px;
    --apm-button-font: {{ section.settings.button_font_size }}px;
    --apm-padding-top-d: {{ section.settings.padding_top_desktop }}px;
    --apm-padding-bottom-d: {{ section.settings.padding_bottom_desktop }}px;
    --apm-padding-top-m: {{ section.settings.padding_top_mobile }}px;
    --apm-padding-bottom-m: {{ section.settings.padding_bottom_mobile }}px;
    --apm-star-color: {{ section.settings.star_color }};
    --apm-cart-modal-reward-bg: #fff6f9;
    --apm-cart-modal-reward-border: rgba(236, 0, 140, 0.22);
    --apm-cart-modal-progress-track: #fde8f0;
    --apm-cart-modal-progress-bar: linear-gradient(90deg, {{ section.settings.button_gradient_start }} 0%, {{ section.settings.button_gradient_end }} 100%);
    --apm-info-block-gap: {{ section.settings.info_block_gap }}px;
    --apm-app-block-margin: {{ section.settings.app_block_spacing }}px;
  "
>
  <div class="aura-product-main__inner">
    {% if section.settings.show_breadcrumbs %}
      <nav class="aura-product-main__breadcrumb" aria-label="{{ 'sections.aura_product_main.breadcrumb_aria' | t }}">
        <a href="{{ routes.root_url }}">{{ 'sections.aura_product_main.home' | t }}</a>
        <span class="aura-product-main__breadcrumb-sep" aria-hidden="true">›</span>
        {% if product.collections.size > 0 %}
          {% assign bc_collection = product.collections.first %}
          <a href="{{ bc_collection.url }}">{{ bc_collection.title | escape }}</a>
          <span class="aura-product-main__breadcrumb-sep" aria-hidden="true">›</span>
        {% endif %}
        <span class="aura-product-main__breadcrumb-current">{{ product.title | escape }}</span>
      </nav>
    {% endif %}

    <div class="aura-product-main__hero">
      <div class="aura-product-main__gallery">
        <div class="aura-product-main__thumbs" data-aura-gallery-thumbs>
          {% if media_list.size > 0 %}
            {% for media in media_list %}
              <button
                type="button"
                class="aura-product-main__thumb{% if forloop.first %} is-active{% endif %}"
                data-aura-gallery-thumb
                data-media-id="{{ media.id }}"
                aria-label="{{ 'sections.aura_product_main.view_image' | t: index: forloop.index }}"
              >
                {% if media.media_type == 'video' or media.media_type == 'external_video' %}
                  <span class="aura-product-main__thumb-video-badge" aria-hidden="true">▶</span>
                {% endif %}
                {% if media.preview_image %}
                  {{ media.preview_image | image_url: width: 200 | image_tag: loading: 'lazy', alt: media.alt | default: product.title | escape }}
                {% else %}
                  <span class="aura-product-main__thumb-fallback">{{ 'sections.aura_product_main.media' | t }}</span>
                {% endif %}
              </button>
            {% endfor %}
          {% else %}
            <div class="aura-product-main__thumb aura-product-main__thumb--placeholder is-active">
              <span>{{ 'sections.aura_product_main.placeholder' | t }}</span>
            </div>
          {% endif %}
        </div>

        <div class="aura-product-main__main-wrap">
          <div
            class="aura-product-main__main"
            data-aura-gallery-main
            data-active-id="{% if first_media %}{{ first_media.id }}{% endif %}"
          >
            {% if section.settings.show_badge and section.settings.badge_text != blank %}
              <span class="aura-product-main__badge">
                {% render 'aura-icon', icon: 'heart', class: 'aura-product-main__badge-icon' %}
                {{ section.settings.badge_text | escape }}
              </span>
            {% endif %}

            <div class="aura-product-main__slides" data-aura-slides>
              {% if media_list.size > 0 %}
                {% for media in media_list %}
                  <div
                    class="aura-product-main__slide{% if forloop.first %} is-active{% endif %}"
                    data-aura-gallery-slide
                    data-media-id="{{ media.id }}"
                    data-media-type="{{ media.media_type }}"
                    {% if media.media_type == 'image' %}
                      data-zoom-src="{{ media | image_url: width: 2400 }}"
                      data-zoom-alt="{{ media.alt | default: product.title | escape }}"
                    {% endif %}
                  >
                    {% case media.media_type %}
                      {% when 'image' %}
                        {{ media | image_url: width: 2000 | image_tag: loading: 'lazy', alt: media.alt | default: product.title, class: 'aura-product-main__main-img' }}
                      {% when 'video' %}
                        {{ media | video_tag: controls: true, class: 'aura-product-main__video' }}
                      {% when 'external_video' %}
                        {{ media | external_video_tag: class: 'aura-product-main__video' }}
                      {% else %}
                        {{ media | media_tag }}
                    {% endcase %}
                  </div>
                {% endfor %}
              {% else %}
                <div class="aura-product-main__slide is-active aura-product-main__slide--placeholder" data-aura-gallery-slide data-media-type="placeholder">
                  <span>{{ 'sections.aura_product_main.main_placeholder' | t }}</span>
                </div>
              {% endif %}
            </div>

            {% if media_list.size > 1 %}
              <button type="button" class="aura-product-main__arrow aura-product-main__arrow--prev" data-aura-gallery-prev aria-label="{{ 'sections.aura_product_main.previous' | t }}">‹</button>
              <button type="button" class="aura-product-main__arrow aura-product-main__arrow--next" data-aura-gallery-next aria-label="{{ 'sections.aura_product_main.next' | t }}">›</button>
            {% endif %}

            {% if section.settings.show_zoom_icon and gallery_has_image %}
              <button
                type="button"
                class="aura-product-main__zoom"
                data-aura-zoom-open
                aria-label="{{ 'sections.aura_product_main.zoom' | t }}"
                hidden
              >
                ⌕
              </button>
            {% endif %}
          </div>
        </div>
      </div>

      <div
        class="aura-product-main__info{% if section.blocks.size > 0 %} aura-product-main__info--blocks{% endif %}"
      >
        {% if section.blocks.size > 0 %}
          {% assign product_form_id = 'AuraProductForm-' | append: section.id %}
          {% form 'product', product, id: product_form_id, class: 'aura-product-main__form aura-product-main__form--blocks' %}
            <input type="hidden" name="id" value="{{ current_variant.id }}" data-aura-variant-id>
            {% render 'aura-product-info-blocks-loop',
              form: form,
              product: product,
              section: section,
              current_variant: current_variant,
              display_subtitle: display_subtitle,
              benefits_meta: benefits_meta,
              fallback_benefits: fallback_benefits,
              pdp_variant_on_sale: pdp_variant_on_sale
            %}
          {% endform %}
        {% else %}
          {% if eyebrow != blank %}
            <p class="aura-product-main__eyebrow">{{ eyebrow | upcase | escape }}</p>
          {% endif %}

          <h1 class="aura-product-main__title">{{ product.title | escape }}</h1>

          {% if display_subtitle != blank %}
            <p class="aura-product-main__subtitle">{{ display_subtitle | escape }}</p>
          {% endif %}

          {% if section.settings.show_rating %}
            {% liquid
              assign rating_num = section.settings.rating_value | plus: 0
              assign full_stars = rating_num | floor
            %}
            <div class="aura-product-main__rating">
              <span class="aura-product-main__stars" aria-hidden="true">
                {% for i in (1..5) %}
                  {% if i <= full_stars %}
                    <span class="aura-product-main__star aura-product-main__star--full">★</span>
                  {% else %}
                    <span class="aura-product-main__star aura-product-main__star--muted">★</span>
                  {% endif %}
                {% endfor %}
              </span>
              <span class="aura-product-main__rating-meta">
                {{ section.settings.rating_value | escape }} ({{ section.settings.review_count | escape }})
              </span>
            </div>
          {% endif %}

          <div class="aura-product-main__price-row">
            <s
              class="aura-product-main__price-compare"
              data-aura-compare
              {% unless pdp_variant_on_sale %}
                hidden
              {% endunless %}
            >
              {%- if pdp_variant_on_sale -%}
                {{- current_variant.compare_at_price | money -}}
              {%- endif -%}
            </s>
            <span class="aura-product-main__price-current" data-aura-price>{{ current_variant.price | money }}</span>
          </div>

          {% if product.description != blank %}
            <div class="aura-product-main__desc rte">{{ product.description }}</div>
          {% endif %}

          {% if section.settings.show_benefits %}
            <ul class="aura-product-main__benefits">
              {% if benefits_meta != blank %}
                {% assign rendered_benefits = false %}
                {% if benefits_meta.type contains 'list' %}
                  {% if benefits_meta.value %}
                    {% for row in benefits_meta.value %}
                      {% assign rendered_benefits = true %}
                      <li>{{ row | strip | escape }}</li>
                    {% endfor %}
                  {% endif %}
                {% endif %}
                {% unless rendered_benefits %}
                  {% if benefits_meta.value != blank %}
                    {% assign benefit_lines = benefits_meta.value | newline_to_br | split: '<br />' %}
                    {% for line in benefit_lines %}
                      {% assign tline = line | strip | strip_html %}
                      {% if tline != blank %}
                        <li>{{ tline | escape }}</li>
                      {% endif %}
                    {% endfor %}
                  {% endif %}
                {% endunless %}
              {% else %}
                {% for line in fallback_benefits %}
                  <li>{{ line | escape }}</li>
                {% endfor %}
              {% endif %}
            </ul>
          {% endif %}

          {% assign legacy_form_id = 'AuraProductForm-' | append: section.id %}
          {% form 'product', product, id: legacy_form_id, class: 'aura-product-main__form' %}
            <input type="hidden" name="id" value="{{ current_variant.id }}" data-aura-variant-id>

            {% if product.options_with_values.size > 0 %}
              <div class="aura-product-main__options" data-aura-options>
                {% for option in product.options_with_values %}
                  <div class="aura-product-main__option">
                    <p class="aura-product-main__option-label">{{ option.name | escape }}</p>
                    <div class="aura-product-main__pills">
                      {% for value in option.values %}
                        {% assign opt_index = forloop.parentloop.index0 %}
                        {% liquid
                          assign is_selected = false
                          if option.selected_value == value
                            assign is_selected = true
                          endif
                        %}
                        <button
                          type="button"
                          class="aura-product-main__pill{% if is_selected %} is-active{% endif %}"
                          data-aura-option
                          data-option-index="{{ opt_index }}"
                          data-value="{{ value | escape }}"
                        >
                          {{ value | escape }}
                        </button>
                      {% endfor %}
                    </div>
                  </div>
                {% endfor %}
              </div>
            {% endif %}

            <div class="aura-product-main__purchase">
              <div class="aura-product-main__purchase-row aura-product-main__purchase-row--static">
                <span>{{ 'sections.aura_product_main.one_time' | t }}</span>
                <strong class="aura-product-main__purchase-price-wrap">
                  <s
                    class="aura-product-main__purchase-compare"
                    data-aura-one-time-compare
                    {% unless pdp_variant_on_sale %}
                      hidden
                    {% endunless %}
                  >
                    {%- if pdp_variant_on_sale -%}
                      {{- current_variant.compare_at_price | money -}}
                    {%- endif -%}
                  </s>
                  <span class="aura-product-main__purchase-current" data-aura-one-time-price>{{ current_variant.price | money }}</span>
                </strong>
              </div>
            </div>

            <div class="aura-product-main__cart-row">
              <div class="aura-product-main__qty">
                <button type="button" class="aura-product-main__qty-btn" data-aura-qty-dec aria-label="{{ 'sections.aura_product_main.decrease' | t }}">−</button>
                <input
                  class="aura-product-main__qty-input"
                  name="quantity"
                  type="number"
                  value="1"
                  min="1"
                  data-aura-qty
                  aria-label="{{ 'sections.aura_product_main.quantity' | t }}"
                >
                <button type="button" class="aura-product-main__qty-btn" data-aura-qty-inc aria-label="{{ 'sections.aura_product_main.increase' | t }}">+</button>
              </div>

              <button
                type="submit"
                name="add"
                class="aura-product-main__submit"
                {% unless current_variant.available %}
                  disabled
                {% endunless %}
                data-aura-add
                data-label-available="{{ 'sections.aura_product_main.add_to_cart' | t | escape }}"
                data-label-loading="{{ 'sections.aura_product_main.add_to_cart_loading' | t | escape }}"
                data-label-soldout="{{ 'sections.aura_product_main.sold_out' | t | escape }}"
              >
                <span class="aura-product-main__submit-spinner" aria-hidden="true"></span>
                <span class="aura-product-main__submit-label">
                  {% if current_variant.available %}
                    {{ 'sections.aura_product_main.add_to_cart' | t }}
                  {% else %}
                    {{ 'sections.aura_product_main.sold_out' | t }}
                  {% endif %}
                </span>
              </button>
            </div>

            {% if section.settings.show_dynamic_checkout %}
              <div class="aura-product-main__dynamic" data-aura-dynamic-checkout>
                {{ form | payment_button }}
              </div>
            {% endif %}
          {% endform %}

          {% if section.settings.show_points %}
            {% liquid
              assign pts_initial = current_variant.price | times: section.settings.points_multiplier | divided_by: 100.0 | round
              assign points_tpl = 'sections.aura_product_main.points_earn' | t: points: '__POINTS__', reward_label: section.settings.points_label
            %}
            {% if section.settings.points_text_override != blank %}
              <p class="aura-product-main__points">{{ section.settings.points_text_override | escape }}</p>
            {% else %}
              <p
                class="aura-product-main__points"
                data-aura-points-wrap
                data-points-mult="{{ section.settings.points_multiplier }}"
                data-points-format="{{ points_tpl | escape }}"
              >
                <span class="aura-product-main__points-inner">
                  {% render 'aura-icon', icon: 'sparkle', class: 'aura-product-main__points-icon' %}
                  <span data-aura-points-text>{{ 'sections.aura_product_main.points_earn' | t: points: pts_initial, reward_label: section.settings.points_label }}</span>
                </span>
              </p>
            {% endif %}
          {% endif %}
        {% endif %}
      </div>
    </div>
  </div>

  <script type="application/json" data-aura-variant-json>
    [
      {% for variant in product.variants %}
        {
          "id": {{ variant.id }},
          "price": {{ variant.price }},
          "compare_at_price": {% if variant.compare_at_price %}{{ variant.compare_at_price }}{% else %}null{% endif %},
          "available": {{ variant.available | json }},
          "options": {{ variant.options | json }},
          "featured_media_id": {% if variant.featured_media %}{{ variant.featured_media.id }}{% else %}null{% endif %},
          "image": {% if variant.featured_media %}{{ variant.featured_media | image_url: width: 360 | json }}{% elsif product.featured_image %}{{ product.featured_image | image_url: width: 360 | json }}{% else %}""{% endif %}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  </script>

  {% if section.settings.show_zoom_icon and gallery_has_image %}
    <div
      class="aura-product-main__lightbox"
      data-aura-lightbox
      role="dialog"
      aria-modal="true"
      aria-hidden="true"
      hidden
    >
      <div class="aura-product-main__lightbox-backdrop" data-aura-lightbox-close tabindex="-1"></div>
      <div class="aura-product-main__lightbox-panel">
        <button
          type="button"
          class="aura-product-main__lightbox-close"
          data-aura-lightbox-close
          aria-label="{{ 'sections.aura_product_main.lightbox_close' | t }}"
        >
          ×
        </button>
        <button
          type="button"
          class="aura-product-main__lightbox-nav aura-product-main__lightbox-nav--prev"
          data-aura-lightbox-prev
          aria-label="{{ 'sections.aura_product_main.lightbox_previous' | t }}"
        >
          ‹
        </button>
        <button
          type="button"
          class="aura-product-main__lightbox-nav aura-product-main__lightbox-nav--next"
          data-aura-lightbox-next
          aria-label="{{ 'sections.aura_product_main.lightbox_next' | t }}"
        >
          ›
        </button>
        <div class="aura-product-main__lightbox-stage">
          <img data-aura-lightbox-img src="" alt="" width="1600" height="1600" loading="lazy">
        </div>
      </div>
    </div>
  {% endif %}

  <div
    class="aura-product-main__cart-modal"
    data-aura-cart-modal
    role="dialog"
    aria-modal="true"
    aria-labelledby="aura-cart-modal-title-{{ section.id }}"
    aria-hidden="true"
    hidden
  >
    <div class="aura-product-main__cart-modal-backdrop" data-aura-cart-modal-dismiss tabindex="-1"></div>
    <div class="aura-product-main__cart-modal-panel" data-aura-cart-modal-panel>
      <button
        type="button"
        class="aura-product-main__cart-modal-close"
        data-aura-cart-modal-dismiss
        aria-label="{{ 'sections.aura_product_main.added_close' | t }}"
      >
        ×
      </button>
      <div class="aura-product-main__cart-modal-heading-row">
        <span class="aura-product-main__cart-modal-check" aria-hidden="true">
          {% render 'aura-icon', icon: 'check', class: 'aura-product-main__cart-modal-check-glyph' %}
        </span>
        <h2 id="aura-cart-modal-title-{{ section.id }}" class="aura-product-main__cart-modal-title">
          {{ 'sections.aura_product_main.cart_modal_title' | t }}
        </h2>
      </div>

      <div class="aura-product-main__cart-modal-body" data-aura-cart-modal-body>
        <div class="aura-product-main__cart-modal-product-row">
          <div class="aura-product-main__cart-modal-thumb-wrap">
            <img
              class="aura-product-main__cart-modal-thumb"
              data-aura-cart-modal-img
              src=""
              alt=""
              width="88"
              height="88"
              loading="lazy"
            >
          </div>
          <div class="aura-product-main__cart-modal-product-info">
            <p class="aura-product-main__cart-modal-product-title" data-aura-cart-modal-product-title></p>
            <p class="aura-product-main__cart-modal-variant" data-aura-cart-modal-variant hidden></p>
            <p class="aura-product-main__cart-modal-line-qty" data-aura-cart-modal-line-qty hidden></p>
          </div>
          <div class="aura-product-main__cart-modal-line-price-wrap">
            <s class="aura-product-main__cart-modal-line-compare" data-aura-cart-modal-line-compare hidden></s>
            <span class="aura-product-main__cart-modal-line-price" data-aura-cart-modal-line-price></span>
          </div>
        </div>

        <div class="aura-product-main__cart-modal-divider" aria-hidden="true"></div>

        <div class="aura-product-main__cart-modal-subtotal-row">
          <span class="aura-product-main__cart-modal-subtotal-label" data-aura-cart-modal-subtotal-label></span>
          <span class="aura-product-main__cart-modal-subtotal-amount" data-aura-cart-modal-subtotal-amount></span>
        </div>

        {% if section.settings.cart_modal_show_rewards %}
          <div class="aura-product-main__cart-modal-rewards" data-aura-cart-modal-rewards>
            <div class="aura-product-main__cart-modal-progress-row">
              <span class="aura-product-main__cart-modal-progress-icon aura-product-main__cart-modal-progress-icon--leading" aria-hidden="true">
                {% render 'aura-icon', icon: 'sparkle', class: 'aura-product-main__cart-modal-progress-icon-inner' %}
              </span>
              <p class="aura-product-main__cart-modal-reward-msg" data-aura-cart-modal-reward-msg></p>
              <span class="aura-product-main__cart-modal-reward-points" data-aura-cart-modal-reward-points></span>
              <span class="aura-product-main__cart-modal-progress-icon aura-product-main__cart-modal-progress-icon--trailing" aria-hidden="true">
                {% render 'aura-icon', icon: 'gift', class: 'aura-product-main__cart-modal-progress-icon-inner' %}
              </span>
            </div>
            <div class="aura-product-main__cart-modal-progress" aria-hidden="true">
              <div class="aura-product-main__cart-modal-progress-track">
                <div class="aura-product-main__cart-modal-progress-fill" data-aura-cart-modal-progress-fill></div>
              </div>
            </div>
          </div>
        {% endif %}
      </div>

      <p class="aura-product-main__cart-modal-error" data-aura-cart-modal-error hidden></p>

      <div class="aura-product-main__cart-modal-actions">
        <a class="aura-product-main__cart-modal-button aura-product-main__cart-modal-button--outline" data-aura-cart-modal-cart-link href="{{ routes.cart_url }}">
          {{ 'sections.aura_product_main.view_cart' | t }}
        </a>
        <button type="button" class="aura-product-main__cart-modal-button aura-product-main__cart-modal-button--outline" data-aura-cart-modal-continue>
          {{ 'sections.aura_product_main.continue_shopping' | t }}
        </button>
        <a class="aura-product-main__cart-modal-button aura-product-main__cart-modal-button--checkout" data-aura-cart-modal-checkout href="{{ shop.url }}/checkout">
          {{ 'sections.aura_product_main.checkout' | t }}
        </a>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .aura-product-main {
    background: var(--apm-background);
  }

  .aura-product-main__inner {
    width: min(var(--apm-max-width), calc(100% - 48px));
    margin: 0 auto;
    padding-top: var(--apm-padding-top-d);
    padding-bottom: var(--apm-padding-bottom-d);
  }

  .aura-product-main__info--blocks {
    min-width: 0;
    width: 100%;
  }

  .aura-product-main__form--blocks {
    display: flex;
    flex-direction: column;
    gap: var(--apm-info-block-gap, 0px);
    width: 100%;
    min-width: 0;
  }

  .aura-product-main .aura-product-main__app-slot {
    width: 100%;
    min-width: 0;
    margin-block: var(--apm-app-block-margin, 0);
  }

  .aura-product-main__breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
    padding: 2rem 0 1.75rem;
    color: #7d8491;
    font-size: 0.8125rem;
  }

  .aura-product-main__breadcrumb a {
    color: inherit;
    text-decoration: none;
  }

  .aura-product-main__breadcrumb a:hover {
    text-decoration: underline;
  }

  .aura-product-main__breadcrumb-current {
    color: #4b5568;
    font-weight: 600;
  }

  .aura-product-main__hero {
    display: grid;
    grid-template-columns: 1.12fr 0.88fr;
    gap: clamp(2rem, 4vw, 4.25rem);
    align-items: start;
    padding-bottom: 3rem;
  }

  .aura-product-main__gallery {
    display: grid;
    grid-template-columns: var(--apm-thumb-size) 1fr;
    gap: 1.35rem;
    align-items: start;
  }

  .aura-product-main__thumbs {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: var(--apm-thumb-size);
    max-width: 100%;
    align-self: start;
    flex-shrink: 0;
  }

  .aura-product-main__thumb {
    position: relative;
    width: var(--apm-thumb-size);
    height: var(--apm-thumb-size);
    min-height: 0;
    padding: 0;
    margin: 0;
    border-radius: var(--apm-thumb-radius);
    border: 2px solid var(--apm-border);
    background: linear-gradient(135deg, #f8cfc4, #fff4ef);
    cursor: pointer;
    overflow: hidden;
    flex-shrink: 0;
    box-sizing: border-box;
  }

  .aura-product-main__thumb img {
    width: 100%;
    height: 100%;
    object-fit: var(--apm-thumb-fit);
    object-position: center;
    display: block;
  }

  .aura-product-main__thumb.is-active {
    border-color: var(--apm-accent);
    box-shadow: 0 0 0 1px rgba(236, 0, 140, 0.2);
  }

  .aura-product-main__thumb--placeholder,
  .aura-product-main__thumb-fallback {
    display: grid;
    place-items: center;
    font-size: 0.65rem;
    font-weight: 700;
    color: #af8077;
    text-align: center;
    padding: 0.35rem;
  }

  .aura-product-main__thumb-video-badge {
    position: absolute;
    right: 4px;
    bottom: 4px;
    font-size: 0.65rem;
    background: rgba(255, 255, 255, 0.9);
    border-radius: 4px;
    padding: 2px 4px;
    z-index: 1;
  }

  .aura-product-main__main-wrap {
    min-width: 0;
    width: 100%;
  }

  .aura-product-main__main {
    position: relative;
    border-radius: var(--apm-gallery-radius);
    background: #fff;
    box-shadow: 0 18px 45px rgba(68, 36, 58, 0.08);
    overflow: hidden;
    display: block;
  }

  .aura-product-main__slides {
    position: relative;
    width: 100%;
    height: auto;
    box-sizing: border-box;
  }

  .aura-product-main__slide {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    min-width: 0;
    display: block;
    box-sizing: border-box;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.38s ease, visibility 0.38s ease;
    z-index: 0;
    pointer-events: none;
  }

  .aura-product-main__slide.is-active {
    position: relative;
    left: auto;
    top: auto;
    opacity: 1;
    visibility: visible;
    z-index: 1;
    pointer-events: auto;
  }

  .aura-product-main__main-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .aura-product-main__video,
  .aura-product-main__slide > video {
    width: 100%;
    height: auto;
    display: block;
  }

  .aura-product-main__slide .aura-product-main__video {
    width: 100%;
    height: auto;
    min-height: 0;
    display: block;
  }

  .aura-product-main__slide iframe,
  .aura-product-main__slide .aura-product-main__video iframe {
    width: 100%;
    aspect-ratio: 16 / 9;
    height: auto;
    max-height: 80vh;
    border: 0;
    display: block;
  }

  .aura-product-main__slide--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background: #f7f5f3;
    color: #6d6562;
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-align: center;
  }

  .aura-product-main__badge {
    position: absolute;
    top: 1.75rem;
    left: 1.75rem;
    z-index: 4;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: #fff;
    color: var(--apm-heading);
    border-radius: 999px;
    padding: 0.55rem 1rem;
    font-size: 0.75rem;
    font-weight: 800;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .aura-product-main__badge-icon {
    width: 1rem;
    height: 1rem;
    color: var(--apm-accent);
  }

  .aura-product-main__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 0;
    background: #fff;
    color: var(--apm-accent);
    display: grid;
    place-items: center;
    font-weight: 900;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
    cursor: pointer;
  }

  .aura-product-main__arrow--prev {
    left: 1.75rem;
  }

  .aura-product-main__arrow--next {
    right: 1.75rem;
  }

  .aura-product-main__zoom {
    position: absolute;
    right: 1.5rem;
    bottom: 1.5rem;
    z-index: 3;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 0;
    background: #fff;
    display: grid;
    place-items: center;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
    color: #6e4d59;
    cursor: pointer;
    font-size: 1.1rem;
    line-height: 1;
    padding: 0;
  }

  .aura-product-main__zoom:focus {
    outline: 2px solid var(--apm-accent);
    outline-offset: 2px;
  }

  .aura-product-main__zoom[hidden] {
    display: none !important;
  }

  .aura-product-main__lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    box-sizing: border-box;
  }

  .aura-product-main__lightbox[hidden] {
    display: none !important;
  }

  .aura-product-main__lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(27, 44, 88, 0.55);
    cursor: pointer;
  }

  .aura-product-main__lightbox-panel {
    position: relative;
    z-index: 2;
    max-width: min(96vw, 1200px);
    max-height: min(92vh, 900px);
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .aura-product-main__lightbox-panel > * {
    pointer-events: auto;
  }

  .aura-product-main__lightbox-stage {
    background: #fff8f4;
    border-radius: var(--apm-gallery-radius);
    padding: 0.75rem;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.25);
    max-width: 100%;
    max-height: min(88vh, 860px);
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
  }

  .aura-product-main__lightbox-stage img {
    max-width: 100%;
    max-height: min(82vh, 800px);
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    transition: opacity 0.25s ease;
  }

  .aura-product-main__lightbox-close {
    position: absolute;
    top: -0.25rem;
    right: -0.25rem;
    width: 44px;
    height: 44px;
    border: 0;
    border-radius: 50%;
    background: #fff;
    color: var(--apm-heading);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    z-index: 3;
  }

  .aura-product-main__lightbox-close:focus {
    outline: 2px solid var(--apm-accent);
    outline-offset: 2px;
  }

  .aura-product-main__lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border: 0;
    border-radius: 50%;
    background: #fff;
    color: var(--apm-accent);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    z-index: 3;
    display: grid;
    place-items: center;
  }

  .aura-product-main__lightbox-nav:focus {
    outline: 2px solid var(--apm-accent);
    outline-offset: 2px;
  }

  .aura-product-main__lightbox-nav[hidden] {
    display: none !important;
  }

  .aura-product-main__lightbox-nav--prev {
    left: 0.25rem;
  }

  .aura-product-main__lightbox-nav--next {
    right: 0.25rem;
  }

  @media (max-width: 640px) {
    .aura-product-main__lightbox-close {
      top: 0.5rem;
      right: 0.5rem;
    }

    .aura-product-main__lightbox-nav--prev {
      left: 0.35rem;
    }

    .aura-product-main__lightbox-nav--next {
      right: 0.35rem;
    }

    .aura-product-main__lightbox-stage {
      padding: 0.5rem;
    }
  }

  .aura-product-main__cart-modal {
    position: fixed;
    inset: 0;
    z-index: 10050;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    box-sizing: border-box;
    overflow-x: hidden;
  }

  .aura-product-main__cart-modal[hidden] {
    display: none !important;
  }

  .aura-product-main__cart-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(27, 44, 88, 0.48);
    cursor: pointer;
  }

  .aura-product-main__cart-modal-panel {
    position: relative;
    z-index: 2;
    width: calc(100vw - 32px);
    max-width: 760px;
    max-height: calc(100vh - 48px);
    overflow-x: hidden;
    overflow-y: auto;
    background: #fff;
    border-radius: clamp(10px, 2vw, 14px);
    padding: 1.5rem 1.25rem 1.35rem;
    box-shadow: 0 28px 64px rgba(27, 44, 88, 0.2);
    border: 1px solid var(--apm-border);
    box-sizing: border-box;
    min-width: 0;
  }

  .aura-product-main__cart-modal-panel--error .aura-product-main__cart-modal-body {
    display: none;
  }

  .aura-product-main__cart-modal-close {
    position: absolute;
    top: 0.55rem;
    right: 0.55rem;
    width: 40px;
    height: 40px;
    border: 0;
    border-radius: 50%;
    background: #f4f0ee;
    color: var(--apm-heading);
    font-size: 1.35rem;
    line-height: 1;
    cursor: pointer;
    display: grid;
    place-items: center;
  }

  .aura-product-main__cart-modal-close:focus {
    outline: 2px solid var(--apm-accent);
    outline-offset: 2px;
  }

  .aura-product-main__cart-modal-heading-row {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin: 0 2.25rem 1.1rem 0;
    flex-wrap: nowrap;
    max-width: 100%;
    min-width: 0;
  }

  .aura-product-main__cart-modal-check {
    width: 2.35rem;
    height: 2.35rem;
    border-radius: 50%;
    background: #fce4ef;
    display: grid;
    place-items: center;
    color: #43318f;
    flex-shrink: 0;
  }

  .aura-product-main__cart-modal-check-glyph {
    display: grid;
    place-items: center;
    line-height: 0;
  }

  .aura-product-main__cart-modal-check-glyph svg {
    width: 14px;
    height: 14px;
    stroke-width: 2.2;
  }

  .aura-product-main__cart-modal-title {
    font-family: var(--font-heading--family, Georgia, 'Times New Roman', serif);
    color: var(--apm-heading);
    font-size: clamp(1.05rem, 3.5vw, 1.28rem);
    font-weight: 600;
    margin: 0;
    line-height: 1.25;
    letter-spacing: -0.02em;
    min-width: 0;
  }

  .aura-product-main__cart-modal-body {
    margin-bottom: 1rem;
    max-width: 100%;
    min-width: 0;
    box-sizing: border-box;
    overflow-x: hidden;
  }

  .aura-product-main__cart-modal-product-row {
    display: grid;
    grid-template-columns: 4.75rem minmax(0, 1fr) minmax(0, auto);
    gap: 0.65rem 0.75rem;
    align-items: start;
    max-width: 100%;
    min-width: 0;
  }

  .aura-product-main__cart-modal-thumb-wrap {
    border-radius: 10px;
    overflow: hidden;
    background: #faf7f5;
    aspect-ratio: 1;
  }

  .aura-product-main__cart-modal-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    vertical-align: middle;
  }

  .aura-product-main__cart-modal-thumb[hidden] {
    display: none !important;
  }

  .aura-product-main__cart-modal-product-info {
    min-width: 0;
  }

  .aura-product-main__cart-modal-product-title {
    margin: 0 0 0.2rem;
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--apm-heading);
    line-height: 1.35;
  }

  .aura-product-main__cart-modal-variant {
    margin: 0;
    font-size: 0.8125rem;
    color: #6b7280;
    line-height: 1.35;
  }

  .aura-product-main__cart-modal-variant[hidden] {
    display: none !important;
  }

  .aura-product-main__cart-modal-line-qty {
    margin: 0.2rem 0 0;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #6b7280;
    line-height: 1.35;
  }

  .aura-product-main__cart-modal-line-qty[hidden] {
    display: none !important;
  }

  .aura-product-main__cart-modal-line-price-wrap {
    text-align: right;
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--apm-heading);
    line-height: 1.3;
    min-width: 0;
    max-width: 100%;
    white-space: normal;
    word-break: normal;
    overflow-wrap: anywhere;
  }

  .aura-product-main__cart-modal-line-compare {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    color: #9ca3af;
    text-decoration: line-through;
    margin-bottom: 0.15rem;
  }

  .aura-product-main__cart-modal-line-compare[hidden] {
    display: none !important;
  }

  .aura-product-main__cart-modal-line-price {
    display: block;
  }

  .aura-product-main__cart-modal-divider {
    height: 1px;
    background: var(--apm-border);
    margin: 1rem 0;
  }

  .aura-product-main__cart-modal-subtotal-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--apm-heading);
    max-width: 100%;
    min-width: 0;
  }

  .aura-product-main__cart-modal-subtotal-label {
    flex: 1;
    min-width: 0;
    padding-right: 0.5rem;
  }

  .aura-product-main__cart-modal-subtotal-amount {
    flex-shrink: 0;
  }

  .aura-product-main__cart-modal-rewards {
    margin-top: 1rem;
    padding: 1.125rem 1.25rem 1.25rem;
    border-radius: 12px;
    background: var(--apm-cart-modal-reward-bg);
    border: 1px solid var(--apm-cart-modal-reward-border);
    box-sizing: border-box;
    max-width: 100%;
    min-width: 0;
    overflow: hidden;
  }

  .aura-product-main__cart-modal-progress-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    box-sizing: border-box;
    margin-bottom: 0.875rem;
    writing-mode: horizontal-tb;
  }

  .aura-product-main__cart-modal-progress-icon {
    flex: 0 0 20px;
    width: 20px;
    min-width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
    color: var(--apm-accent);
  }

  .aura-product-main__cart-modal-progress-icon--trailing {
    color: var(--apm-heading);
    opacity: 0.9;
  }

  .aura-product-main__cart-modal-progress-icon-inner {
    display: flex !important;
    align-items: center;
    justify-content: center;
    width: 20px !important;
    height: 20px !important;
    min-width: 20px !important;
    min-height: 20px !important;
    flex: 0 0 20px !important;
    line-height: 0;
  }

  .aura-product-main__cart-modal-progress-icon-inner svg {
    width: 20px !important;
    height: 20px !important;
    max-width: 20px !important;
    max-height: 20px !important;
    display: block;
    flex-shrink: 0;
  }

  .aura-product-main__cart-modal-reward-msg {
    margin: 0;
    flex: 1 1 auto;
    min-width: 0;
    font-size: 0.8125rem;
    line-height: 1.45;
    color: var(--apm-text);
    white-space: normal;
    word-break: normal;
    overflow-wrap: break-word;
    writing-mode: horizontal-tb;
  }

  .aura-product-main__cart-modal-reward-msg strong {
    font-weight: 800;
    color: var(--apm-heading);
  }

  .aura-product-main__cart-modal-reward-points {
    flex: 0 1 auto;
    min-width: 0;
    font-size: 0.75rem;
    font-weight: 700;
    color: #5b5260;
    text-align: right;
    line-height: 1.35;
    white-space: normal;
    word-break: normal;
    writing-mode: horizontal-tb;
    max-width: 40%;
  }

  .aura-product-main__cart-modal-progress {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    box-sizing: border-box;
  }

  .aura-product-main__cart-modal-progress-track {
    width: 100%;
    max-width: 100%;
    height: 8px;
    border-radius: 999px;
    background: var(--apm-cart-modal-progress-track);
    overflow: hidden;
    border: 1px solid rgba(236, 0, 140, 0.12);
    box-sizing: border-box;
  }

  .aura-product-main__cart-modal-progress-fill {
    height: 100%;
    width: 0%;
    border-radius: 999px;
    background: var(--apm-cart-modal-progress-bar);
    transition: width 0.35s ease;
  }

  .aura-product-main__cart-modal-error {
    margin: 0 0 1rem;
    color: #b42318;
    font-size: 0.875rem;
    line-height: 1.4;
  }

  .aura-product-main__cart-modal-error[hidden] {
    display: none !important;
  }

  .aura-product-main__cart-modal-panel--error .aura-product-main__cart-modal-error {
    display: block !important;
  }

  .aura-product-main__cart-modal-actions {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 0.25rem;
    max-width: 100%;
    min-width: 0;
    box-sizing: border-box;
  }

