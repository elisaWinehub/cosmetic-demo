{% comment %}
  Aura Society — product hero (PDP). Uses product object; enable on product templates only.
{% endcomment %}
{% liquid
  assign root_class = 'aura-product-main-' | append: section.id
  assign current_variant = product.selected_or_first_available_variant
  assign media_list = product.media
  assign first_media = media_list | first
  assign eyebrow = product.type
  if section.settings.eyebrow_override != blank
    assign eyebrow = section.settings.eyebrow_override
  endif

  assign mf_ns = section.settings.benefits_metafield_namespace | default: 'custom'
  assign mf_key = section.settings.benefits_metafield_key | default: 'benefits'
  assign benefits_meta = blank
  if mf_ns != blank and mf_key != blank and product.metafields[mf_ns][mf_key] != blank
    assign benefits_meta = product.metafields[mf_ns][mf_key]
  endif

  assign fallback_benefits = 'Boosts natural glow||Improves texture and radiance||Hydrates and soothes||Safe for sensitive skin' | split: '||'

  assign gallery_has_image = false
  if media_list.size > 0
    for media in media_list
      if media.media_type == 'image'
        assign gallery_has_image = true
        break
      endif
    endfor
  endif
%}

<section
  class="aura-product-main {{ root_class }}"
  data-aura-product-main
  data-points-mult="{{ section.settings.points_multiplier }}"
  data-money-format="{{ shop.money_format | escape }}"
  style="
    --apm-max-width: {{ section.settings.section_width }}px;
    --apm-background: {{ section.settings.background_color }};
    --apm-text: {{ section.settings.text_color }};
    --apm-heading: {{ section.settings.heading_color }};
    --apm-accent: {{ section.settings.accent_color }};
    --apm-border: {{ section.settings.border_color }};
    --apm-gradient: linear-gradient(90deg, {{ section.settings.button_gradient_start }} 0%, {{ section.settings.button_gradient_end }} 100%);
    --apm-gallery-radius: {{ section.settings.gallery_radius }}px;
    --apm-thumb-radius: {{ section.settings.thumbnail_radius }}px;
    --apm-thumb-size: {{ section.settings.thumbnail_size }}px;
    --apm-thumb-fit: {{ section.settings.thumbnail_object_fit }};
    --apm-button-radius: {{ section.settings.button_radius }}px;
    --apm-title-desktop: {{ section.settings.title_size_desktop }}px;
    --apm-title-mobile: {{ section.settings.title_size_mobile }}px;
    --apm-body: {{ section.settings.body_size }}px;
    --apm-button-font: {{ section.settings.button_font_size }}px;
    --apm-padding-top-d: {{ section.settings.padding_top_desktop }}px;
    --apm-padding-bottom-d: {{ section.settings.padding_bottom_desktop }}px;
    --apm-padding-top-m: {{ section.settings.padding_top_mobile }}px;
    --apm-padding-bottom-m: {{ section.settings.padding_bottom_mobile }}px;
    --apm-star-color: {{ section.settings.star_color }};
  "
>
  <div class="aura-product-main__inner">
    {% if section.settings.show_breadcrumbs %}
      <nav class="aura-product-main__breadcrumb" aria-label="{{ 'sections.aura_product_main.breadcrumb_aria' | t }}">
        <a href="{{ routes.root_url }}">{{ 'sections.aura_product_main.home' | t }}</a>
        <span class="aura-product-main__breadcrumb-sep" aria-hidden="true">›</span>
        {% if product.collections.size > 0 %}
          {% assign bc_collection = product.collections.first %}
          <a href="{{ bc_collection.url }}">{{ bc_collection.title | escape }}</a>
          <span class="aura-product-main__breadcrumb-sep" aria-hidden="true">›</span>
        {% endif %}
        <span class="aura-product-main__breadcrumb-current">{{ product.title | escape }}</span>
      </nav>
    {% endif %}

    <div class="aura-product-main__hero">
      <div class="aura-product-main__gallery">
        <div class="aura-product-main__thumbs" data-aura-gallery-thumbs>
          {% if media_list.size > 0 %}
            {% for media in media_list %}
              <button
                type="button"
                class="aura-product-main__thumb{% if forloop.first %} is-active{% endif %}"
                data-aura-gallery-thumb
                data-media-id="{{ media.id }}"
                aria-label="{{ 'sections.aura_product_main.view_image' | t: index: forloop.index }}"
              >
                {% if media.media_type == 'video' or media.media_type == 'external_video' %}
                  <span class="aura-product-main__thumb-video-badge" aria-hidden="true">▶</span>
                {% endif %}
                {% if media.preview_image %}
                  {{ media.preview_image | image_url: width: 200 | image_tag: loading: 'lazy', alt: media.alt | default: product.title | escape }}
                {% else %}
                  <span class="aura-product-main__thumb-fallback">{{ 'sections.aura_product_main.media' | t }}</span>
                {% endif %}
              </button>
            {% endfor %}
          {% else %}
            <div class="aura-product-main__thumb aura-product-main__thumb--placeholder is-active">
              <span>{{ 'sections.aura_product_main.placeholder' | t }}</span>
            </div>
          {% endif %}
        </div>

        <div class="aura-product-main__main-wrap">
          <div
            class="aura-product-main__main"
            data-aura-gallery-main
            data-active-id="{% if first_media %}{{ first_media.id }}{% endif %}"
          >
            {% if section.settings.show_badge and section.settings.badge_text != blank %}
              <span class="aura-product-main__badge">
                {% render 'aura-icon', icon: 'heart', class: 'aura-product-main__badge-icon' %}
                {{ section.settings.badge_text | escape }}
              </span>
            {% endif %}

            <div class="aura-product-main__slides" data-aura-slides>
              {% if media_list.size > 0 %}
                {% for media in media_list %}
                  <div
                    class="aura-product-main__slide{% if forloop.first %} is-active{% endif %}"
                    data-aura-gallery-slide
                    data-media-id="{{ media.id }}"
                    data-media-type="{{ media.media_type }}"
                    {% if media.media_type == 'image' %}
                      data-zoom-src="{{ media | image_url: width: 2400 }}"
                      data-zoom-alt="{{ media.alt | default: product.title | escape }}"
                    {% endif %}
                  >
                    {% case media.media_type %}
                      {% when 'image' %}
                        {{ media | image_url: width: 2000 | image_tag: loading: 'lazy', alt: media.alt | default: product.title, class: 'aura-product-main__main-img' }}
                      {% when 'video' %}
                        {{ media | video_tag: controls: true, class: 'aura-product-main__video' }}
                      {% when 'external_video' %}
                        {{ media | external_video_tag: class: 'aura-product-main__video' }}
                      {% else %}
                        {{ media | media_tag }}
                    {% endcase %}
                  </div>
                {% endfor %}
              {% else %}
                <div class="aura-product-main__slide is-active aura-product-main__slide--placeholder" data-aura-gallery-slide data-media-type="placeholder">
                  <span>{{ 'sections.aura_product_main.main_placeholder' | t }}</span>
                </div>
              {% endif %}
            </div>

            {% if media_list.size > 1 %}
              <button type="button" class="aura-product-main__arrow aura-product-main__arrow--prev" data-aura-gallery-prev aria-label="{{ 'sections.aura_product_main.previous' | t }}">‹</button>
              <button type="button" class="aura-product-main__arrow aura-product-main__arrow--next" data-aura-gallery-next aria-label="{{ 'sections.aura_product_main.next' | t }}">›</button>
            {% endif %}

            {% if section.settings.show_zoom_icon and gallery_has_image %}
              <button
                type="button"
                class="aura-product-main__zoom"
                data-aura-zoom-open
                aria-label="{{ 'sections.aura_product_main.zoom' | t }}"
                hidden
              >
                ⌕
              </button>
            {% endif %}
          </div>
        </div>
      </div>

      <div class="aura-product-main__info">
        {% if eyebrow != blank %}
          <p class="aura-product-main__eyebrow">{{ eyebrow | upcase | escape }}</p>
        {% endif %}

        <h1 class="aura-product-main__title">{{ product.title | escape }}</h1>

        {% if section.settings.subtitle != blank %}
          <p class="aura-product-main__subtitle">{{ section.settings.subtitle | escape }}</p>
        {% endif %}

        {% if section.settings.show_rating %}
          {% liquid
            assign rating_num = section.settings.rating_value | plus: 0
            assign full_stars = rating_num | floor
          %}
          <div class="aura-product-main__rating">
            <span class="aura-product-main__stars" aria-hidden="true">
              {% for i in (1..5) %}
                {% if i <= full_stars %}
                  <span class="aura-product-main__star aura-product-main__star--full">★</span>
                {% else %}
                  <span class="aura-product-main__star aura-product-main__star--muted">★</span>
                {% endif %}
              {% endfor %}
            </span>
            <span class="aura-product-main__rating-meta">
              {{ section.settings.rating_value | escape }} ({{ section.settings.review_count | escape }})
            </span>
          </div>
        {% endif %}

        <div class="aura-product-main__price-row">
          <span class="aura-product-main__price" data-aura-price>{{ current_variant.price | money }}</span>
          <span
            class="aura-product-main__compare"
            data-aura-compare
            {% unless current_variant.compare_at_price > current_variant.price %}
              hidden
            {% endunless %}
          >
            {%- if current_variant.compare_at_price > current_variant.price -%}
              {{ current_variant.compare_at_price | money }}
            {%- endif -%}
          </span>
        </div>

        {% if product.description != blank %}
          <div class="aura-product-main__desc rte">{{ product.description }}</div>
        {% endif %}

        {% if section.settings.show_benefits %}
          <ul class="aura-product-main__benefits">
            {% if benefits_meta != blank %}
              {% assign rendered_benefits = false %}
              {% if benefits_meta.type contains 'list' %}
                {% if benefits_meta.value %}
                  {% for row in benefits_meta.value %}
                    {% assign rendered_benefits = true %}
                    <li>{{ row | strip | escape }}</li>
                  {% endfor %}
                {% endif %}
              {% endif %}
              {% unless rendered_benefits %}
                {% if benefits_meta.value != blank %}
                  {% assign benefit_lines = benefits_meta.value | newline_to_br | split: '<br />' %}
                  {% for line in benefit_lines %}
                    {% assign tline = line | strip | strip_html %}
                    {% if tline != blank %}
                      <li>{{ tline | escape }}</li>
                    {% endif %}
                  {% endfor %}
                {% endif %}
              {% endunless %}
            {% else %}
              {% for line in fallback_benefits %}
                <li>{{ line | escape }}</li>
              {% endfor %}
            {% endif %}
          </ul>
        {% endif %}

        {% assign product_form_id = 'AuraProductForm-' | append: section.id %}
        {% form 'product', product, id: product_form_id, class: 'aura-product-main__form' %}
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-aura-variant-id>

          {% if product.options_with_values.size > 0 %}
            <div class="aura-product-main__options" data-aura-options>
              {% for option in product.options_with_values %}
                <div class="aura-product-main__option">
                  <p class="aura-product-main__option-label">{{ option.name | escape }}</p>
                  <div class="aura-product-main__pills">
                    {% for value in option.values %}
                      {% assign opt_index = forloop.parentloop.index0 %}
                      {% liquid
                        assign is_selected = false
                        if option.selected_value == value
                          assign is_selected = true
                        endif
                      %}
                      <button
                        type="button"
                        class="aura-product-main__pill{% if is_selected %} is-active{% endif %}"
                        data-aura-option
                        data-option-index="{{ opt_index }}"
                        data-value="{{ value | escape }}"
                      >
                        {{ value | escape }}
                      </button>
                    {% endfor %}
                  </div>
                </div>
              {% endfor %}
            </div>
          {% endif %}

          <div class="aura-product-main__purchase">
            <div class="aura-product-main__purchase-row aura-product-main__purchase-row--static">
              <span>{{ 'sections.aura_product_main.one_time' | t }}</span>
              <strong data-aura-one-time-price>{{ current_variant.price | money }}</strong>
            </div>
          </div>

          <div class="aura-product-main__cart-row">
            <div class="aura-product-main__qty">
              <button type="button" class="aura-product-main__qty-btn" data-aura-qty-dec aria-label="{{ 'sections.aura_product_main.decrease' | t }}">−</button>
              <input
                class="aura-product-main__qty-input"
                name="quantity"
                type="number"
                value="1"
                min="1"
                data-aura-qty
                aria-label="{{ 'sections.aura_product_main.quantity' | t }}"
              >
              <button type="button" class="aura-product-main__qty-btn" data-aura-qty-inc aria-label="{{ 'sections.aura_product_main.increase' | t }}">+</button>
            </div>

            <button
              type="submit"
              name="add"
              class="aura-product-main__submit"
              {% unless current_variant.available %}
                disabled
              {% endunless %}
              data-aura-add
              data-label-available="{{ 'sections.aura_product_main.add_to_cart' | t | escape }}"
              data-label-soldout="{{ 'sections.aura_product_main.sold_out' | t | escape }}"
            >
              {% if current_variant.available %}
                {{ 'sections.aura_product_main.add_to_cart' | t }}
              {% else %}
                {{ 'sections.aura_product_main.sold_out' | t }}
              {% endif %}
            </button>
          </div>

          {% if section.settings.show_dynamic_checkout %}
            <div class="aura-product-main__dynamic" data-aura-dynamic-checkout>
              {{ form | payment_button }}
            </div>
          {% endif %}
        {% endform %}

        {% if section.settings.show_points %}
          {% liquid
            assign pts_initial = current_variant.price | times: section.settings.points_multiplier | divided_by: 100.0 | round
            assign points_tpl = 'sections.aura_product_main.points_earn' | t: points: '__POINTS__', label: section.settings.points_label
          %}
          {% if section.settings.points_text_override != blank %}
            <p class="aura-product-main__points">{{ section.settings.points_text_override | escape }}</p>
          {% else %}
            <p
              class="aura-product-main__points"
              data-aura-points-wrap
              data-points-mult="{{ section.settings.points_multiplier }}"
              data-points-format="{{ points_tpl | escape }}"
            >
              <span class="aura-product-main__points-inner">
                {% render 'aura-icon', icon: 'sparkle', class: 'aura-product-main__points-icon' %}
                <span data-aura-points-text>{{ 'sections.aura_product_main.points_earn' | t: points: pts_initial, label: section.settings.points_label }}</span>
              </span>
            </p>
          {% endif %}
        {% endif %}
      </div>
    </div>
  </div>

  <script type="application/json" data-aura-variant-json>
    [
      {% for variant in product.variants %}
        {
          "id": {{ variant.id }},
          "price": {{ variant.price }},
          "compare_at_price": {% if variant.compare_at_price %}{{ variant.compare_at_price }}{% else %}null{% endif %},
          "available": {{ variant.available | json }},
          "options": {{ variant.options | json }},
          "featured_media_id": {% if variant.featured_media %}{{ variant.featured_media.id }}{% else %}null{% endif %}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  </script>

  {% if section.settings.show_zoom_icon and gallery_has_image %}
    <div
      class="aura-product-main__lightbox"
      data-aura-lightbox
      role="dialog"
      aria-modal="true"
      aria-hidden="true"
      hidden
    >
      <div class="aura-product-main__lightbox-backdrop" data-aura-lightbox-close tabindex="-1"></div>
      <div class="aura-product-main__lightbox-panel">
        <button
          type="button"
          class="aura-product-main__lightbox-close"
          data-aura-lightbox-close
          aria-label="{{ 'sections.aura_product_main.lightbox_close' | t }}"
        >
          ×
        </button>
        <button
          type="button"
          class="aura-product-main__lightbox-nav aura-product-main__lightbox-nav--prev"
          data-aura-lightbox-prev
          aria-label="{{ 'sections.aura_product_main.lightbox_previous' | t }}"
        >
          ‹
        </button>
        <button
          type="button"
          class="aura-product-main__lightbox-nav aura-product-main__lightbox-nav--next"
          data-aura-lightbox-next
          aria-label="{{ 'sections.aura_product_main.lightbox_next' | t }}"
        >
          ›
        </button>
        <div class="aura-product-main__lightbox-stage">
          <img data-aura-lightbox-img src="" alt="" width="1600" height="1600" loading="lazy">
        </div>
      </div>
    </div>
  {% endif %}
</section>

{% stylesheet %}
  .aura-product-main {
    background: var(--apm-background);
  }

  .aura-product-main__inner {
    width: min(var(--apm-max-width), calc(100% - 48px));
    margin: 0 auto;
    padding-top: var(--apm-padding-top-d);
    padding-bottom: var(--apm-padding-bottom-d);
  }

  .aura-product-main__breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
    padding: 2rem 0 1.75rem;
    color: #7d8491;
    font-size: 0.8125rem;
  }

  .aura-product-main__breadcrumb a {
    color: inherit;
    text-decoration: none;
  }

  .aura-product-main__breadcrumb a:hover {
    text-decoration: underline;
  }

  .aura-product-main__breadcrumb-current {
    color: #4b5568;
    font-weight: 600;
  }

  .aura-product-main__hero {
    display: grid;
    grid-template-columns: 1.12fr 0.88fr;
    gap: clamp(2rem, 4vw, 4.25rem);
    align-items: start;
    padding-bottom: 3rem;
  }

  .aura-product-main__gallery {
    display: grid;
    grid-template-columns: var(--apm-thumb-size) 1fr;
    gap: 1.35rem;
    align-items: start;
  }

  .aura-product-main__thumbs {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: var(--apm-thumb-size);
    max-width: 100%;
    align-self: start;
    flex-shrink: 0;
  }

  .aura-product-main__thumb {
    position: relative;
    width: var(--apm-thumb-size);
    height: var(--apm-thumb-size);
    min-height: 0;
    padding: 0;
    margin: 0;
    border-radius: var(--apm-thumb-radius);
    border: 2px solid var(--apm-border);
    background: linear-gradient(135deg, #f8cfc4, #fff4ef);
    cursor: pointer;
    overflow: hidden;
    flex-shrink: 0;
    box-sizing: border-box;
  }

  .aura-product-main__thumb img {
    width: 100%;
    height: 100%;
    object-fit: var(--apm-thumb-fit);
    object-position: center;
    display: block;
  }

  .aura-product-main__thumb.is-active {
    border-color: var(--apm-accent);
    box-shadow: 0 0 0 1px rgba(236, 0, 140, 0.2);
  }

  .aura-product-main__thumb--placeholder,
  .aura-product-main__thumb-fallback {
    display: grid;
    place-items: center;
    font-size: 0.65rem;
    font-weight: 700;
    color: #af8077;
    text-align: center;
    padding: 0.35rem;
  }

  .aura-product-main__thumb-video-badge {
    position: absolute;
    right: 4px;
    bottom: 4px;
    font-size: 0.65rem;
    background: rgba(255, 255, 255, 0.9);
    border-radius: 4px;
    padding: 2px 4px;
    z-index: 1;
  }

  .aura-product-main__main-wrap {
    min-width: 0;
    width: 100%;
  }

  .aura-product-main__main {
    position: relative;
    border-radius: var(--apm-gallery-radius);
    background: #fff;
    box-shadow: 0 18px 45px rgba(68, 36, 58, 0.08);
    overflow: hidden;
    display: block;
  }

  .aura-product-main__slides {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: 1fr;
    width: 100%;
    max-width: 535px;
    max-height: 640px;
    margin-inline: auto;
    aspect-ratio: 535 / 640;
    height: auto;
    box-sizing: border-box;
  }

  .aura-product-main__slide {
    grid-row: 1;
    grid-column: 1;
    position: relative;
    min-width: 0;
    min-height: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.38s ease, visibility 0.38s ease;
    z-index: 0;
    pointer-events: none;
  }

  .aura-product-main__slide.is-active {
    opacity: 1;
    visibility: visible;
    z-index: 1;
    pointer-events: auto;
  }

  .aura-product-main__main-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    display: block;
  }

  .aura-product-main__video,
  .aura-product-main__slide > video {
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    object-position: center;
    display: block;
  }

  .aura-product-main__slide .aura-product-main__video {
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .aura-product-main__slide iframe,
  .aura-product-main__slide .aura-product-main__video iframe {
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    border: 0;
  }

  .aura-product-main__slide--placeholder {
    place-items: center;
    padding: 1.5rem;
    background: #f7f5f3;
    color: #6d6562;
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-align: center;
  }

  .aura-product-main__badge {
    position: absolute;
    top: 1.75rem;
    left: 1.75rem;
    z-index: 4;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: #fff;
    color: var(--apm-heading);
    border-radius: 999px;
    padding: 0.55rem 1rem;
    font-size: 0.75rem;
    font-weight: 800;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .aura-product-main__badge-icon {
    width: 1rem;
    height: 1rem;
    color: var(--apm-accent);
  }

  .aura-product-main__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 0;
    background: #fff;
    color: var(--apm-accent);
    display: grid;
    place-items: center;
    font-weight: 900;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
    cursor: pointer;
  }

  .aura-product-main__arrow--prev {
    left: 1.75rem;
  }

  .aura-product-main__arrow--next {
    right: 1.75rem;
  }

  .aura-product-main__zoom {
    position: absolute;
    right: 1.5rem;
    bottom: 1.5rem;
    z-index: 3;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 0;
    background: #fff;
    display: grid;
    place-items: center;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
    color: #6e4d59;
    cursor: pointer;
    font-size: 1.1rem;
    line-height: 1;
    padding: 0;
  }

  .aura-product-main__zoom:focus {
    outline: 2px solid var(--apm-accent);
    outline-offset: 2px;
  }

  .aura-product-main__zoom[hidden] {
    display: none !important;
  }

  .aura-product-main__lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    box-sizing: border-box;
