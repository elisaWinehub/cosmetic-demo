{% javascript %}
  (function () {
    function parseJson(el) {
      if (!el) return null;
      try {
        return JSON.parse(el.textContent);
      } catch (e) {
        return null;
      }
    }

    function formatMoney(cents, moneyFormat, currencySymbol) {
      var formatted;
      if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
        formatted = Shopify.formatMoney(cents, moneyFormat);
      } else {
        formatted = (cents / 100).toFixed(2);
      }
      var sym = currencySymbol || '';
      var t = String(formatted).trim();
      if (sym && t.length && t.charAt(0) >= '0' && t.charAt(0) <= '9') {
        return sym + t;
      }
      return formatted;
    }

    const roots = document.querySelectorAll('[data-aura-product-main]');
    roots.forEach(function (root) {
      const slides = root.querySelectorAll('[data-aura-gallery-slide]');
      const thumbs = root.querySelectorAll('[data-aura-gallery-thumb]');
      const mainEl = root.querySelector('[data-aura-gallery-main]');
      const prevBtn = root.querySelector('[data-aura-gallery-prev]');
      const nextBtn = root.querySelector('[data-aura-gallery-next]');
      const zoomOpen = root.querySelector('[data-aura-zoom-open]');
      const lightbox = root.querySelector('[data-aura-lightbox]');
      const lightboxImg = lightbox ? lightbox.querySelector('[data-aura-lightbox-img]') : null;
      const lightboxPrev = lightbox ? lightbox.querySelector('[data-aura-lightbox-prev]') : null;
      const lightboxNext = lightbox ? lightbox.querySelector('[data-aura-lightbox-next]') : null;
      const lightboxCloses = lightbox ? lightbox.querySelectorAll('[data-aura-lightbox-close]') : [];

      function getImageSlides() {
        return Array.from(slides).filter(function (s) {
          return (
            s.getAttribute('data-media-type') === 'image' &&
            s.getAttribute('data-zoom-src')
          );
        });
      }

      function syncZoomButton() {
        if (!zoomOpen) return;
        const active = root.querySelector('[data-aura-gallery-slide].is-active');
        if (
          active &&
          active.getAttribute('data-media-type') === 'image' &&
          active.getAttribute('data-zoom-src')
        ) {
          zoomOpen.hidden = false;
        } else {
          zoomOpen.hidden = true;
        }
      }

      function setGalleryByMediaId(mediaId) {
        if (!mediaId) return;
        const idStr = String(mediaId);
        slides.forEach(function (slide) {
          slide.classList.toggle('is-active', slide.getAttribute('data-media-id') === idStr);
        });
        thumbs.forEach(function (thumb) {
          thumb.classList.toggle('is-active', thumb.getAttribute('data-media-id') === idStr);
        });
        if (mainEl) mainEl.setAttribute('data-active-id', idStr);
        syncZoomButton();
      }

      function activateAdjacent(dir) {
        if (slides.length <= 1) return;
        const activeSlide = root.querySelector('[data-aura-gallery-slide].is-active');
        if (!activeSlide) return;
        const id = activeSlide.getAttribute('data-media-id');
        const ids = Array.from(slides)
          .map(function (s) {
            return s.getAttribute('data-media-id');
          })
          .filter(function (mid) {
            return mid != null && mid !== '';
          });
        const i = ids.indexOf(id);
        if (i < 0) return;
        const next = (i + dir + ids.length) % ids.length;
        setGalleryByMediaId(ids[next]);
      }

      var lightboxIndex = 0;
      var onDocKeydown = null;

      function showLightboxImage() {
        const imgs = getImageSlides();
        if (!lightboxImg || imgs.length === 0) return;
        const slide = imgs[lightboxIndex];
        const src = slide.getAttribute('data-zoom-src');
        const alt = slide.getAttribute('data-zoom-alt') || '';
        if (src) lightboxImg.setAttribute('src', src);
        lightboxImg.setAttribute('alt', alt);
        if (lightboxPrev) lightboxPrev.hidden = imgs.length <= 1;
        if (lightboxNext) lightboxNext.hidden = imgs.length <= 1;
      }

      function closeLightbox() {
        if (!lightbox) return;
        lightbox.setAttribute('hidden', 'hidden');
        lightbox.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        if (onDocKeydown) {
          document.removeEventListener('keydown', onDocKeydown);
          onDocKeydown = null;
        }
      }

      function openLightbox() {
        const imgs = getImageSlides();
        if (!lightbox || !lightboxImg || imgs.length === 0) return;
        const active = root.querySelector('[data-aura-gallery-slide].is-active');
        var idx = 0;
        if (active && active.getAttribute('data-media-type') === 'image') {
          const curId = active.getAttribute('data-media-id');
          const found = imgs.findIndex(function (s) {
            return s.getAttribute('data-media-id') === curId;
          });
          if (found >= 0) idx = found;
        }
        lightboxIndex = idx;
        showLightboxImage();
        lightbox.removeAttribute('hidden');
        lightbox.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        onDocKeydown = function (e) {
          if (e.key === 'Escape') closeLightbox();
        };
        document.addEventListener('keydown', onDocKeydown);
      }

      function lightboxAdjacent(dir) {
        const imgs = getImageSlides();
        if (imgs.length <= 1) return;
        lightboxIndex = (lightboxIndex + dir + imgs.length) % imgs.length;
        showLightboxImage();
      }

      thumbs.forEach(function (thumb) {
        thumb.addEventListener('click', function () {
          setGalleryByMediaId(thumb.getAttribute('data-media-id'));
        });
      });

      if (prevBtn) prevBtn.addEventListener('click', function () { activateAdjacent(-1); });
      if (nextBtn) nextBtn.addEventListener('click', function () { activateAdjacent(1); });

      if (zoomOpen) {
        zoomOpen.addEventListener('click', function (e) {
          e.preventDefault();
          openLightbox();
        });
      }

      if (lightbox && lightboxPrev) {
        lightboxPrev.addEventListener('click', function () { lightboxAdjacent(-1); });
      }
      if (lightbox && lightboxNext) {
        lightboxNext.addEventListener('click', function () { lightboxAdjacent(1); });
      }

      lightboxCloses.forEach(function (btn) {
        btn.addEventListener('click', function () { closeLightbox(); });
      });

      syncZoomButton();

      const variantScript = root.querySelector('[data-aura-variant-json]');
      const variants = parseJson(variantScript) || [];
      const form = root.querySelector('.aura-product-main__form');
      const idInput = root.querySelector('[data-aura-variant-id]');
      const priceEl = root.querySelector('[data-aura-price]');
      const compareEl = root.querySelector('[data-aura-compare]');
      const optionButtons = root.querySelectorAll('[data-aura-option]');
      const qtyInput = root.querySelector('[data-aura-qty]');
      const addBtn = root.querySelector('[data-aura-add]');
      const addBtnLabel = addBtn ? addBtn.querySelector('.aura-product-main__submit-label') : null;
      const pointsWrap = root.querySelector('[data-aura-points-wrap]');
      const pointsTextEl = root.querySelector('[data-aura-points-text]');
      const oneTimePriceEl = root.querySelector('[data-aura-one-time-price]');
      const oneTimeCompareEl = root.querySelector('[data-aura-one-time-compare]');
      const qtyDec = root.querySelector('[data-aura-qty-dec]');
      const qtyInc = root.querySelector('[data-aura-qty-inc]');
      const attrFormat = root.getAttribute('data-money-format');
      const currencySymbol = root.getAttribute('data-currency-symbol') || '';
      const moneyFormat =
        attrFormat ||
        (typeof window !== 'undefined' && window.Shopify && window.Shopify.money_format
          ? window.Shopify.money_format
          : '${{amount}}');

      if (!form || !idInput || variants.length === 0) return;

      const optionButtonCount = root.querySelectorAll('[data-aura-option]').length;
      const optionCount =
        optionButtonCount === 0
          ? 0
          : variants[0] && variants[0].options
            ? variants[0].options.length
            : 0;

      function getSelectedOptions() {
        const selected = [];
        for (let i = 0; i < optionCount; i++) {
          const active = root.querySelector(
            '[data-aura-option][data-option-index="' + i + '"].is-active'
          );
          selected.push(active ? active.getAttribute('data-value') : null);
        }
        return selected;
      }

      function findVariant() {
        if (optionCount === 0) return variants[0];
        const selected = getSelectedOptions();
        return variants.find(function (v) {
          if (!v.options || v.options.length !== selected.length) return false;
          return v.options.every(function (opt, idx) {
            return opt === selected[idx];
          });
        });
      }

      function applyVariant(v) {
        if (!v) return;
        idInput.value = v.id;
        if (priceEl) priceEl.textContent = formatMoney(v.price, moneyFormat, currencySymbol);
        if (compareEl) {
          if (v.compare_at_price && v.compare_at_price > v.price) {
            compareEl.removeAttribute('hidden');
            compareEl.textContent = formatMoney(v.compare_at_price, moneyFormat, currencySymbol);
          } else {
            compareEl.setAttribute('hidden', 'hidden');
            compareEl.textContent = '';
          }
        }
        if (v.featured_media_id) setGalleryByMediaId(v.featured_media_id);
        if (oneTimePriceEl) oneTimePriceEl.textContent = formatMoney(v.price, moneyFormat, currencySymbol);
        if (oneTimeCompareEl) {
          if (v.compare_at_price && v.compare_at_price > v.price) {
            oneTimeCompareEl.removeAttribute('hidden');
            oneTimeCompareEl.textContent = formatMoney(v.compare_at_price, moneyFormat, currencySymbol);
          } else {
            oneTimeCompareEl.setAttribute('hidden', 'hidden');
            oneTimeCompareEl.textContent = '';
          }
        }

        if (addBtn) {
          if (v.available) {
            addBtn.disabled = false;
            const availText = addBtn.getAttribute('data-label-available') || '';
            if (addBtnLabel) {
              addBtnLabel.textContent = availText || addBtnLabel.textContent;
            } else {
              addBtn.textContent = availText || addBtn.textContent;
            }
          } else {
            addBtn.disabled = true;
            const soldText = addBtn.getAttribute('data-label-soldout') || '';
            if (addBtnLabel) {
              addBtnLabel.textContent = soldText || addBtnLabel.textContent;
            } else {
              addBtn.textContent = soldText || addBtn.textContent;
            }
          }
        }

        const mult = parseFloat(pointsWrap ? pointsWrap.getAttribute('data-points-mult') || root.getAttribute('data-points-mult') : root.getAttribute('data-points-mult')) || 1;
        const fmt = pointsWrap ? pointsWrap.getAttribute('data-points-format') : '';
        if (pointsTextEl && fmt) {
          const pts = Math.round((v.price / 100) * mult);
          pointsTextEl.textContent = fmt.split('__POINTS__').join(String(pts));
        }
      }

      optionButtons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          const idx = btn.getAttribute('data-option-index');
          root.querySelectorAll('[data-aura-option][data-option-index="' + idx + '"]').forEach(function (b) {
            b.classList.remove('is-active');
          });
          btn.classList.add('is-active');
          const v = findVariant();
          applyVariant(v);
        });
      });

      if (qtyInput && qtyDec) {
        qtyDec.addEventListener('click', function () {
          const n = parseInt(qtyInput.value, 10) || 1;
          qtyInput.value = Math.max(1, n - 1);
        });
      }
      if (qtyInput && qtyInc) {
        qtyInc.addEventListener('click', function () {
          const n = parseInt(qtyInput.value, 10) || 1;
          qtyInput.value = n + 1;
        });
      }

      function normalizeAddLine(body) {
        if (!body) return null;
        if (Array.isArray(body)) return body[0] || null;
        if (body.items && body.items.length) return body.items[0];
        if (body.variant_id != null || body.id != null) return body;
        return null;
      }

      function cartQtyForVariant(cart, variantId) {
        if (!cart || !cart.items || variantId == null) return null;
        var idStr = String(variantId);
        var sum = 0;
        for (var i = 0; i < cart.items.length; i++) {
          var it = cart.items[i];
          if (it && String(it.variant_id) === idStr) {
            sum += parseInt(it.quantity, 10) || 0;
          }
        }
        return sum > 0 ? sum : null;
      }

      const cartModal = root.querySelector('[data-aura-cart-modal]');
      const cartModalPanel = root.querySelector('[data-aura-cart-modal-panel]');
      const cartModalError = root.querySelector('[data-aura-cart-modal-error]');
      const cartDismissers = root.querySelectorAll('[data-aura-cart-modal-dismiss]');
      const cartContinue = root.querySelector('[data-aura-cart-modal-continue]');
      const cartLink = root.querySelector('[data-aura-cart-modal-cart-link]');
      const cartCheckout = root.querySelector('[data-aura-cart-modal-checkout]');
      const cmImg = root.querySelector('[data-aura-cart-modal-img]');
      const cmTitle = root.querySelector('[data-aura-cart-modal-product-title]');
      const cmVariant = root.querySelector('[data-aura-cart-modal-variant]');
      const cmLineQty = root.querySelector('[data-aura-cart-modal-line-qty]');
      const cmLineCompare = root.querySelector('[data-aura-cart-modal-line-compare]');
      const cmLinePrice = root.querySelector('[data-aura-cart-modal-line-price]');
      const cmSubLabel = root.querySelector('[data-aura-cart-modal-subtotal-label]');
      const cmSubAmt = root.querySelector('[data-aura-cart-modal-subtotal-amount]');
      const cmRewards = root.querySelector('[data-aura-cart-modal-rewards]');
      const cmRewardMsg = root.querySelector('[data-aura-cart-modal-reward-msg]');
      const cmRewardPts = root.querySelector('[data-aura-cart-modal-reward-points]');
      const cmProgressFill = root.querySelector('[data-aura-cart-modal-progress-fill]');
      const cartAddUrl = root.getAttribute('data-cart-add-url');
      const cartJsonUrl = root.getAttribute('data-cart-json-url');
      var cartModalEscHandler = null;

      var cartUrlAttr = root.getAttribute('data-cart-url');
      var checkoutUrlAttr = root.getAttribute('data-checkout-url');
      if (cartLink && cartUrlAttr) cartLink.setAttribute('href', cartUrlAttr);
      if (cartCheckout && checkoutUrlAttr) cartCheckout.setAttribute('href', checkoutUrlAttr);

      function setCartModalErrorMode(isErr) {
        if (!cartModalPanel) return;
        cartModalPanel.classList.toggle('aura-product-main__cart-modal-panel--error', isErr);
      }

      function closeCartModal() {
        if (!cartModal) return;
        cartModal.setAttribute('hidden', 'hidden');
        cartModal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        if (cartModalEscHandler) {
          document.removeEventListener('keydown', cartModalEscHandler);
          cartModalEscHandler = null;
        }
        setCartModalErrorMode(false);
        if (cartModalError) {
          cartModalError.setAttribute('hidden', 'hidden');
          cartModalError.textContent = '';
        }
        if (cmRewardMsg) cmRewardMsg.innerHTML = '';
      }

      function openCartModal() {
        if (!cartModal) return;
        cartModal.removeAttribute('hidden');
        cartModal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        cartModalEscHandler = function (ev) {
          if (ev.key === 'Escape') closeCartModal();
        };
        document.addEventListener('keydown', cartModalEscHandler);
      }

      function populateCartModalSuccess(v, cart, qty, addBody) {
        if (!v) return;
        var pTitle = root.getAttribute('data-product-title') || '';
        var line = normalizeAddLine(addBody);
        var unitPrice = v.price;
        var unitCompare = v.compare_at_price;
        var onSale = unitCompare && unitCompare > unitPrice;
        var lineTotal = unitPrice * qty;
        if (line && typeof line.final_line_price === 'number') lineTotal = line.final_line_price;
        else if (line && typeof line.line_price === 'number') lineTotal = line.line_price;

        if (cmTitle) cmTitle.textContent = pTitle;
        var opts = v.options && v.options.length ? v.options.filter(function (o) { return o; }).join(' / ') : '';
        if (cmVariant) {
          if (opts) {
            cmVariant.textContent = opts;
            cmVariant.removeAttribute('hidden');
          } else {
            cmVariant.textContent = '';
            cmVariant.setAttribute('hidden', 'hidden');
          }
        }

        var inCartQty = cartQtyForVariant(cart, v.id);
        if (inCartQty == null || inCartQty < 1) {
          if (line && String(line.variant_id) === String(v.id) && typeof line.quantity === 'number') {
            inCartQty = line.quantity;
          }
        }
        if (inCartQty == null || inCartQty < 1) {
          inCartQty = qty;
        }
        if (cmLineQty) {
          var qtyTpl = root.getAttribute('data-cart-modal-line-qty-template') || 'Qty: [[count]]';
          cmLineQty.textContent = qtyTpl.split('[[count]]').join(String(inCartQty));
          cmLineQty.removeAttribute('hidden');
        }

        if (cmImg) {
          if (v.image) {
            cmImg.src = v.image;
            cmImg.alt = pTitle || '';
            cmImg.removeAttribute('hidden');
          } else {
            cmImg.removeAttribute('src');
            cmImg.alt = '';
            cmImg.setAttribute('hidden', 'hidden');
          }
        }
        if (cmLineCompare) {
          if (onSale) {
            cmLineCompare.textContent = formatMoney(unitCompare * qty, moneyFormat, currencySymbol);
            cmLineCompare.removeAttribute('hidden');
          } else {
            cmLineCompare.textContent = '';
            cmLineCompare.setAttribute('hidden', 'hidden');
          }
        }
        if (cmLinePrice) {
          cmLinePrice.textContent = formatMoney(lineTotal, moneyFormat, currencySymbol);
        }

        var cartTotalCents = cart && typeof cart.total_price === 'number' ? cart.total_price : null;
        var itemCount = cart && typeof cart.item_count === 'number' ? cart.item_count : qty;
        if (cartTotalCents == null && line && typeof line.final_line_price === 'number') {
          cartTotalCents = line.final_line_price;
        } else if (cartTotalCents == null) {
          cartTotalCents = lineTotal;
        }

        if (cmSubAmt) {
          cmSubAmt.textContent = formatMoney(cartTotalCents, moneyFormat, currencySymbol);
        }
        if (cmSubLabel) {
          var oneLbl = root.getAttribute('data-cart-modal-subtotal-one') || '';
          var othLbl = root.getAttribute('data-cart-modal-subtotal-other') || '';
          if (itemCount === 1 && oneLbl) {
            cmSubLabel.textContent = oneLbl;
          } else if (othLbl) {
            cmSubLabel.textContent = othLbl.split('[[count]]').join(String(itemCount));
          } else {
            cmSubLabel.textContent = '';
          }
        }

        var showRewards = root.getAttribute('data-cart-modal-show-rewards') === 'true';
        if (showRewards && cmRewards && cmRewardMsg && cmRewardPts && cmProgressFill) {
          var spendGoal = parseInt(root.getAttribute('data-reward-spend-goal-cents'), 10);
          if (!spendGoal || spendGoal < 1) spendGoal = 10000;
          var mult = parseFloat(root.getAttribute('data-cart-modal-points-mult')) || 1;
          var ptsMax = parseInt(root.getAttribute('data-reward-points-max'), 10) || 100;
          if (ptsMax < 1) ptsMax = 100;
          var rLabel = root.getAttribute('data-reward-label') || '';
          var tpl = root.getAttribute('data-reward-message-template');
          var tplFb = root.getAttribute('data-reward-message-fallback') || '';
          if (!tpl) tpl = tplFb;
          var completeMsg = root.getAttribute('data-reward-complete-msg') || '';

          var remaining = spendGoal - cartTotalCents;
          if (remaining <= 0) {
            cmRewardMsg.innerHTML = completeMsg;
          } else {
            var amtStr = formatMoney(remaining, moneyFormat, currencySymbol);
            var safeTpl = tpl || "You're [[amount]] away from your next reward!";
            cmRewardMsg.innerHTML = safeTpl.split('[[amount]]').join('<strong>' + amtStr + '</strong>');
          }

          var ptsEarned = Math.round((cartTotalCents * mult) / 100);
          cmRewardPts.textContent = ptsEarned + ' / ' + ptsMax + ' ' + rLabel;

          var spendPct = Math.min(100, Math.max(0, (cartTotalCents / spendGoal) * 100));
          cmProgressFill.style.width = spendPct + '%';
        } else if (cmProgressFill) {
          cmProgressFill.style.width = '0%';
        }

        setCartModalErrorMode(false);
        if (cartModalError) {
          cartModalError.setAttribute('hidden', 'hidden');
          cartModalError.textContent = '';
        }
      }

      cartDismissers.forEach(function (btn) {
        btn.addEventListener('click', function () { closeCartModal(); });
      });
      if (cartContinue) {
        cartContinue.addEventListener('click', function () { closeCartModal(); });
      }

      if (form && addBtn && cartAddUrl && cartJsonUrl) {
        form.addEventListener('submit', function (e) {
          var sub = e.submitter;
          if (!sub || sub.name !== 'add' || sub.disabled) return;
          e.preventDefault();
          var vid = idInput.value;
          if (!vid) return;
          var qty = qtyInput ? Math.max(1, parseInt(qtyInput.value, 10) || 1) : 1;
          var addBodyCache = null;
          var loadingLabel = addBtn.getAttribute('data-label-loading') || '';
          if (addBtnLabel && loadingLabel) {
            addBtnLabel.textContent = loadingLabel;
          }
          addBtn.setAttribute('aria-busy', 'true');
          addBtn.classList.add('is-loading');
          addBtn.disabled = true;
          fetch(cartAddUrl, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json',
            },
            body: JSON.stringify({ items: [{ id: Number(vid), quantity: qty }] }),
          })
            .then(function (res) {
              return res.json().then(function (body) {
                addBodyCache = body;
                return { ok: res.ok, body: body };
              });
            })
            .then(function (r) {
              var body = r.body || {};
              var err = !r.ok;
              if (!err && body.status) err = true;
              if (!err && body.errors) {
                var ek = Object.keys(body.errors);
                if (ek.length) err = true;
              }
              if (err) {
                var msg = '';
                if (body.message) msg = String(body.message);
                else if (typeof body.description === 'string') msg = body.description;
                else if (body.errors && Object.keys(body.errors).length) {
                  try {
                    msg = Object.values(body.errors).flat().join(' ');
                  } catch (ignore) {
                    msg = JSON.stringify(body.errors);
                  }
                }
                if (!msg) msg = root.getAttribute('data-added-error-msg') || '';
                if (cartModalError) {
                  cartModalError.textContent = msg;
                  cartModalError.removeAttribute('hidden');
                }
                setCartModalErrorMode(true);
                openCartModal();
                return Promise.reject('aura-cart-modal-handled');
              }
              return fetch(cartJsonUrl, { headers: { Accept: 'application/json' } })
                .then(function (res) {
                  return res.json();
                })
                .catch(function () {
                  return null;
                });
            })
            .then(function (cart) {
              var v = findVariant();
              populateCartModalSuccess(v, cart, qty, addBodyCache);
              var resourceCart = cart;
              if (!resourceCart) {
                resourceCart = { item_count: qty, total_price: null };
                var ln = normalizeAddLine(addBodyCache);
                if (ln && typeof ln.final_line_price === 'number') {
                  resourceCart.total_price = ln.final_line_price;
                } else if (v) {
                  resourceCart.total_price = v.price * qty;
                }
              }
              document.dispatchEvent(
                new CustomEvent('cart:update', {
                  bubbles: true,
                  detail: {
                    resource: resourceCart,
                    data: {
                      itemCount: qty,
                      source: 'product-form-component',
                    },
                  },
                })
              );
              openCartModal();
            })
            .catch(function (reason) {
              if (reason === 'aura-cart-modal-handled') return;
              if (cartModalError) {
                cartModalError.textContent = root.getAttribute('data-added-error-msg') || '';
                cartModalError.removeAttribute('hidden');
              }
              setCartModalErrorMode(true);
              openCartModal();
            })
            .finally(function () {
              addBtn.classList.remove('is-loading');
              addBtn.removeAttribute('aria-busy');
              applyVariant(findVariant());
            });
        });
      }

      const initial = variants.find(function (v) { return String(v.id) === String(idInput.value); });
      if (initial) applyVariant(initial);
    });
  })();
