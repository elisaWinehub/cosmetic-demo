{% javascript %}
  (function () {
    const root = document.querySelector('[data-aura-plp]');
    if (!root) return;

    function formatMoney(cents, moneyFormat, currencySymbol) {
      let formatted;
      if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
        formatted = Shopify.formatMoney(cents, moneyFormat);
      } else {
        formatted = (cents / 100).toFixed(2);
      }
      const sym = currencySymbol || '';
      const t = String(formatted).trim();
      if (sym && t.length && t.charAt(0) >= '0' && t.charAt(0) <= '9') {
        return sym + t;
      }
      return formatted;
    }

    function normalizeAddLine(body) {
      if (!body) return null;
      if (Array.isArray(body)) return body[0] || null;
      if (body.items && body.items.length) return body.items[0];
      if (body.variant_id != null || body.id != null) return body;
      return null;
    }

    function cartQtyForVariant(cart, variantId) {
      if (!cart || !cart.items || variantId == null) return null;
      const idStr = String(variantId);
      let sum = 0;
      for (let i = 0; i < cart.items.length; i++) {
        const it = cart.items[i];
        if (it && String(it.variant_id) === idStr) {
          sum += parseInt(it.quantity, 10) || 0;
        }
      }
      return sum > 0 ? sum : null;
    }

    const WISHLIST_KEY = 'aura-plp-wishlist-v2';

    const readWishlist = () => {
      try {
        let raw = localStorage.getItem(WISHLIST_KEY);
        if (!raw) raw = localStorage.getItem('aura-plp-wishlist');
        if (!raw) return [];
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return [];
        return parsed
          .map((entry) => {
            if (entry && typeof entry === 'object') {
              const id = entry.i != null ? String(entry.i) : entry.id != null ? String(entry.id) : '';
              const h = entry.h != null ? String(entry.h) : entry.handle != null ? String(entry.handle) : '';
              return { i: id, h };
            }
            if (typeof entry === 'string' || typeof entry === 'number') {
              return { i: String(entry), h: '' };
            }
            return { i: '', h: '' };
          })
          .filter((e) => e.i || e.h);
      } catch {
        return [];
      }
    };

    const writeWishlist = (entries) => {
      try {
        localStorage.setItem(WISHLIST_KEY, JSON.stringify(entries));
      } catch {
        /* ignore */
      }
    };

    const wishlistAddLabel = root.getAttribute('data-i18n-wishlist-add') || '';
    const wishlistRemoveLabel = root.getAttribute('data-i18n-wishlist-remove') || '';

    const form = root.querySelector('[data-aura-plp-facet-form]');
    if (form) {
      form.addEventListener('change', (e) => {
        const t = e.target;
        if (t && t.matches && t.matches('[data-aura-plp-auto-submit]')) {
          form.requestSubmit();
        }
      });
    }

    const sortSelect = root.querySelector('[data-aura-plp-sort]');
    if (sortSelect && form) {
      sortSelect.addEventListener('change', () => {
        form.requestSubmit();
      });
    }

    const grid = root.querySelector('[data-aura-plp-grid]');
    const viewKey = 'aura-plp-view-' + (root.getAttribute('data-section-id') || 'default');

    const applyView = (mode) => {
      if (!grid) return;
      if (mode === 'list') {
        grid.classList.add('aura-plp-grid--list');
      } else {
        grid.classList.remove('aura-plp-grid--list');
      }
      root.querySelectorAll('[data-aura-plp-view]').forEach((btn) => {
        const m = btn.getAttribute('data-aura-plp-view');
        const on = m === mode;
        btn.classList.toggle('is-active', on);
        btn.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
      try {
        sessionStorage.setItem(viewKey, mode);
      } catch {
        /* ignore */
      }
    };

    let initialView = 'grid';
    try {
      const saved = sessionStorage.getItem(viewKey);
      if (saved === 'list' || saved === 'grid') initialView = saved;
    } catch {
      /* ignore */
    }
    applyView(initialView);

    root.querySelectorAll('[data-aura-plp-view]').forEach((btn) => {
      btn.addEventListener('click', () => {
        applyView(btn.getAttribute('data-aura-plp-view') || 'grid');
      });
    });

    const sidebar = root.querySelector('[data-aura-plp-sidebar]');
    const overlay = root.querySelector('[data-aura-plp-overlay]');
    const openBtn = root.querySelector('[data-aura-plp-open-filters]');
    const closeBtn = root.querySelector('[data-aura-plp-close-filters]');

    const setDrawer = (open) => {
      if (!sidebar) return;
      sidebar.classList.toggle('is-open', open);
      if (overlay) {
        overlay.classList.toggle('is-visible', open);
        overlay.hidden = !open;
      }
      if (openBtn) openBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
    };

    if (openBtn) openBtn.addEventListener('click', () => setDrawer(true));
    if (closeBtn) closeBtn.addEventListener('click', () => setDrawer(false));
    if (overlay) overlay.addEventListener('click', () => setDrawer(false));

    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      if (sidebar && sidebar.classList.contains('is-open')) setDrawer(false);
    });

    const syncWishBtn = (btn) => {
      const id = btn.getAttribute('data-product-id');
      const h = (btn.getAttribute('data-product-handle') || '').trim();
      if (!id && !h) return;
      const entries = readWishlist();
      const on = entries.some(
        (e) => (id && e.i === String(id)) || (h && e.h && e.h === h)
      );
      btn.setAttribute('aria-pressed', on ? 'true' : 'false');
      if (wishlistRemoveLabel && wishlistAddLabel) {
        btn.setAttribute('aria-label', on ? wishlistRemoveLabel : wishlistAddLabel);
      }
    };

    root.querySelectorAll('[data-aura-wishlist]').forEach((btn) => {
      syncWishBtn(btn);
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const id = btn.getAttribute('data-product-id');
        const h = (btn.getAttribute('data-product-handle') || '').trim();
        if (!id && !h) return;
        let entries = readWishlist();
        const sid = id ? String(id) : '';
        const on = entries.some(
          (e) => (sid && e.i === sid) || (h && e.h && e.h === h)
        );
        if (on) {
          entries = entries.filter(
            (e) => !((sid && e.i === sid) || (h && e.h && e.h === h))
          );
        } else {
          entries = entries.concat([{ i: sid, h: h || '' }]);
        }
        writeWishlist(entries);
        root.querySelectorAll('[data-aura-wishlist]').forEach(syncWishBtn);
      });
    });

    root.querySelectorAll('[data-aura-plp-qty]').forEach((wrap) => {
      const input = wrap.querySelector('[data-aura-plp-qty-input]');
      const dec = wrap.querySelector('[data-aura-plp-qty-dec]');
      const inc = wrap.querySelector('[data-aura-plp-qty-inc]');
      if (!input) return;
      const clamp = () => {
        let n = parseInt(input.value, 10);
        if (Number.isNaN(n) || n < 1) n = 1;
        if (n > 99) n = 99;
        input.value = String(n);
      };
      if (dec) dec.addEventListener('click', () => { input.value = String(Math.max(1, (parseInt(input.value, 10) || 1) - 1)); });
      if (inc) inc.addEventListener('click', () => { input.value = String(Math.min(99, (parseInt(input.value, 10) || 1) + 1)); });
      input.addEventListener('change', clamp);
    });

    const cartAddUrl = root.getAttribute('data-cart-add-url');
    const cartJsonUrl = root.getAttribute('data-cart-json-url');
    const errMsg = root.getAttribute('data-add-error') || '';
    const attrFormat = root.getAttribute('data-money-format');
    const currencySymbol = root.getAttribute('data-currency-symbol') || '';
    const moneyFormat =
      attrFormat ||
      (typeof window !== 'undefined' && window.Shopify && window.Shopify.money_format
        ? window.Shopify.money_format
        : '${{amount}}');

    const plpCartModal = root.querySelector('[data-aura-plp-cart-modal]');
    const plpCartPanel = root.querySelector('[data-aura-plp-cart-modal-panel]');
    const plpCartError = root.querySelector('[data-aura-plp-cart-modal-error]');
    const plpCartDismissers = root.querySelectorAll('[data-aura-plp-cart-modal-dismiss]');
    const plpCartContinue = root.querySelector('[data-aura-plp-cart-modal-continue]');
    const plpCmImg = root.querySelector('[data-aura-plp-cart-modal-img]');
    const plpCmTitle = root.querySelector('[data-aura-plp-cart-modal-product-title]');
    const plpCmVariant = root.querySelector('[data-aura-plp-cart-modal-variant]');
    const plpCmLineQty = root.querySelector('[data-aura-plp-cart-modal-line-qty]');
    const plpCmLineCompare = root.querySelector('[data-aura-plp-cart-modal-line-compare]');
    const plpCmLinePrice = root.querySelector('[data-aura-plp-cart-modal-line-price]');
    const plpCmSubLabel = root.querySelector('[data-aura-plp-cart-modal-subtotal-label]');
    const plpCmSubAmt = root.querySelector('[data-aura-plp-cart-modal-subtotal-amount]');
    const plpCmRewards = root.querySelector('[data-aura-plp-cart-modal-rewards]');
    const plpCmRewardMsg = root.querySelector('[data-aura-plp-cart-modal-reward-msg]');
    const plpCmRewardPts = root.querySelector('[data-aura-plp-cart-modal-reward-points]');
    const plpCmProgressFill = root.querySelector('[data-aura-plp-cart-modal-progress-fill]');
    let plpCartEscHandler = null;

    const cartUrlAttr = root.getAttribute('data-cart-url');
    const checkoutUrlAttr = root.getAttribute('data-checkout-url');
    const plpCartLink = root.querySelector('[data-aura-plp-cart-modal-cart-link]');
    const plpCheckoutLink = root.querySelector('[data-aura-plp-cart-modal-checkout]');
    if (plpCartLink && cartUrlAttr) plpCartLink.setAttribute('href', cartUrlAttr);
    if (plpCheckoutLink && checkoutUrlAttr) plpCheckoutLink.setAttribute('href', checkoutUrlAttr);

    function setPlpCartModalErrorMode(isErr) {
      if (!plpCartPanel) return;
      plpCartPanel.classList.toggle('aura-plp-cart-modal__panel--error', isErr);
    }

    function closePlpCartModal() {
      if (!plpCartModal) return;
      plpCartModal.setAttribute('hidden', 'hidden');
      plpCartModal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      if (plpCartEscHandler) {
        document.removeEventListener('keydown', plpCartEscHandler);
        plpCartEscHandler = null;
      }
      setPlpCartModalErrorMode(false);
      if (plpCartError) {
        plpCartError.setAttribute('hidden', 'hidden');
        plpCartError.textContent = '';
      }
    }

    function openPlpCartModal() {
      if (!plpCartModal) return;
      plpCartModal.removeAttribute('hidden');
      plpCartModal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      plpCartEscHandler = (ev) => {
        if (ev.key === 'Escape') closePlpCartModal();
      };
      document.addEventListener('keydown', plpCartEscHandler);
    }

    function populatePlpCartModalSuccess(card, cart, qty, variantId, addBody) {
      if (!card) return;
      const unitPrice = parseInt(card.getAttribute('data-variant-price-cents'), 10) || 0;
      const compareRaw = parseInt(card.getAttribute('data-variant-compare-cents'), 10) || 0;
      const unitCompare = compareRaw > unitPrice ? compareRaw : null;
      const onSale = Boolean(unitCompare && unitCompare > unitPrice);
      let lineTotal = unitPrice * qty;
      const line = normalizeAddLine(addBody);
      if (line && typeof line.final_line_price === 'number') lineTotal = line.final_line_price;
      else if (line && typeof line.line_price === 'number') lineTotal = line.line_price;

      let pTitle = '';
      const titleEl = card.querySelector('.aura-plp-card__title');
      if (titleEl) pTitle = titleEl.textContent || '';

      if (plpCmTitle) plpCmTitle.textContent = pTitle;

      const vLabel = (card.getAttribute('data-variant-label') || '').trim();
      if (plpCmVariant) {
        if (vLabel) {
          plpCmVariant.textContent = vLabel;
          plpCmVariant.removeAttribute('hidden');
        } else {
          plpCmVariant.textContent = '';
          plpCmVariant.setAttribute('hidden', 'hidden');
        }
      }

      let inCartQty = cartQtyForVariant(cart, variantId);
      if (inCartQty == null || inCartQty < 1) {
        if (line && String(line.variant_id) === String(variantId) && typeof line.quantity === 'number') {
          inCartQty = line.quantity;
        }
      }
      if (inCartQty == null || inCartQty < 1) {
        inCartQty = qty;
      }
      if (plpCmLineQty) {
        const qtyTpl = root.getAttribute('data-cart-modal-line-qty-template') || '';
        plpCmLineQty.textContent = qtyTpl.split('[[count]]').join(String(inCartQty));
        plpCmLineQty.removeAttribute('hidden');
      }

      if (plpCmImg) {
        const imgEl = card.querySelector('.aura-plp-card__img--primary');
        const src = imgEl ? imgEl.currentSrc || imgEl.getAttribute('src') || '' : '';
        if (src) {
          plpCmImg.src = src;
          plpCmImg.alt = pTitle || '';
          plpCmImg.removeAttribute('hidden');
        } else {
          plpCmImg.removeAttribute('src');
          plpCmImg.alt = '';
          plpCmImg.setAttribute('hidden', 'hidden');
        }
      }

      if (plpCmLineCompare) {
        if (onSale) {
          plpCmLineCompare.textContent = formatMoney(unitCompare * qty, moneyFormat, currencySymbol);
          plpCmLineCompare.removeAttribute('hidden');
        } else {
          plpCmLineCompare.textContent = '';
          plpCmLineCompare.setAttribute('hidden', 'hidden');
        }
      }
      if (plpCmLinePrice) {
        plpCmLinePrice.textContent = formatMoney(lineTotal, moneyFormat, currencySymbol);
      }

      let cartTotalCents = cart && typeof cart.total_price === 'number' ? cart.total_price : null;
      let itemCount = cart && typeof cart.item_count === 'number' ? cart.item_count : qty;
      if (cartTotalCents == null && line && typeof line.final_line_price === 'number') {
        cartTotalCents = line.final_line_price;
      } else if (cartTotalCents == null) {
        cartTotalCents = lineTotal;
      }

      if (plpCmSubAmt) {
        plpCmSubAmt.textContent = formatMoney(cartTotalCents, moneyFormat, currencySymbol);
      }
      if (plpCmSubLabel) {
        const oneLbl = root.getAttribute('data-cart-modal-subtotal-one') || '';
        const othLbl = root.getAttribute('data-cart-modal-subtotal-other') || '';
        if (itemCount === 1 && oneLbl) {
          plpCmSubLabel.textContent = oneLbl;
        } else if (othLbl) {
          plpCmSubLabel.textContent = othLbl.split('[[count]]').join(String(itemCount));
        } else {
          plpCmSubLabel.textContent = '';
        }
      }

      const showRewards = root.getAttribute('data-cart-modal-show-rewards') === 'true';
      if (showRewards && plpCmRewards && plpCmRewardMsg && plpCmRewardPts && plpCmProgressFill) {
        let spendGoal = parseInt(root.getAttribute('data-reward-spend-goal-cents'), 10);
        if (!spendGoal || spendGoal < 1) spendGoal = 10000;
        const mult = parseFloat(root.getAttribute('data-cart-modal-points-mult')) || 1;
        let ptsMax = parseInt(root.getAttribute('data-reward-points-max'), 10) || 100;
        if (ptsMax < 1) ptsMax = 100;
        const rLabel = root.getAttribute('data-reward-label') || '';
        let tpl = root.getAttribute('data-reward-message-template');
        const tplFb = root.getAttribute('data-reward-message-fallback') || '';
        if (!tpl) tpl = tplFb;
        const completeMsg = root.getAttribute('data-reward-complete-msg') || '';

        const remaining = spendGoal - cartTotalCents;
        if (remaining <= 0) {
          plpCmRewardMsg.innerHTML = completeMsg;
        } else {
          const amtStr = formatMoney(remaining, moneyFormat, currencySymbol);
          const safeTpl = tpl || "You're [[amount]] away from your next reward!";
          plpCmRewardMsg.innerHTML = safeTpl.split('[[amount]]').join('<strong>' + amtStr + '</strong>');
        }

        const ptsEarned = Math.round((cartTotalCents * mult) / 100);
        plpCmRewardPts.textContent = ptsEarned + ' / ' + ptsMax + ' ' + rLabel;

        const spendPct = Math.min(100, Math.max(0, (cartTotalCents / spendGoal) * 100));
        plpCmProgressFill.style.width = spendPct + '%';
      } else if (plpCmProgressFill) {
        plpCmProgressFill.style.width = '0%';
      }

      setPlpCartModalErrorMode(false);
      if (plpCartError) {
        plpCartError.setAttribute('hidden', 'hidden');
        plpCartError.textContent = '';
      }
    }

    plpCartDismissers.forEach((btn) => {
      btn.addEventListener('click', () => closePlpCartModal());
    });
    if (plpCartContinue) {
      plpCartContinue.addEventListener('click', () => closePlpCartModal());
    }

    root.querySelectorAll('[data-aura-quick-add]').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        if (btn.disabled || !cartAddUrl) return;
        const card = btn.closest('[data-aura-plp-card]');
        const vid = btn.getAttribute('data-variant-id');
        if (!vid) return;
        let qty = 1;
        if (card) {
          const qin = card.querySelector('[data-aura-plp-qty-input]');
          if (qin) qty = Math.max(1, parseInt(qin.value, 10) || 1);
        }
        let addBodyCache = null;
        btn.classList.add('is-loading');
        btn.setAttribute('aria-busy', 'true');
        fetch(cartAddUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({ items: [{ id: Number(vid), quantity: qty }] }),
        })
          .then((res) =>
            res.json().then((body) => {
              addBodyCache = body;
              return { ok: res.ok, body };
            })
          )
          .then(({ ok, body }) => {
            let err = !ok;
            if (!err && body && body.status) err = true;
            if (!err && body && body.errors && Object.keys(body.errors).length) err = true;
            if (err) {
              let msg = errMsg;
              if (body && body.message) msg = String(body.message);
              else if (typeof body.description === 'string') msg = body.description;
              else if (body && body.errors && Object.keys(body.errors).length) {
                try {
                  msg = Object.values(body.errors).flat().join(' ');
                } catch (ignore) {
                  msg = JSON.stringify(body.errors);
                }
              }
              if (!plpCartModal) {
                alert(msg);
                return Promise.reject();
              }
              if (plpCartError) {
                plpCartError.textContent = msg;
                plpCartError.removeAttribute('hidden');
              }
              setPlpCartModalErrorMode(true);
              openPlpCartModal();
              return Promise.reject('aura-plp-cart-handled');
            }
            return fetch(cartJsonUrl || '/cart.js', { headers: { Accept: 'application/json' } })
              .then((r) => r.json())
              .catch(() => null);
          })
          .then((cart) => {
            populatePlpCartModalSuccess(card, cart, qty, vid, addBodyCache);
            let resourceCart = cart;
            if (!resourceCart) {
              resourceCart = { item_count: qty, total_price: null };
              const ln = normalizeAddLine(addBodyCache);
              if (ln && typeof ln.final_line_price === 'number') {
                resourceCart.total_price = ln.final_line_price;
              } else if (card) {
                const up = parseInt(card.getAttribute('data-variant-price-cents'), 10) || 0;
                resourceCart.total_price = up * qty;
              }
            }
            document.dispatchEvent(
              new CustomEvent('cart:update', {
                bubbles: true,
                detail: {
                  resource: resourceCart,
                  data: {
                    itemCount: qty,
                    source: 'product-form-component',
                  },
                },
              })
            );
            openPlpCartModal();
          })
          .catch((reason) => {
            if (reason === 'aura-plp-cart-handled') return;
            if (!plpCartModal) {
              alert(errMsg);
              return;
            }
            if (plpCartError) {
              plpCartError.textContent = errMsg;
              plpCartError.removeAttribute('hidden');
            }
            setPlpCartModalErrorMode(true);
            openPlpCartModal();
          })
          .finally(() => {
            btn.classList.remove('is-loading');
            btn.removeAttribute('aria-busy');
          });
      });
    });
  })();
{% endjavascript %}

