{% comment %}
  Aura Society — collection grid + native Shopify filters. Scoped under .aura-collection-page; use with template collection.aura.
{% endcomment %}

{% liquid
  assign sort_by = collection.sort_by | default: collection.default_sort_by
  assign price_id = 'aura-price-' | append: section.id

  assign plp_cart_modal_pts_mult = section.settings.cart_modal_points_multiplier | default: 0
  if plp_cart_modal_pts_mult == 0
    assign plp_cart_modal_pts_mult = section.settings.plp_points_multiplier | default: 1
  endif
  assign plp_cart_modal_lbl = section.settings.cart_modal_reward_label | strip
  if plp_cart_modal_lbl == blank
    assign plp_cart_modal_lbl = section.settings.plp_points_label | default: 'Glow Points'
  endif
  assign plp_reward_goal_raw = section.settings.cart_modal_reward_spend_goal | default: 100
  assign plp_reward_goal_cents = plp_reward_goal_raw | times: 100
  assign plp_cart_modal_pts_cap = section.settings.cart_modal_points_cap | default: 100
  assign plp_type_summary = 'sections.aura_collection_grid.filter_type' | t
%}

<section
  class="aura-collection-page aura-collection-plp"
  data-aura-plp
  data-section-id="{{ section.id }}"
  data-cart-add-url="{{ routes.cart_add_url | append: '.js' | escape }}"
  data-cart-json-url="{{ routes.cart_url | append: '.js' | escape }}"
  data-money-format="{{ shop.money_format | escape }}"
  data-currency-symbol="{{ cart.currency.symbol | escape }}"
  data-cart-url="{{ routes.cart_url | escape }}"
  data-checkout-url="{{ shop.url }}/checkout"
  data-cart-modal-subtotal-one="{{ 'sections.aura_product_main.cart_modal_subtotal_one' | t | escape }}"
  data-cart-modal-subtotal-other="{{ 'sections.aura_product_main.cart_modal_subtotal_other' | t | escape }}"
  data-cart-modal-line-qty-template="{{ 'sections.aura_product_main.cart_modal_line_in_cart' | t | escape }}"
  data-add-error="{{ 'sections.aura_product_main.added_error' | t | escape }}"
  data-cart-modal-show-rewards="{% if section.settings.cart_modal_show_rewards == false %}false{% else %}true{% endif %}"
  data-reward-spend-goal-cents="{{ plp_reward_goal_cents }}"
  data-reward-points-max="{{ plp_cart_modal_pts_cap }}"
  data-cart-modal-points-mult="{{ plp_cart_modal_pts_mult }}"
  data-reward-label="{{ plp_cart_modal_lbl | escape }}"
  data-reward-message-template="{{ section.settings.cart_modal_reward_message | escape }}"
  data-reward-message-fallback="{{ 'sections.aura_product_main.cart_modal_reward_away' | t | escape }}"
  data-reward-complete-msg="{{ 'sections.aura_product_main.cart_modal_reward_complete' | t | escape }}"
  data-i18n-wishlist-add="{{ 'sections.aura_collection_grid.wishlist_add' | t | escape }}"
  data-i18n-wishlist-remove="{{ 'sections.aura_collection_grid.wishlist_remove' | t | escape }}"
  style="
    --acg-max: 1440px;
    --acg-gap: {{ section.settings.grid_gap }}px;
    --acg-cols-d: {{ section.settings.columns_desktop }};
    --acg-card-radius: {{ section.settings.card_radius }}px;
    --acg-heading: {{ section.settings.heading_navy }};
    --acg-text: {{ section.settings.text_color }};
    --acg-accent: {{ section.settings.accent_pink }};
    --acg-card-surface: {{ section.settings.card_surface }};
    --acg-border: {{ section.settings.border_soft }};
    --acg-navy: {{ section.settings.button_navy }};
    --acg-star: {{ section.settings.star_color }};
    --acg-g-start: {{ section.settings.button_gradient_start }};
    --acg-g-end: {{ section.settings.button_gradient_end }};
    --acg-pad-top: {{ section.settings.padding_top }}px;
    --acg-pad-bottom: {{ section.settings.padding_bottom }}px;
    --acg-modal-button-radius: {{ section.settings.modal_button_radius }}px;
    --acg-plp-cart-modal-reward-bg: #fff6f9;
    --acg-plp-cart-modal-reward-border: rgba(236, 0, 140, 0.22);
    --acg-plp-cart-modal-progress-track: #fde8f0;
    --acg-plp-cart-modal-progress-bar: linear-gradient(90deg, {{ section.settings.button_gradient_start }} 0%, {{ section.settings.button_gradient_end }} 100%);
  "
>
  <div class="aura-plp-max">
    <div class="aura-plp-bar">
      <button
        type="button"
        class="aura-plp-filters-open"
        data-aura-plp-open-filters
        aria-expanded="false"
        aria-controls="AuraPlpSidebar-{{ section.id }}"
      >
        {{ 'sections.aura_collection_grid.filters_open' | t }}
      </button>
    </div>

    <div class="aura-plp-overlay" data-aura-plp-overlay hidden></div>

    <div class="aura-plp-layout">
      <aside
        class="aura-plp-sidebar"
        id="AuraPlpSidebar-{{ section.id }}"
        data-aura-plp-sidebar
      >
        <div class="aura-plp-sidebar__card">
          <div class="aura-plp-sidebar__head">
            <span class="aura-plp-sidebar__title">{{ 'sections.aura_collection_grid.filters_title' | t }}</span>
            <button
              type="button"
              class="aura-plp-sidebar__close"
              data-aura-plp-close-filters
              aria-label="{{ 'sections.aura_collection_grid.filters_close' | t }}"
            >
              ×
            </button>
          </div>

          <form
            method="get"
            action="{{ collection.url }}"
            id="AuraPlpFacets-{{ section.id }}"
            class="aura-plp-facet-form"
            data-aura-plp-facet-form
          >
            {%- for filter in collection.filters -%}
              {%- assign plp_fparam = filter.param_name | downcase -%}
              {%- if plp_fparam contains 'product_type' -%}
                {% render 'aura-plp-filter-group', filter: filter, section: section, price_id: price_id, summary_label: plp_type_summary %}
              {%- endif -%}
            {%- endfor -%}
            {%- for filter in collection.filters -%}
              {%- assign plp_fparam = filter.param_name | downcase -%}
              {%- unless plp_fparam contains 'product_type' -%}
                {% render 'aura-plp-filter-group', filter: filter, section: section, price_id: price_id %}
              {%- endunless -%}
            {%- endfor -%}
          </form>

          <a href="{{ collection.url }}" class="aura-plp-clear">{{ 'sections.aura_collection_grid.clear_all' | t }}</a>
        </div>
      </aside>

      <div class="aura-plp-main">
        {% paginate collection.products by section.settings.products_per_page %}
          <div class="aura-plp-toolbar">
            <p class="aura-plp-count" role="status">
              {{ 'sections.aura_collection_grid.product_count' | t: count: collection.products_count }}
            </p>
            <div class="aura-plp-toolbar__right">
              <div class="aura-plp-sort">
                <label class="aura-plp-sort__lbl" for="AuraPlpSort-{{ section.id }}">{{ 'sections.aura_collection_grid.sort_label' | t }}</label>
                <select
                  id="AuraPlpSort-{{ section.id }}"
                  class="aura-plp-sort__select"
                  name="sort_by"
                  form="AuraPlpFacets-{{ section.id }}"
                  data-aura-plp-sort
                >
                  {% for option in collection.sort_options %}
                    <option
                      value="{{ option.value }}"
                      {% if option.value == sort_by %}
                        selected
                      {% endif %}
                    >
                      {{ option.name | escape }}
                    </option>
                  {% endfor %}
                </select>
              </div>
              <div class="aura-plp-view" role="group">
                <button
                  type="button"
                  class="aura-plp-view__btn is-active"
                  data-aura-plp-view="grid"
                  aria-pressed="true"
                  aria-label="{{ 'sections.aura_collection_grid.view_grid_aria' | t }}"
                >
                  <span class="aura-plp-view__ic" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linejoin="round">
                      <rect x="3" y="3" width="7.5" height="7.5" rx="1.2"></rect>
                      <rect x="13.5" y="3" width="7.5" height="7.5" rx="1.2"></rect>
                      <rect x="3" y="13.5" width="7.5" height="7.5" rx="1.2"></rect>
                      <rect x="13.5" y="13.5" width="7.5" height="7.5" rx="1.2"></rect>
                    </svg>
                  </span>
                </button>
                <button
                  type="button"
                  class="aura-plp-view__btn"
                  data-aura-plp-view="list"
                  aria-pressed="false"
                  aria-label="{{ 'sections.aura_collection_grid.view_list_aria' | t }}"
                >
                  <span class="aura-plp-view__ic" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round">
                      <path d="M4.5 7.5h15"></path>
                      <path d="M4.5 12h15"></path>
                      <path d="M4.5 16.5h15"></path>
                    </svg>
                  </span>
                </button>
              </div>
            </div>
          </div>

          {% if collection.products.size == 0 %}
            <p class="aura-plp-empty">{{ 'sections.aura_collection_grid.empty' | t }}</p>
          {% else %}
            <div class="aura-plp-grid" data-aura-plp-grid>
              {% for product in collection.products %}
                <div class="aura-plp-grid__cell">
                  {% render 'aura-product-card', product: product, section: section %}
                </div>
              {% endfor %}
            </div>
          {% endif %}

          {% if paginate.pages > 1 %}
            <nav class="aura-plp-pagination" aria-label="{{ 'sections.aura_collection_grid.pagination' | t }}">
              {{ paginate | default_pagination }}
            </nav>
          {% endif %}
        {% endpaginate %}
      </div>
    </div>
  </div>

  <div
    class="aura-plp-cart-modal"
    data-aura-plp-cart-modal
    role="dialog"
    aria-modal="true"
    aria-labelledby="aura-plp-cart-modal-title-{{ section.id }}"
    aria-hidden="true"
    hidden
  >
    <div class="aura-plp-cart-modal__backdrop" data-aura-plp-cart-modal-dismiss tabindex="-1"></div>
    <div class="aura-plp-cart-modal__panel" data-aura-plp-cart-modal-panel>
      <button
        type="button"
        class="aura-plp-cart-modal__close"
        data-aura-plp-cart-modal-dismiss
        aria-label="{{ 'sections.aura_product_main.added_close' | t }}"
      >
        ×
      </button>
      <div class="aura-plp-cart-modal__heading-row">
        <span class="aura-plp-cart-modal__check" aria-hidden="true">
          {% render 'aura-icon', icon: 'check', class: 'aura-plp-cart-modal__check-glyph' %}
        </span>
        <h2 id="aura-plp-cart-modal-title-{{ section.id }}" class="aura-plp-cart-modal__title">
          {{ 'sections.aura_product_main.cart_modal_title' | t }}
        </h2>
      </div>

      <div class="aura-plp-cart-modal__body" data-aura-plp-cart-modal-body>
        <div class="aura-plp-cart-modal__product-row">
          <div class="aura-plp-cart-modal__thumb-wrap">
            <img
              class="aura-plp-cart-modal__thumb"
              data-aura-plp-cart-modal-img
              src=""
              alt=""
              width="88"
              height="88"
              loading="lazy"
            >
          </div>
          <div class="aura-plp-cart-modal__product-info">
            <p class="aura-plp-cart-modal__product-title" data-aura-plp-cart-modal-product-title></p>
            <p class="aura-plp-cart-modal__variant" data-aura-plp-cart-modal-variant hidden></p>
            <p class="aura-plp-cart-modal__line-qty" data-aura-plp-cart-modal-line-qty hidden></p>
          </div>
          <div class="aura-plp-cart-modal__line-price-wrap">
            <s class="aura-plp-cart-modal__line-compare" data-aura-plp-cart-modal-line-compare hidden></s>
            <span class="aura-plp-cart-modal__line-price" data-aura-plp-cart-modal-line-price></span>
          </div>
        </div>

        <div class="aura-plp-cart-modal__divider" aria-hidden="true"></div>

        <div class="aura-plp-cart-modal__subtotal-row">
          <span class="aura-plp-cart-modal__subtotal-label" data-aura-plp-cart-modal-subtotal-label></span>
          <span class="aura-plp-cart-modal__subtotal-amount" data-aura-plp-cart-modal-subtotal-amount></span>
        </div>

        {% if section.settings.cart_modal_show_rewards %}
          <div class="aura-plp-cart-modal__rewards" data-aura-plp-cart-modal-rewards>
            <div class="aura-plp-cart-modal__progress-row">
              <span class="aura-plp-cart-modal__progress-icon aura-plp-cart-modal__progress-icon--leading" aria-hidden="true">
                {% render 'aura-icon', icon: 'sparkle', class: 'aura-plp-cart-modal__progress-icon-inner' %}
              </span>
              <p class="aura-plp-cart-modal__reward-msg" data-aura-plp-cart-modal-reward-msg></p>
              <span class="aura-plp-cart-modal__reward-points" data-aura-plp-cart-modal-reward-points></span>
              <span class="aura-plp-cart-modal__progress-icon aura-plp-cart-modal__progress-icon--trailing" aria-hidden="true">
                {% render 'aura-icon', icon: 'gift', class: 'aura-plp-cart-modal__progress-icon-inner' %}
              </span>
            </div>
            <div class="aura-plp-cart-modal__progress" aria-hidden="true">
              <div class="aura-plp-cart-modal__progress-track">
                <div class="aura-plp-cart-modal__progress-fill" data-aura-plp-cart-modal-progress-fill></div>
              </div>
            </div>
          </div>
        {% endif %}
      </div>

      <p class="aura-plp-cart-modal__error" data-aura-plp-cart-modal-error hidden></p>

      <div class="aura-plp-cart-modal__actions">
        <a
          class="aura-plp-cart-modal__btn aura-plp-cart-modal__btn--outline"
          data-aura-plp-cart-modal-cart-link
          href="{{ routes.cart_url }}"
        >
          {{ 'sections.aura_product_main.view_cart' | t }}
        </a>
        <button
          type="button"
          class="aura-plp-cart-modal__btn aura-plp-cart-modal__btn--outline"
          data-aura-plp-cart-modal-continue
        >
          {{ 'sections.aura_product_main.continue_shopping' | t }}
        </button>
        <a
          class="aura-plp-cart-modal__btn aura-plp-cart-modal__btn--checkout"
          data-aura-plp-cart-modal-checkout
          href="{{ shop.url }}/checkout"
        >
          {{ 'sections.aura_product_main.checkout' | t }}
        </a>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .aura-collection-page.aura-collection-plp {
    padding: var(--acg-pad-top, 16px) 0 var(--acg-pad-bottom, 64px);
  }

  .aura-collection-page .aura-plp-max {
    max-width: var(--acg-max, 1440px);
    margin: 0 auto;
    padding: 0 1.25rem;
    box-sizing: border-box;
  }

  @media (min-width: 750px) {
    .aura-collection-page .aura-plp-max {
      padding: 0 2rem;
    }
  }

  .aura-collection-page .aura-plp-bar {
    display: flex;
    justify-content: flex-start;
    margin-bottom: 1rem;
  }

  @media (min-width: 990px) {
    .aura-collection-page .aura-plp-bar {
      display: none;
    }
  }

  .aura-collection-page .aura-plp-filters-open {
    appearance: none;
    border-radius: 999px;
    padding: 0.55rem 1.15rem;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    border: 1px solid color-mix(in srgb, var(--acg-accent, #ec008c) 50%, var(--acg-border, #f0dfe8));
    color: var(--acg-heading, #1b2c58);
    background: #fff;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .aura-collection-page .aura-plp-filters-open:hover {
    background: #fff8fc;
    border-color: color-mix(in srgb, var(--acg-accent, #ec008c) 65%, transparent);
  }

  .aura-collection-page .aura-plp-overlay {
    position: fixed;
    inset: 0;
    z-index: 35;
    background: rgba(27, 44, 88, 0.22);
    border: none;
    padding: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .aura-collection-page .aura-plp-overlay.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  .aura-collection-page .aura-plp-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--acg-gap, 24px);
    align-items: start;
  }

  @media (min-width: 990px) {
    .aura-collection-page .aura-plp-layout {
      grid-template-columns: minmax(240px, 280px) minmax(0, 1fr);
      gap: 32px;
    }
  }

  .aura-collection-page .aura-plp-sidebar {
    position: fixed;
    z-index: 40;
    top: 0;
    left: 0;
    bottom: 0;
    width: min(92vw, 360px);
    max-width: 100%;
    background: #fff;
    transform: translateX(-108%);
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    overflow: auto;
    box-shadow: 8px 0 40px rgba(27, 44, 88, 0.12);
  }

  .aura-collection-page .aura-plp-sidebar.is-open {
    transform: translateX(0);
  }

  @media (min-width: 990px) {
    .aura-collection-page .aura-plp-sidebar {
      position: sticky;
      top: 1.25rem;
      width: auto;
      max-width: none;
      transform: none;
      box-shadow: none;
      background: transparent;
      overflow: visible;
    }

    .aura-collection-page .aura-plp-sidebar.is-open {
      transform: none;
    }
  }

  .aura-collection-page .aura-plp-sidebar__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 0.75rem;
    margin-bottom: 0.5rem;
    border-bottom: 1px solid var(--acg-border, #f0dfe8);
  }

  @media (min-width: 990px) {
    .aura-collection-page .aura-plp-sidebar__head {
      border-bottom: none;
      padding-bottom: 0;
      margin-bottom: 0;
    }

    .aura-collection-page .aura-plp-sidebar__close {
      display: none;
    }
  }

  .aura-collection-page .aura-plp-sidebar__title {
    font-weight: 700;
    color: var(--acg-heading, #1b2c58);
    font-size: 1rem;
  }

  .aura-collection-page .aura-plp-sidebar__close {
    border: none;
    background: transparent;
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    color: var(--acg-heading, #1b2c58);
    padding: 0.25rem;
  }

  .aura-collection-page .aura-plp-sidebar__card {
    padding: 1.25rem;
    min-height: 100%;
    box-sizing: border-box;
  }

  @media (min-width: 990px) {
    .aura-collection-page .aura-plp-sidebar__card {
      border: 1px solid var(--acg-border, #f0dfe8);
      border-radius: 16px;
      background: #fff;
      padding: 1.25rem 1.35rem 1.5rem;
    }
  }

  .aura-collection-page .aura-plp-accordion {
    border-bottom: 1px solid color-mix(in srgb, var(--acg-border, #f0dfe8) 85%, #fff);
    padding: 0.35rem 0;
  }

  .aura-collection-page .aura-plp-accordion__summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.5rem 0;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--acg-heading, #1b2c58);
  }

  .aura-collection-page .aura-plp-accordion__summary::-webkit-details-marker {
    display: none;
  }

  .aura-collection-page .aura-plp-accordion__caret {
    width: 0.45rem;
    height: 0.45rem;
    border-right: 2px solid var(--acg-heading, #1b2c58);
    border-bottom: 2px solid var(--acg-heading, #1b2c58);
    transform: rotate(45deg);
    translate: 0 -0.1rem;
    transition: transform 0.25s ease;
    flex-shrink: 0;
    opacity: 0.55;
  }

  .aura-collection-page .aura-plp-accordion[open] .aura-plp-accordion__caret {
    transform: rotate(225deg);
  }

  .aura-collection-page .aura-plp-accordion__body {
    padding: 0.25rem 0 0.75rem;
  }

  .aura-collection-page .aura-plp-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .aura-collection-page .aura-plp-checkbox {
    position: absolute;
    opacity: 0;
    width: 1px;
    height: 1px;
    pointer-events: none;
  }

  .aura-collection-page .aura-plp-checkbox-lbl {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 0.88rem;
    color: var(--acg-text, #3d4657);
    cursor: pointer;
    padding: 0.35rem 0 0.35rem 1.85rem;
    position: relative;
    line-height: 1.35;
    transition: color 0.2s ease;
  }

  .aura-collection-page .aura-plp-checkbox-lbl::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    translate: 0 -50%;
    width: 1.1rem;
    height: 1.1rem;
    border-radius: 4px;
    border: 1.5px solid color-mix(in srgb, var(--acg-accent, #ec008c) 45%, var(--acg-border, #f0dfe8));
    background: #fff;
    transition:
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .aura-collection-page .aura-plp-checkbox:checked + .aura-plp-checkbox-lbl {
    color: color-mix(in srgb, var(--acg-accent, #ec008c) 30%, var(--acg-heading, #1b2c58));
    font-weight: 600;
  }

  .aura-collection-page .aura-plp-checkbox:checked + .aura-plp-checkbox-lbl::before {
    background: color-mix(in srgb, var(--acg-accent, #ec008c) 16%, #fff);
    border-color: var(--acg-accent, #ec008c);
  }

  .aura-collection-page .aura-plp-checkbox:checked + .aura-plp-checkbox-lbl::after {
    content: '';
    position: absolute;
    left: 0.28rem;
    top: 50%;
    width: 0.32rem;
    height: 0.55rem;
    border: solid var(--acg-accent, #ec008c);
    border-width: 0 2px 2px 0;
    transform: translateY(-65%) rotate(45deg);
  }

  .aura-collection-page .aura-plp-list__item--disabled .aura-plp-checkbox-lbl {
    opacity: 0.38;
    cursor: not-allowed;
  }

  .aura-collection-page .aura-plp-checkbox-count {
    font-size: 0.78rem;
    opacity: 0.65;
  }

  .aura-collection-page .aura-plp-price {
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.65rem;
  }

  .aura-collection-page .aura-plp-price__field {
    flex: 1;
    min-width: 5rem;
  }

