    font-size: 0.875rem;
    line-height: 1.45;
    color: color-mix(in srgb, var(--acp-navy) 82%, #fff);
  }
  .aura-customer-portal__promo-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.55rem 1rem;
    border-radius: 999px;
    background: #fff;
    color: var(--acp-navy);
    font-weight: 600;
    font-size: 0.85rem;
