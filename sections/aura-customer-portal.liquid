    color: color-mix(in srgb, var(--acp-navy) 70%, #fff);
  }
  .aura-customer-portal__benefit-grid {
    display: grid;
    gap: 0.85rem;
  }
  @media screen and (min-width: 750px) {
    .aura-customer-portal__benefit-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .aura-customer-portal__benefit {
    background: #fff;
    border: 1px solid color-mix(in srgb, var(--acp-navy) 12%, transparent);
    border-radius: var(--acp-radius);
    padding: 1rem;
  }
  .aura-customer-portal__benefit-ic {
    display: flex;
    color: var(--acp-pink);
    margin-bottom: 0.5rem;
  }
  .aura-customer-portal__benefit-title {
    margin: 0 0 0.35rem;
    font-size: 1rem;
    font-weight: 600;
  }
  .aura-customer-portal__benefit-text {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.45;
    color: color-mix(in srgb, var(--acp-navy) 78%, #fff);
  }
  .aura-customer-portal__refer {
    display: grid;
    gap: 1.25rem;
  }
  @media screen and (min-width: 750px) {
    .aura-customer-portal__refer {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
      align-items: start;
    }
  }
  .aura-customer-portal__refer-media {
    border-radius: var(--acp-radius);
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--acp-navy) 10%, transparent);
  }
  .aura-customer-portal__refer-img {
    width: 100%;
    display: block;
    height: auto;
  }
  .aura-customer-portal__refer-reward {
    margin: 0 0 1rem;
    font-family: var(--acp-heading-font);
    font-size: 1.15rem;
    font-weight: 600;
  }
  .aura-customer-portal__field {
    margin-bottom: 0.85rem;
  }
  .aura-customer-portal__field-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.35rem;
    color: color-mix(in srgb, var(--acp-navy) 60%, #fff);
  }
  .aura-customer-portal__input {
    width: 100%;
    max-width: 100%;
    padding: 0.6rem 0.75rem;
    border-radius: calc(var(--acp-radius) - 4px);
    border: 1px solid color-mix(in srgb, var(--acp-navy) 18%, transparent);
    font: inherit;
    background: #fff;
  }
  .aura-customer-portal__copied {
    margin: 0.5rem 0 0;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--acp-pink);
  }
  .aura-customer-portal__signout-card {
    background: #fff;
    border-radius: var(--acp-radius);
    border: 1px solid color-mix(in srgb, var(--acp-navy) 12%, transparent);
    padding: 1.25rem;
    max-width: 420px;
  }
  .aura-customer-portal__signout-card p {
    margin: 0 0 1rem;
    line-height: 1.45;
  }
  .aura-customer-portal__icon-fallback {
    opacity: 0.5;
  }
  .aura-customer-portal__rte {
    margin-top: 1rem;
    font-size: 0.9rem;
    line-height: 1.45;
    color: color-mix(in srgb, var(--acp-navy) 78%, #fff);
  }
  .aura-customer-portal--guest {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.25rem;
    color: #0a142f;
  }
  .aura-customer-portal--guest .link {
    color: #ec008c;
    font-weight: 600;
  }
{% endstylesheet %}

