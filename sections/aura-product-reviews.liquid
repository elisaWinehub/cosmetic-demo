{% assign rv_class = 'aura-product-reviews-' | append: section.id %}

<section
  class="aura-product-reviews full-width {{ rv_class }}"
  style="
    --apr-background: {{ section.settings.background_color }};
    --apr-heading: {{ section.settings.heading_color }};
    --apr-text: {{ section.settings.text_color }};
    --apr-score: {{ section.settings.score_color }};
    --apr-star: {{ section.settings.star_color }};
    --apr-bar-track: {{ section.settings.bar_track_color }};
    --apr-bar-fill: {{ section.settings.bar_fill_color }};
    --apr-card-bg: {{ section.settings.card_background }};
    --apr-card-border: {{ section.settings.card_border_color }};
    --apr-button-border: {{ section.settings.button_border_color }};
    --apr-button-text: {{ section.settings.button_text_color }};
    --apr-padding-t: {{ section.settings.padding_top }}px;
    --apr-padding-b: {{ section.settings.padding_bottom }}px;
    --apr-title-size: {{ section.settings.heading_size }}px;
    --apr-body-size: {{ section.settings.body_size }}px;
    --apr-score-size: {{ section.settings.score_size }}px;
  "
>
  <div class="aura-product-reviews__inner">
    {% if section.settings.heading != blank %}
      <h2 class="aura-product-reviews__title">{{ section.settings.heading | escape }}</h2>
    {% endif %}

    <div class="aura-product-reviews__grid">
      <div class="aura-product-reviews__summary">
        <div class="aura-product-reviews__score">{{ section.settings.score | escape }}</div>
        <div class="aura-product-reviews__stars" aria-hidden="true">
          {% assign fs = section.settings.score | plus: 0 | floor %}
          {% for i in (1..5) %}
            <span class="{% if i <= fs %}aura-product-reviews__star--full{% else %}aura-product-reviews__star--muted{% endif %}">★</span>
          {% endfor %}
        </div>
        {% if section.settings.based_on != blank %}
          <p class="aura-product-reviews__based">{{ section.settings.based_on | escape }}</p>
        {% endif %}

        <div class="aura-product-reviews__bars">
          <div class="aura-product-reviews__bar-row">
            <span>5 ★</span>
            <div class="aura-product-reviews__bar"><span style="width: {{ section.settings.bar_5 }}%;"></span></div>
            <span>{{ section.settings.bar_5 }}%</span>
          </div>
          <div class="aura-product-reviews__bar-row">
            <span>4 ★</span>
            <div class="aura-product-reviews__bar"><span style="width: {{ section.settings.bar_4 }}%;"></span></div>
            <span>{{ section.settings.bar_4 }}%</span>
          </div>
          <div class="aura-product-reviews__bar-row">
            <span>3 ★</span>
            <div class="aura-product-reviews__bar"><span style="width: {{ section.settings.bar_3 }}%;"></span></div>
            <span>{{ section.settings.bar_3 }}%</span>
          </div>
          <div class="aura-product-reviews__bar-row">
            <span>2 ★</span>
            <div class="aura-product-reviews__bar"><span style="width: {{ section.settings.bar_2 }}%;"></span></div>
            <span>{{ section.settings.bar_2 }}%</span>
          </div>
          <div class="aura-product-reviews__bar-row">
            <span>1 ★</span>
            <div class="aura-product-reviews__bar"><span style="width: {{ section.settings.bar_1 }}%;"></span></div>
            <span>{{ section.settings.bar_1 }}%</span>
          </div>
        </div>

        {% if section.settings.button_label != blank %}
          <a class="aura-product-reviews__button" href="{{ section.settings.button_link | default: '#' }}">
            {{ section.settings.button_label | escape }}
          </a>
        {% endif %}
      </div>

      <div class="aura-product-reviews__cards{% if section.settings.mobile_scroll %} aura-product-reviews__cards--scroll{% endif %}">
        {% for block in section.blocks %}
          {% if block.type == 'review' %}
            {% liquid
              assign br = block.settings.rating | plus: 0 | floor
            %}
            <article class="aura-product-reviews__card" {{ block.shopify_attributes }}>
              <div class="aura-product-reviews__card-stars" aria-hidden="true">
                {% for i in (1..5) %}
                  <span class="{% if i <= br %}aura-product-reviews__star--full{% else %}aura-product-reviews__star--muted{% endif %}">★</span>
                {% endfor %}
              </div>
              {% if block.settings.text != blank %}
                <p class="aura-product-reviews__card-text">{{ block.settings.text | escape }}</p>
              {% endif %}
              {% if block.settings.author != blank %}
                <small class="aura-product-reviews__card-author">— {{ block.settings.author | escape }}</small>
              {% endif %}
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .{{ rv_class }} {
    background: var(--apr-background);
    border-bottom: 1px solid #eee1dc;
  }

  .{{ rv_class }} .aura-product-reviews__inner {
    width: min(1240px, calc(100% - 48px));
    margin: 0 auto;
    padding-top: var(--apr-padding-t);
    padding-bottom: var(--apr-padding-b);
  }

  .{{ rv_class }} .aura-product-reviews__title {
    font-family: var(--font-heading--family, Georgia, serif);
    font-size: var(--apr-title-size);
    font-weight: 500;
    color: var(--apr-heading);
    margin: 0 0 1.75rem;
    letter-spacing: -0.02em;
  }

  .{{ rv_class }} .aura-product-reviews__grid {
    display: grid;
    grid-template-columns: 330px 1fr;
    gap: clamp(1.75rem, 4vw, 3.25rem);
    align-items: start;
  }

  .{{ rv_class }} .aura-product-reviews__score {
    font-size: var(--apr-score-size);
    font-weight: 900;
    color: var(--apr-score);
    margin: 0.5rem 0 0.15rem;
    line-height: 1;
  }

  .{{ rv_class }} .aura-product-reviews__stars {
    color: var(--apr-star);
    letter-spacing: 0.05em;
    font-size: 1rem;
    margin-bottom: 0.35rem;
  }

  .{{ rv_class }} .aura-product-reviews__star--muted {
    opacity: 0.28;
  }

  .{{ rv_class }} .aura-product-reviews__based {
    margin: 0 0 1rem;
    color: #596173;
    font-size: var(--apr-body-size);
  }

  .{{ rv_class }} .aura-product-reviews__bars {
    display: grid;
    gap: 0.65rem;
    margin-top: 0.25rem;
  }

  .{{ rv_class }} .aura-product-reviews__bar-row {
    display: grid;
    grid-template-columns: 40px 1fr 44px;
    gap: 0.65rem;
    align-items: center;
    font-size: 0.8125rem;
    color: #596173;
    font-weight: 700;
  }

  .{{ rv_class }} .aura-product-reviews__bar {
    height: 8px;
    border-radius: 99px;
    background: var(--apr-bar-track);
    overflow: hidden;
  }

  .{{ rv_class }} .aura-product-reviews__bar span {
    display: block;
    height: 100%;
    border-radius: 99px;
    background: var(--apr-bar-fill);
  }

  .{{ rv_class }} .aura-product-reviews__button {
    display: inline-block;
    margin-top: 1.35rem;
    padding: 0.65rem 1.75rem;
    border-radius: 8px;
    border: 1px solid var(--apr-button-border);
    color: var(--apr-button-text);
    text-decoration: none;
    font-weight: 800;
    font-size: 0.875rem;
  }

  .{{ rv_class }} .aura-product-reviews__button:hover {
    background: rgba(27, 44, 88, 0.04);
  }

  .{{ rv_class }} .aura-product-reviews__cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.35rem;
  }

  .{{ rv_class }} .aura-product-reviews__cards--scroll {
    overflow-x: auto;
    grid-auto-flow: column;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    grid-auto-columns: minmax(240px, 1fr);
    padding-bottom: 0.35rem;
    scroll-snap-type: x mandatory;
  }

  .{{ rv_class }} .aura-product-reviews__cards--scroll .aura-product-reviews__card {
    scroll-snap-align: start;
  }

  .{{ rv_class }} .aura-product-reviews__card {
    border: 1px solid var(--apr-card-border);
    border-radius: 14px;
    background: var(--apr-card-bg);
    padding: 1.5rem;
    box-shadow: 0 12px 34px rgba(55, 31, 43, 0.04);
  }

  .{{ rv_class }} .aura-product-reviews__card-stars {
    color: var(--apr-star);
    letter-spacing: 0.05em;
    margin-bottom: 0.65rem;
    font-size: 0.95rem;
  }

  .{{ rv_class }} .aura-product-reviews__card-text {
    margin: 0 0 0.85rem;
    color: #4d5667;
    font-size: 0.875rem;
    font-weight: 700;
    line-height: 1.5;
  }

  .{{ rv_class }} .aura-product-reviews__card-author {
    color: #6b7280;
    font-size: 0.8125rem;
    font-weight: 600;
  }

  @media (max-width: 980px) {
    .{{ rv_class }} .aura-product-reviews__grid {
      grid-template-columns: 1fr;
    }

    .{{ rv_class }} .aura-product-reviews__cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .{{ rv_class }} .aura-product-reviews__inner {
      width: min(100% - 28px, 1240px);
    }

    .{{ rv_class }} .aura-product-reviews__cards {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Aura product reviews",
  "tag": "section",
  "class": "aura-product-reviews-section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1B2C58"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Summary text color",
      "default": "#596173"
    },
    {
      "type": "color",
      "id": "score_color",
      "label": "Score color",
      "default": "#9f3b2e"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#EC008C"
    },
    {
      "type": "color",
      "id": "bar_track_color",
      "label": "Bar track color",
      "default": "#f8e6ef"
    },
    {
      "type": "color",
      "id": "bar_fill_color",
      "label": "Bar fill color",
      "default": "#d12c9b"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border",
      "default": "#eeded8"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Button border",
      "default": "#dac8c3"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#252b36"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real results. Real glow."
    },
    {
      "type": "text",
      "id": "score",
      "label": "Score",
      "default": "4.8"
    },
    {
      "type": "text",
      "id": "based_on",
      "label": "Based on text",
      "default": "Based on 124 reviews"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Write a review"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "bar_5",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "5 star bar %",
      "default": 86
    },
    {
      "type": "range",
      "id": "bar_4",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "4 star bar %",
      "default": 10
    },
    {
      "type": "range",
      "id": "bar_3",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "3 star bar %",
      "default": 3
    },
    {
      "type": "range",
      "id": "bar_2",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "2 star bar %",
      "default": 1
    },
    {
      "type": "range",
      "id": "bar_1",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "1 star bar %",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "mobile_scroll",
      "label": "Horizontal scroll cards on mobile",
      "default": false
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 34
    },
    {
      "type": "range",
      "id": "score_size",
      "min": 24,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Score size",
      "default": 34
    },
    {
      "type": "range",
      "id": "body_size",
      "min": 13,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Body size",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 44
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 44
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Star rating",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text",
          "default": "My skin looks brighter and more even after just a week."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Olivia P."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aura product reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "text": "My skin looks brighter and more even after just a week. Love the lightweight feel!",
            "author": "Olivia P."
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "text": "So hydrating and gentle. It layers perfectly under my moisturizer.",
            "author": "Jenna R."
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 4,
            "text": "I've tried so many serums and this is definitely one of my favorites.",
            "author": "Mia T."
          }
        }
      ]
    }
  ]
}
{% endschema %}
