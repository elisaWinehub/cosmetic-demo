{% assign works_class = 'aura-how-it-works-' | append: section.id %}

<section
  class="aura-how-it-works full-width {{ works_class }}{% if section.settings.mobile_stacked %} aura-how-it-works--mobile-stacked{% endif %}{% if section.settings.show_connector_line %} aura-how-it-works--with-line{% endif %}"
  style="
    --aura-how-it-works-background: {{ section.settings.background_color }};
    --aura-how-it-works-icon-background: {{ section.settings.icon_background }};
    --aura-how-it-works-icon-color: {{ section.settings.icon_color }};
    --aura-how-it-works-line-color: {{ section.settings.line_color }};
    --aura-how-it-works-heading-size: {{ section.settings.heading_size }}px;
    --aura-how-it-works-body-size: {{ section.settings.body_size }}px;
    --aura-how-it-works-padding-top: {{ section.settings.padding_top }}px;
    --aura-how-it-works-padding-bottom: {{ section.settings.padding_bottom }}px;
    --aura-how-it-works-gap: {{ section.settings.step_gap }}px;
  "
>
  <div class="aura-how-it-works__inner">
    {% if section.settings.heading != blank %}
      <div class="aura-how-it-works__header">
        <h2 class="aura-how-it-works__heading">{{ section.settings.heading | escape }}</h2>
      </div>
    {% endif %}

    <div class="aura-how-it-works__grid">
      {% for block in section.blocks %}
        <article class="aura-how-it-works__step" {{ block.shopify_attributes }}>
          <div class="aura-how-it-works__icon-wrap">
            <div class="aura-how-it-works__icon">
              {% if block.settings.custom_svg != blank %}
                {{ block.settings.custom_svg }}
              {% else %}
                {% render 'aura-icon', icon: block.settings.icon %}
              {% endif %}
            </div>
          </div>

          {% if block.settings.step_number != blank %}
            <p class="aura-how-it-works__number">{{ block.settings.step_number | escape }}</p>
          {% endif %}

          {% if block.settings.heading != blank %}
            <h3 class="aura-how-it-works__step-heading">{{ block.settings.heading | escape }}</h3>
          {% endif %}

          {% if block.settings.text != blank %}
            <p class="aura-how-it-works__step-text">{{ block.settings.text | escape }}</p>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% style %}
  .{{ works_class }} {
    background: var(--aura-how-it-works-background);
    border-top: 1px solid rgba(129, 57, 82, 0.12);
    border-bottom: 1px solid rgba(129, 57, 82, 0.12);
  }

  .{{ works_class }} .aura-how-it-works__inner {
    width: min(1160px, calc(100% - 48px));
    margin: 0 auto;
    padding-top: var(--aura-how-it-works-padding-top);
    padding-bottom: var(--aura-how-it-works-padding-bottom);
  }

  .{{ works_class }} .aura-how-it-works__header {
    margin-bottom: 1.8rem;
    text-align: center;
  }

  .{{ works_class }} .aura-how-it-works__heading {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: var(--aura-how-it-works-heading-size);
    font-weight: 500;
    letter-spacing: -0.04em;
    color: #171012;
  }

  .{{ works_class }} .aura-how-it-works__grid {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--aura-how-it-works-gap);
  }

  .{{ works_class }}.aura-how-it-works--with-line .aura-how-it-works__grid::before {
    content: "";
    position: absolute;
    top: 2rem;
    left: 12%;
    right: 12%;
    border-top: 2px dashed var(--aura-how-it-works-line-color);
    z-index: 0;
  }

  .{{ works_class }} .aura-how-it-works__step {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .{{ works_class }} .aura-how-it-works__icon-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 0.9rem;
  }

  .{{ works_class }} .aura-how-it-works__icon {
    display: grid;
    place-items: center;
    width: 4rem;
    height: 4rem;
    padding: 1rem;
    border-radius: 50%;
    background: var(--aura-how-it-works-icon-background);
    color: var(--aura-how-it-works-icon-color);
  }

  .{{ works_class }} .aura-how-it-works__number {
    margin: 0 0 0.35rem;
    color: #a95976;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .{{ works_class }} .aura-how-it-works__step-heading {
    margin: 0 0 0.45rem;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .{{ works_class }} .aura-how-it-works__step-text {
    max-width: 13rem;
    margin: 0 auto;
    color: #6f5b63;
    font-size: 0.78rem;
    line-height: 1.45;
  }

  @media (max-width: 989px) {
    .{{ works_class }} .aura-how-it-works__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .{{ works_class }}.aura-how-it-works--with-line .aura-how-it-works__grid::before {
      display: none;
    }
  }

  @media (max-width: 767px) {
    .{{ works_class }} .aura-how-it-works__inner {
      width: min(1160px, calc(100% - 32px));
    }

    .{{ works_class }} .aura-how-it-works__heading {
      font-size: min(calc(var(--aura-how-it-works-heading-size) * 0.84), 2.2rem);
    }

    .{{ works_class }}.aura-how-it-works--mobile-stacked .aura-how-it-works__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Aura how it works",
  "tag": "section",
  "class": "section-aura-how-it-works",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How Aura Society works"
    },
    {
      "type": "checkbox",
      "id": "show_connector_line",
      "label": "Show dotted connector line",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "mobile_stacked",
      "label": "Use stacked mobile layout",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#fff7f7"
    },
    {
      "type": "color",
      "id": "icon_background",
      "label": "Icon background",
      "default": "#fff0f3"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#a65471"
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Connector line color",
      "default": "#e0b4c3"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body size",
      "min": 13,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "step_gap",
      "label": "Step spacing",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 44
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "sparkle",
          "options": [
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "bag", "label": "Bag" },
            { "value": "gift", "label": "Gift" },
            { "value": "crown", "label": "Crown" }
          ]
        },
        {
          "type": "textarea",
          "id": "custom_svg",
          "label": "Custom SVG code"
        },
        {
          "type": "text",
          "id": "step_number",
          "label": "Step number",
          "default": "1. Join"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Join"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Sign up for free and start collecting points."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aura how it works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "icon": "sparkle",
            "step_number": "1. Join",
            "heading": "Join",
            "text": "Sign up for free and start collecting points instantly."
          }
        },
        {
          "type": "step",
          "settings": {
            "icon": "bag",
            "step_number": "2. Shop & earn",
            "heading": "Shop & earn",
            "text": "Earn points every time you purchase your skincare favorites."
          }
        },
        {
          "type": "step",
          "settings": {
            "icon": "crown",
            "step_number": "3. Unlock perks",
            "heading": "Unlock perks",
            "text": "Move up tiers to unlock exclusive beauty experiences."
          }
        },
        {
          "type": "step",
          "settings": {
            "icon": "gift",
            "step_number": "4. Redeem rewards",
            "heading": "Redeem rewards",
            "text": "Use your points for curated rewards, credits, and gifts."
          }
        }
      ]
    }
  ]
}
{% endschema %}
