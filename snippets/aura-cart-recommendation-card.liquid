{% doc %}
  Product card for Aura cart recommendations. Parent `.aura-cart-page`.

  @param {product} product
  @param {object} section - `aura-cart-page` section

  @example
  {% render 'aura-cart-recommendation-card', product: product, section: section %}
{% enddoc %}

{% liquid
  assign v = product.selected_or_first_available_variant
  assign img_primary = product.featured_image
  if product.featured_media and product.featured_media.preview_image
    assign img_primary = product.featured_media.preview_image
  endif

  assign tag_bs = section.settings.rec_badge_best_seller_tag | handleize
  assign tag_new = section.settings.rec_badge_new_tag | handleize
  assign tag_ex = section.settings.rec_badge_exclusive_tag | handleize
  assign show_bs = false
  assign show_new = false
  assign show_ex = false
  for t in product.tags
    assign th = t | handleize
    if th == tag_bs
      assign show_bs = true
    endif
    if th == tag_new
      assign show_new = true
    endif
    if th == tag_ex
      assign show_ex = true
    endif
  endfor

  assign new_days = section.settings.rec_new_product_days | default: 45
  assign days_secs = new_days | times: 86400
  assign cutoff_ts = 'now' | date: '%s' | minus: days_secs
  assign created_ts = product.created_at | date: '%s'
  if created_ts > cutoff_ts
    assign show_new = true
  endif

  assign tag_badge_count = 0
  if show_bs
    assign tag_badge_count = tag_badge_count | plus: 1
  endif
  if show_ex
    assign tag_badge_count = tag_badge_count | plus: 1
  endif
  if show_new
    assign tag_badge_count = tag_badge_count | plus: 1
  endif

  assign static_badge = nil
  if section.settings.rec_show_badges
    if tag_badge_count == 0
      assign roll = product.id | modulo: 3
      case roll
        when 0
          assign static_badge = 'best_seller'
        when 1
          assign static_badge = 'new'
        else
          assign static_badge = 'exclusive'
      endcase
    endif
  endif

  assign rec_pts = v.price | times: section.settings.points_multiplier | divided_by: 100.0 | round
%}

<article
  class="aura-cart-page__product-card"
  data-aura-cart-rec-card
  data-product-id="{{ product.id }}"
  data-product-handle="{{ product.handle | escape }}"
  data-variant-price-cents="{{ v.price }}"
  data-variant-compare-cents="{% if v.compare_at_price > v.price %}{{ v.compare_at_price }}{% else %}0{% endif %}"
  {% if v.available %}
    data-variant-id="{{ v.id }}"
  {% endif %}
>
  <a class="aura-cart-page__product-card-media-link" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
    <div class="aura-cart-page__product-card-media">
      {% if section.settings.rec_show_badges %}
        <div class="aura-cart-page__product-card-badges">
          {% if show_bs %}
            <span class="aura-cart-page__product-card-badge">{{ 'sections.aura_collection_grid.badge_best_seller' | t }}</span>
          {% endif %}
          {% if show_ex %}
            <span class="aura-cart-page__product-card-badge">{{ 'sections.aura_collection_grid.badge_exclusive' | t }}</span>
          {% endif %}
          {% if show_new %}
            <span class="aura-cart-page__product-card-badge">{{ 'sections.aura_collection_grid.badge_new' | t }}</span>
          {% endif %}
          {% if tag_badge_count == 0 and static_badge != nil %}
            {% case static_badge %}
              {% when 'best_seller' %}
                <span class="aura-cart-page__product-card-badge">{{ 'sections.aura_collection_grid.badge_best_seller' | t }}</span>
              {% when 'exclusive' %}
                <span class="aura-cart-page__product-card-badge">{{ 'sections.aura_collection_grid.badge_exclusive' | t }}</span>
              {% else %}
                <span class="aura-cart-page__product-card-badge">{{ 'sections.aura_collection_grid.badge_new' | t }}</span>
            {% endcase %}
          {% endif %}
        </div>
      {% endif %}

      {% if section.settings.rec_show_wishlist %}
        <button
          type="button"
          class="aura-cart-page__product-card-wish"
          data-aura-cart-rec-wish
          data-product-id="{{ product.id }}"
          data-product-handle="{{ product.handle | escape }}"
          aria-label="{{ 'sections.aura_collection_grid.wishlist_add' | t }}"
          aria-pressed="false"
        >
          <span class="aura-cart-page__product-card-wish-outline" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M12 20.2 4.7 12.9a4.9 4.9 0 0 1 6.9-6.9L12 6.4l.4-.4a4.9 4.9 0 0 1 6.9 6.9L12 20.2Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path>
            </svg>
          </span>
          <span class="aura-cart-page__product-card-wish-fill" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 20.2 4.7 12.9a4.9 4.9 0 0 1 6.9-6.9L12 6.4l.4-.4a4.9 4.9 0 0 1 6.9 6.9L12 20.2Z"></path>
            </svg>
          </span>
        </button>
      {% endif %}

      {% if img_primary %}
        <div class="aura-cart-page__product-card-img-wrap">
          {{
            img_primary
            | image_url: width: 600
            | image_tag:
              loading: 'lazy',
              class: 'aura-cart-page__product-card-img',
              widths: '180, 300, 450, 600',
              alt: img_primary.alt | default: product.title
          }}
        </div>
      {% else %}
        <div class="aura-cart-page__product-card-img-wrap aura-cart-page__product-card-img-wrap--ph">
          {{ 'product-apparel-1' | placeholder_svg_tag: class: 'aura-cart-page__product-card-ph' }}
        </div>
      {% endif %}
    </div>
  </a>

  <div class="aura-cart-page__product-card-body">
    <a class="aura-cart-page__product-card-title" href="{{ product.url }}">{{ product.title | escape }}</a>
    <div class="aura-cart-page__product-card-price-row">
      {% if v.compare_at_price > v.price %}
        <span class="aura-cart-page__product-card-price aura-cart-page__product-card-price--sale">{{ v.price | money }}</span>
        <span class="aura-cart-page__product-card-compare">{{ v.compare_at_price | money }}</span>
      {% else %}
        <span class="aura-cart-page__product-card-price">{{ v.price | money }}</span>
      {% endif %}
    </div>
    {% if section.settings.rec_show_points_pill %}
      <p class="aura-cart-page__product-card-pill">
        <span aria-hidden="true">✦</span> {{ 'sections.aura_cart_page.earn_pts_short' | t: points: rec_pts }}
      </p>
    {% endif %}
    {% if v.available %}
      <div class="aura-cart-page__product-card-foot">
        {% if section.settings.rec_show_quantity %}
          <div class="aura-cart-page__rec-qty" data-aura-cart-rec-qty>
            <button
              type="button"
              class="aura-cart-page__rec-qty-btn"
              data-aura-cart-rec-qty-dec
              aria-label="{{ 'sections.aura_product_main.decrease' | t }}"
            >
              −
            </button>
            <input
              type="number"
              class="aura-cart-page__rec-qty-input"
              data-aura-cart-rec-qty-input
              value="1"
              min="1"
              max="99"
              aria-label="{{ 'sections.aura_product_main.quantity' | t }}"
            >
            <button
              type="button"
              class="aura-cart-page__rec-qty-btn"
              data-aura-cart-rec-qty-inc
              aria-label="{{ 'sections.aura_product_main.increase' | t }}"
            >
              +
            </button>
          </div>
        {% endif %}
        <button
          type="button"
          class="aura-cart-page__product-card-add"
          data-aura-cart-rec-add
          data-variant-id="{{ v.id }}"
          aria-label="{{ 'sections.aura_product_main.add_to_cart' | t }}"
        >
          <span class="aura-cart-page__product-card-add-ic" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M5 9h14l-1 11H6L5 9Z" stroke="currentColor" stroke-width="1.15" stroke-linejoin="round"></path>
              <path d="M9 9V7a3 3 0 0 1 6 0v2" stroke="currentColor" stroke-width="1.15" stroke-linecap="round"></path>
            </svg>
          </span>
        </button>
      </div>
    {% endif %}
  </div>
</article>
