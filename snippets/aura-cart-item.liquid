{% doc %}
  Renders one cart line for Aura cart page. Parent must be `.aura-cart-page`.

  @param {line_item} item - Cart line item
  @param {object} section - `aura-cart-page` section (settings)
  @param {number} line_points - Precomputed points for this line

  @example
  {% render 'aura-cart-item', item: item, section: section, line_points: lp %}
{% enddoc %}

{%- liquid
  assign vtitle = item.variant.title | strip
  assign show_variant = true
  if vtitle == blank or vtitle == 'Default Title'
    assign show_variant = false
  endif
-%}

<div
  class="aura-cart-page__item"
  data-aura-cart-line-key="{{ item.key }}"
>
  <div class="aura-cart-page__item-product">
    <div class="aura-cart-page__item-media">
      {% if item.image %}
        <a class="aura-cart-page__item-img-link" href="{{ item.url }}" aria-label="{{ item.product.title | escape }}">
          {{
            item.image
            | image_url: width: 240
            | image_tag:
              loading: 'lazy',
              class: 'aura-cart-page__item-img',
              widths: '120, 180, 240',
              alt: item.image.alt | default: item.product.title
          }}
        </a>
      {% else %}
        <div class="aura-cart-page__item-img-fallback">
          {{ 'product-apparel-1' | placeholder_svg_tag: class: 'aura-cart-page__item-ph' }}
        </div>
      {% endif %}
    </div>

    <div class="aura-cart-page__item-copy">
      <a class="aura-cart-page__item-title" href="{{ item.url }}">{{ item.product.title | escape }}</a>
      {% if show_variant %}
        <p class="aura-cart-page__item-variant">{{ vtitle | escape }}</p>
      {% endif %}
      <p class="aura-cart-page__item-pill" aria-label="{{ 'sections.aura_cart_page.points_line_aria' | t: points: line_points }}">
        <span class="aura-cart-page__item-pill-ic" aria-hidden="true">✦</span>
        {{ 'sections.aura_cart_page.earn_pts_short' | t: points: line_points }}
      </p>
    </div>
  </div>

  <div class="aura-cart-page__item-price-col">
    <span class="aura-cart-page__item-price-label">{{ 'sections.aura_cart_page.price_each' | t }}</span>
    <span class="aura-cart-page__item-price" data-aura-line-unit>{{ item.final_price | money }}</span>
  </div>

  <div class="aura-cart-page__item-qty-col">
    <div class="aura-cart-page__qty" data-aura-cart-qty-wrap>
      <button
        type="button"
        class="aura-cart-page__qty-btn"
        data-aura-cart-qty-dec
        aria-label="{{ 'sections.aura_product_main.decrease' | t }}"
      >
        −
      </button>
      <input
        type="number"
        class="aura-cart-page__qty-input"
        data-aura-line-qty
        value="{{ item.quantity }}"
        min="0"
        aria-label="{{ 'sections.aura_product_main.quantity' | t }}"
        readonly
      >
      <button
        type="button"
        class="aura-cart-page__qty-btn"
        data-aura-cart-qty-inc
        aria-label="{{ 'sections.aura_product_main.increase' | t }}"
      >
        +
      </button>
    </div>
  </div>

  <div class="aura-cart-page__item-total-col">
    <span class="aura-cart-page__item-total-label">{{ 'sections.aura_cart_page.line_total' | t }}</span>
    <span class="aura-cart-page__item-line" data-aura-line-total>{{ item.final_line_price | money }}</span>
  </div>

  <button
    type="button"
    class="aura-cart-page__item-remove"
    data-aura-cart-remove
    aria-label="{{ 'sections.aura_cart_page.remove_line' | t }}"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M4 7h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
      <path d="M10 11v6m4-6v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
      <path d="M9 7V5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" stroke="currentColor" stroke-width="1.5"></path>
      <path d="M7 7l1 12a2 2 0 0 0 2 1.8h6a2 2 0 0 0 2-1.8l1-12" stroke="currentColor" stroke-width="1.5"></path>
    </svg>
  </button>
</div>
