{% doc %}
  Fallback subtitle or ingredients copy from `product.type` when metafields are empty.

  @param {product} product - Current product
  @param {string} part - One of: subtitle, ingredients_heading, ingredients_intro, ingredients_list (list uses || between rows; each row is "Name — Description")
{% enddoc %}

{% liquid
  assign pt = product.type | strip | downcase
  assign out = ''

  case pt
    when 'serum'
      if part == 'subtitle'
        assign out = 'Brightening • Hydrating • Radiant'
      elsif part == 'ingredients_heading'
        assign out = 'What makes it powerful'
      elsif part == 'ingredients_intro'
        assign out = 'A blend of clinically loved ingredients that work together to brighten, hydrate, and revitalize your skin.'
      elsif part == 'ingredients_list'
        assign out = 'Niacinamide — Helps even skin tone and reduce the look of dark spots.||Hyaluronic Acid — Deeply hydrates and locks in moisture for plump, glowing skin.||Peony Extract — Helps soothe, brighten, and improve skin clarity.'
      endif

    when 'perfume'
      if part == 'subtitle'
        assign out = 'Elegant • Long-lasting • Alluring'
      elsif part == 'ingredients_heading'
        assign out = 'Crafted to leave a lasting impression'
      elsif part == 'ingredients_intro'
        assign out = 'An elegant fragrance blend designed to linger beautifully on the skin while evolving throughout the day.'
      elsif part == 'ingredients_list'
        assign out = 'White Peony — Adds a soft floral elegance with a delicate feminine touch.||Amber Musk — Creates warmth and long-lasting depth.||Citrus Blossom — Brightens the fragrance with fresh sparkling notes.'
      endif

    when 'lip gloss'
      if part == 'subtitle'
        assign out = 'Glossy • Smooth • Plumping'
      elsif part == 'ingredients_heading'
        assign out = 'Gloss that feels as good as it looks'
      elsif part == 'ingredients_intro'
        assign out = 'A nourishing lip formula that delivers shine, comfort, and hydration without feeling sticky.'
      elsif part == 'ingredients_list'
        assign out = 'Shea Butter — Helps soften and smooth dry lips.||Vitamin E — Provides antioxidant protection and nourishment.||Jojoba Oil — Locks in moisture for a glossy healthy finish.'
      endif

    when 'blush'
      if part == 'subtitle'
        assign out = 'Radiant • Buildable • Silky'
      elsif part == 'ingredients_heading'
        assign out = 'Color that melts into the skin'
      elsif part == 'ingredients_intro'
        assign out = 'A silky blend of skin-loving ingredients designed to deliver a natural radiant flush.'
      elsif part == 'ingredients_list'
        assign out = 'Squalane — Helps maintain hydration and smooth texture.||Rose Extract — Adds soothing and refreshing properties.||Lightweight Pigments — Create a soft buildable natural-looking glow.'
      endif

    when 'moisturizer'
      if part == 'subtitle'
        assign out = 'Hydrating • Nourishing • Softening'
      elsif part == 'ingredients_heading'
        assign out = 'Deep hydration meets everyday glow'
      elsif part == 'ingredients_intro'
        assign out = 'A nourishing moisturizer formulated to restore softness, hydration, and skin balance.'
      elsif part == 'ingredients_list'
        assign out = 'Ceramides — Help strengthen the skin barrier and retain moisture.||Hyaluronic Acid — Provides long-lasting hydration and plumpness.||Aloe Vera — Helps calm and soothe dry sensitive skin.'
      endif

    when 'foundation'
      if part == 'subtitle'
        assign out = 'Flawless • Lightweight • Blurring'
      elsif part == 'ingredients_heading'
        assign out = 'Coverage powered by skincare ingredients'
      elsif part == 'ingredients_intro'
        assign out = 'A breathable complexion formula that smooths, hydrates, and blurs imperfections for an effortless finish.'
      elsif part == 'ingredients_list'
        assign out = 'Niacinamide — Helps improve skin tone appearance over time.||Peptides — Support smoother-looking skin texture.||Hyaluronic Acid — Keeps skin hydrated throughout the day.'
      endif
  endcase
%}
{{- out -}}
