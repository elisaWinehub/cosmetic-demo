{% doc %}
  Aura PLP product card. All markup/CSS hooks scoped under parent `.aura-collection-page`.

  @param {product} product - Product object
  @param {section} section - Parent `aura-collection-grid` section (settings)

  @example
  {% render 'aura-product-card', product: product, section: section %}
{% enddoc %}

{% liquid
  assign v = product.selected_or_first_available_variant
  assign img_primary = product.featured_image
  if product.featured_media and product.featured_media.preview_image
    assign img_primary = product.featured_media.preview_image
  endif
  assign img_secondary = nil
  if section.settings.enable_hover_image and product.media.size > 1
    for m in product.media
      if m.media_type == 'image' and m.preview_image
        if m.preview_image.id != img_primary.id
          assign img_secondary = m.preview_image
          break
        endif
      endif
    endfor
  endif

  assign tag_bs = section.settings.badge_best_seller_tag | handleize
  assign tag_new = section.settings.badge_new_tag | handleize
  assign tag_ex = section.settings.badge_exclusive_tag | handleize
  assign show_bs = false
  assign show_new = false
  assign show_ex = false
  for t in product.tags
    assign th = t | handleize
    if th == tag_bs
      assign show_bs = true
    endif
    if th == tag_new
      assign show_new = true
    endif
    if th == tag_ex
      assign show_ex = true
    endif
  endfor

  assign new_days = section.settings.new_product_days | default: 45
  assign days_secs = new_days | times: 86400
  assign cutoff_ts = 'now' | date: '%s' | minus: days_secs
  assign created_ts = product.created_at | date: '%s'
  if created_ts > cutoff_ts
    assign show_new = true
  endif

  assign show_quick = true
  if section.settings.multi_variant_mode == 'choose' and product.has_only_default_variant == false
    assign show_quick = false
  endif

  assign tag_badge_count = 0
  if show_bs
    assign tag_badge_count = tag_badge_count | plus: 1
  endif
  if show_ex
    assign tag_badge_count = tag_badge_count | plus: 1
  endif
  if show_new
    assign tag_badge_count = tag_badge_count | plus: 1
  endif

  assign static_badge = nil
  if section.settings.show_badges
    if tag_badge_count == 0
      assign roll = product.id | modulo: 3
      case roll
        when 0
          assign static_badge = 'best_seller'
        when 1
          assign static_badge = 'new'
        else
          assign static_badge = 'exclusive'
      endcase
    endif
  endif

  assign review_count_display = section.settings.static_review_count | default: '124' | strip

  assign plp_variant_label = ''
  unless product.has_only_default_variant
    assign plp_variant_label = v.title
  endunless
%}

<article
  class="aura-plp-card"
  data-aura-plp-card
  data-product-id="{{ product.id }}"
  data-product-handle="{{ product.handle | escape }}"
  data-variant-price-cents="{{ v.price }}"
  data-variant-compare-cents="{% if v.compare_at_price > v.price %}{{ v.compare_at_price }}{% else %}0{% endif %}"
  data-variant-label="{{ plp_variant_label | escape }}"
  {% if show_quick %}
    data-variant-id="{{ v.id }}"
    data-variant-available="{% if v.available %}true{% else %}false{% endif %}"
  {% endif %}
>
  <a class="aura-plp-card__media-link" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
    <div class="aura-plp-card__media">
      {% if section.settings.show_badges %}
        <div class="aura-plp-card__badges">
          {% if show_bs %}
            <span class="aura-plp-card__badge">{{ 'sections.aura_collection_grid.badge_best_seller' | t }}</span>
          {% endif %}
          {% if show_ex %}
            <span class="aura-plp-card__badge">{{ 'sections.aura_collection_grid.badge_exclusive' | t }}</span>
          {% endif %}
          {% if show_new %}
            <span class="aura-plp-card__badge">{{ 'sections.aura_collection_grid.badge_new' | t }}</span>
          {% endif %}
          {% if tag_badge_count == 0 and static_badge != nil %}
            {% case static_badge %}
              {% when 'best_seller' %}
                <span class="aura-plp-card__badge">{{ 'sections.aura_collection_grid.badge_best_seller' | t }}</span>
              {% when 'exclusive' %}
                <span class="aura-plp-card__badge">{{ 'sections.aura_collection_grid.badge_exclusive' | t }}</span>
              {% else %}
                <span class="aura-plp-card__badge">{{ 'sections.aura_collection_grid.badge_new' | t }}</span>
            {% endcase %}
          {% endif %}
        </div>
      {% endif %}

      {% if section.settings.show_wishlist %}
        <button
          type="button"
          class="aura-plp-card__wish"
          data-aura-wishlist
          data-product-id="{{ product.id }}"
          data-product-handle="{{ product.handle | escape }}"
          aria-label="{{ 'sections.aura_collection_grid.wishlist_add' | t }}"
          aria-pressed="false"
        >
          <span class="aura-plp-card__wish-svg aura-plp-card__wish-svg--outline" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path d="M12 20.2 4.7 12.9a4.9 4.9 0 0 1 6.9-6.9L12 6.4l.4-.4a4.9 4.9 0 0 1 6.9 6.9L12 20.2Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path>
            </svg>
          </span>
          <span class="aura-plp-card__wish-svg aura-plp-card__wish-svg--fill" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 20.2 4.7 12.9a4.9 4.9 0 0 1 6.9-6.9L12 6.4l.4-.4a4.9 4.9 0 0 1 6.9 6.9L12 20.2Z"></path>
            </svg>
          </span>
        </button>
      {% endif %}

      {% if img_primary %}
        <div class="aura-plp-card__img-wrap">
          {{
            img_primary
            | image_url: width: 900
            | image_tag:
              loading: 'lazy',
              class: 'aura-plp-card__img aura-plp-card__img--primary',
              widths: '200, 360, 540, 720, 900',
              alt: img_primary.alt | default: product.title
          }}
          {% if img_secondary %}
            {{
              img_secondary
              | image_url: width: 900
              | image_tag:
                loading: 'lazy',
                class: 'aura-plp-card__img aura-plp-card__img--secondary',
                widths: '200, 360, 540, 720, 900',
                alt: img_secondary.alt | default: product.title
            }}
          {% endif %}
        </div>
      {% else %}
        <div class="aura-plp-card__img-wrap aura-plp-card__img-wrap--placeholder">
          {{ 'product-apparel-1' | placeholder_svg_tag: class: 'aura-plp-card__ph' }}
        </div>
      {% endif %}
    </div>
  </a>

  <div class="aura-plp-card__body">
    <a class="aura-plp-card__title" href="{{ product.url }}">{{ product.title | escape }}</a>

    <div class="aura-plp-card__price-row">
      {% if v.compare_at_price > v.price %}
        <span class="aura-plp-card__price aura-plp-card__price--sale">{{ v.price | money }}</span>
        <span class="aura-plp-card__compare">{{ v.compare_at_price | money }}</span>
      {% else %}
        <span class="aura-plp-card__price">{{ v.price | money }}</span>
      {% endif %}
    </div>

    {% if section.settings.show_ratings %}
      <div class="aura-plp-card__rating" aria-label="{{ 'sections.aura_collection_grid.rating_aria' | t: rating: 5 }}">
        <span class="aura-plp-card__stars" aria-hidden="true">
          {%- for i in (1..5) -%}
            <span class="aura-plp-card__star--full">★</span>
          {%- endfor -%}
        </span>
        <span class="aura-plp-card__reviews">({{ review_count_display | escape }})</span>
      </div>
    {% endif %}

    <div class="aura-plp-card__foot">
      {% if show_quick %}
        {% if section.settings.show_quantity %}
          <div class="aura-plp-card__qty aura-plp-qty" data-aura-plp-qty>
            <button type="button" class="aura-plp-qty__btn" data-aura-plp-qty-dec aria-label="{{ 'sections.aura_product_main.decrease' | t }}">
              −
            </button>
            <input
              type="number"
              class="aura-plp-qty__input"
              name="quantity"
              value="1"
              min="1"
              max="99"
              data-aura-plp-qty-input
              aria-label="{{ 'sections.aura_product_main.quantity' | t }}"
            >
            <button type="button" class="aura-plp-qty__btn" data-aura-plp-qty-inc aria-label="{{ 'sections.aura_product_main.increase' | t }}">
              +
            </button>
          </div>
        {% endif %}
        <button
          type="button"
          class="aura-plp-card__add"
          data-aura-quick-add
          data-variant-id="{{ v.id }}"
          {% unless v.available %}
            disabled
          {% endunless %}
          aria-label="{{ 'sections.aura_product_main.add_to_cart' | t }}"
        >
          <span class="aura-plp-card__add-ic" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M5 9h14l-1 11H6L5 9Z" stroke="currentColor" stroke-width="1.15" stroke-linejoin="round"></path>
              <path d="M9 9V7a3 3 0 0 1 6 0v2" stroke="currentColor" stroke-width="1.15" stroke-linecap="round"></path>
            </svg>
          </span>
        </button>
      {% else %}
        <a class="aura-plp-card__choose" href="{{ product.url }}">{{ 'sections.aura_collection_grid.choose_options' | t }}</a>
      {% endif %}
    </div>
  </div>
</article>

{% stylesheet %}
  .aura-collection-page .aura-plp-card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    border-radius: var(--acg-card-radius, 16px);
    background: #fff;
    border: 1px solid var(--acg-border, #f0dfe8);
    overflow: hidden;
    transition:
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.25s ease,
      box-shadow 0.35s ease;
  }

  .aura-collection-page .aura-plp-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--acg-accent, #ec008c) 22%, transparent);
    box-shadow: 0 18px 40px rgba(27, 44, 88, 0.07);
  }

  .aura-collection-page .aura-plp-card__media-link {
    text-decoration: none;
    color: inherit;
  }

  .aura-collection-page .aura-plp-card__media {
    position: relative;
    background: var(--acg-card-surface, #fef7fb);
  }

  .aura-collection-page .aura-plp-card__badges {
    position: absolute;
    top: 0.65rem;
    left: 0.65rem;
    z-index: 3;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    pointer-events: none;
    max-width: calc(100% - 3.5rem);
  }

  .aura-collection-page .aura-plp-card__badge {
    display: inline-flex;
    align-items: center;
    padding: 0.22rem 0.65rem;
    border-radius: 999px;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: #ec008c;
    color: #fff;
    border: none;
    box-shadow: none;
  }

  .aura-collection-page .aura-plp-card__wish {
    position: absolute;
    top: 0.55rem;
    right: 0.55rem;
    z-index: 4;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--acg-border, #f0dfe8) 85%, #fff);
    background: rgba(255, 255, 255, 0.92);
    display: grid;
    place-items: center;
    cursor: pointer;
    color: var(--acg-heading, #1b2c58);
    transition: background 0.25s ease, color 0.25s ease, transform 0.2s ease, border-color 0.2s ease;
    padding: 0;
    margin: 0;
  }

  .aura-collection-page .aura-plp-card__wish:hover {
    transform: scale(1.04);
    color: var(--acg-accent, #ec008c);
    border-color: color-mix(in srgb, var(--acg-accent, #ec008c) 35%, transparent);
  }

  .aura-collection-page .aura-plp-card__wish[aria-pressed='true'] {
    color: var(--acg-accent, #ec008c);
    background: #fff6fb;
    border-color: color-mix(in srgb, var(--acg-accent, #ec008c) 45%, transparent);
  }

  .aura-collection-page .aura-plp-card__wish-svg {
    display: grid;
    place-items: center;
    line-height: 0;
  }

  .aura-collection-page .aura-plp-card__wish-svg--fill {
    display: none;
  }

  .aura-collection-page .aura-plp-card__wish[aria-pressed='true'] .aura-plp-card__wish-svg--outline {
    display: none;
  }

  .aura-collection-page .aura-plp-card__wish[aria-pressed='true'] .aura-plp-card__wish-svg--fill {
    display: grid;
  }

  .aura-collection-page .aura-plp-card__img-wrap {
    aspect-ratio: 1 / 1;
    position: relative;
    overflow: hidden;
    display: block;
    width: 100%;
    background: var(--acg-card-surface, #fef7fb);
  }

  .aura-collection-page .aura-plp-card__img-wrap--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .aura-collection-page .aura-plp-card__ph {
    width: 45%;
    height: auto;
    opacity: 0.35;
  }

  .aura-collection-page .aura-plp-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: opacity 0.5s ease;
  }

  .aura-collection-page .aura-plp-card__img--secondary {
    opacity: 0;
  }

  .aura-collection-page .aura-plp-card:has(.aura-plp-card__img--secondary):hover .aura-plp-card__img--primary {
    opacity: 0;
  }

  .aura-collection-page .aura-plp-card:has(.aura-plp-card__img--secondary):hover .aura-plp-card__img--secondary {
    opacity: 1;
  }

  .aura-collection-page .aura-plp-card:not(:has(.aura-plp-card__img--secondary)):hover .aura-plp-card__img--primary {
    opacity: 0.92;
  }

  .aura-collection-page .aura-plp-card__body {
    padding: 0.85rem 1rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    flex: 1;
  }

  .aura-collection-page .aura-plp-card__title {
    font-family: var(--font-body-family, inherit);
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--acg-heading, #1b2c58);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .aura-collection-page .aura-plp-card__title:hover {
    color: var(--acg-accent, #ec008c);
  }

  .aura-collection-page .aura-plp-card__price-row {
    display: flex;
    align-items: baseline;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .aura-collection-page .aura-plp-card__price {
    font-weight: 700;
    color: var(--acg-heading, #1b2c58);
    font-size: 0.95rem;
  }

  .aura-collection-page .aura-plp-card__price--sale {
    color: var(--acg-accent, #ec008c);
  }

  .aura-collection-page .aura-plp-card__compare {
    font-size: 0.85rem;
    text-decoration: line-through;
    color: color-mix(in srgb, var(--acg-text, #3d4657) 55%, transparent);
  }

  .aura-collection-page .aura-plp-card__rating {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--acg-text, #3d4657);
    flex-wrap: wrap;
  }

  .aura-collection-page .aura-plp-card__stars {
    letter-spacing: 0.02em;
    line-height: 1;
    color: var(--acg-star, #ec008c);
  }

  .aura-collection-page .aura-plp-card__star--full {
    color: var(--acg-star, #ec008c);
  }

  .aura-collection-page .aura-plp-card__reviews {
    font-size: 0.8rem;
    color: color-mix(in srgb, var(--acg-text, #3d4657) 88%, var(--acg-heading, #1b2c58));
  }

  .aura-collection-page .aura-plp-card__foot {
    margin-top: auto;
    padding-top: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.5rem;
    flex-wrap: nowrap;
    width: 100%;
    box-sizing: border-box;
  }

  @media (max-width: 420px) {
    .aura-collection-page .aura-plp-card__foot {
      flex-wrap: wrap;
    }
  }

  .aura-collection-page .aura-plp-qty {
    display: inline-flex;
    align-items: stretch;
    border-radius: 999px;
    border: 1px solid var(--acg-border, #f0dfe8);
    background: #fff;
    overflow: hidden;
    flex: 0 0 auto;
    width: 7.25rem;
    max-width: calc(100% - 2.25rem);
    height: 2.35rem;
    box-sizing: border-box;
  }

  .aura-collection-page .aura-plp-qty__btn {
    flex: 0 0 auto;
    width: 2.1rem;
    min-width: 2.1rem;
    border: none;
    background: transparent;
    font-size: 1.05rem;
    line-height: 1;
    cursor: pointer;
    color: var(--acg-heading, #1b2c58);
    transition: background 0.2s ease;
    display: grid;
    place-items: center;
    padding: 0;
  }

  .aura-collection-page .aura-plp-qty__btn:hover {
    background: #fff6fb;
  }

  .aura-collection-page .aura-plp-qty__input {
    flex: 1 1 auto;
    min-width: 0;
    width: 100%;
    border: none;
    border-left: 1px solid var(--acg-border, #f0dfe8);
    border-right: 1px solid var(--acg-border, #f0dfe8);
    text-align: center;
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
    color: var(--acg-heading, #1b2c58);
    background: transparent;
    appearance: textfield;
    padding: 0 0.2rem;
    box-sizing: border-box;
  }

  .aura-collection-page .aura-plp-qty__input::-webkit-outer-spin-button,
  .aura-collection-page .aura-plp-qty__input::-webkit-inner-spin-button {
    appearance: none;
    margin: 0;
  }

  .aura-collection-page .aura-plp-card__add {
    flex: 0 0 auto;
    margin-left: auto;
    width: auto;
    min-width: 1.75rem;
    height: 2.35rem;
    padding: 0 0.15rem;
    border-radius: 0;
    border: none;
    box-shadow: none;
    outline: none;
    cursor: pointer;
    background: transparent;
    color: var(--acg-navy, #1a2b4c);
    display: grid;
    place-items: center;
    margin: 0;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease,
      background 0.2s ease;
  }

  .aura-collection-page .aura-plp-card__add:hover:not(:disabled),
  .aura-collection-page .aura-plp-card__add:focus-visible:not(:disabled) {
    background: color-mix(in srgb, var(--acg-navy, #1a2b4c) 6%, transparent);
    transform: scale(1.04);
  }

  .aura-collection-page .aura-plp-card__add:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--acg-navy, #1a2b4c) 35%, transparent);
    outline-offset: 2px;
  }

  .aura-collection-page .aura-plp-card__add:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .aura-collection-page .aura-plp-card__add.is-loading {
    pointer-events: none;
    opacity: 0.65;
  }

  .aura-collection-page .aura-plp-card__add-ic {
    display: grid;
    place-items: center;
    line-height: 0;
    color: var(--acg-navy, #1a2b4c);
  }

  .aura-collection-page .aura-plp-card__add-ic svg {
    width: 1.05rem;
    height: 1.05rem;
    display: block;
  }

  .aura-collection-page .aura-plp-card__choose {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    min-height: 2.75rem;
    padding: 0 1rem;
    border-radius: var(--acg-card-radius, 16px);
    border: 1px solid var(--acg-border, #f0dfe8);
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--acg-heading, #1b2c58);
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--acg-g-start, #43318f) 12%, #fff),
      color-mix(in srgb, var(--acg-g-end, #ec008c) 10%, #fff)
    );
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .aura-collection-page .aura-plp-card__choose:hover {
    border-color: color-mix(in srgb, var(--acg-accent, #ec008c) 45%, transparent);
    transform: translateY(-1px);
  }

  .aura-collection-page .aura-plp-grid--list .aura-plp-card {
    flex-direction: row;
    align-items: stretch;
  }

  .aura-collection-page .aura-plp-grid--list .aura-plp-card__media-link {
    flex: 0 0 38%;
    max-width: 220px;
  }

  .aura-collection-page .aura-plp-grid--list .aura-plp-card__body {
    flex: 1;
    justify-content: center;
  }

  @media (max-width: 749px) {
    .aura-collection-page .aura-plp-grid--list .aura-plp-card {
      flex-direction: column;
    }

    .aura-collection-page .aura-plp-grid--list .aura-plp-card__media-link {
      max-width: none;
    }
  }
{% endstylesheet %}
