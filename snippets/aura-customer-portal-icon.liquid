{% doc %}
  Inline SVG icon for Aura customer portal (tab nav, benefits).

  @param {string} icon - One of: user, order, subscription, truck, gift, sparkles, map_pin, card, logout, copy, chevron
{% enddoc %}
{% liquid
  assign i = icon | default: ''
%}
