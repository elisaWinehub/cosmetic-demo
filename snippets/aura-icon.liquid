{% doc %}
  Renders an Aura Society inline SVG icon.

  @param {string} icon - The icon name to render.
  @param {string} [class] - Optional classes for the wrapper.

  @example
  {% render 'aura-icon', icon: 'sparkle' %}
{% enddoc %}

{% liquid
  assign icon_name = icon | default: 'sparkle'
%}

<span class="aura-icon {{ class }}" aria-hidden="true">
  {% case icon_name %}
    {% when 'sparkle' %}
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M12 2.8 14.35 9.65 21.2 12l-6.85 2.35L12 21.2l-2.35-6.85L2.8 12l6.85-2.35L12 2.8Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path>
      </svg>
    {% when 'crown' %}
      <svg viewBox="0 0 24 24" fill="none">
        <path d="m3 18 1.8-10.5 5.2 5.2L12 5l2 7.7 5.2-5.2L21 18H3Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path>
        <path d="M4.2 21h15.6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
      </svg>
    {% when 'gift' %}
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M4 11h16v9H4z" stroke="currentColor" stroke-width="1.6"></path>
        <path d="M12 11v9" stroke="currentColor" stroke-width="1.6"></path>
        <path d="M3 7.5h18V11H3z" stroke="currentColor" stroke-width="1.6"></path>
        <path d="M12 7.5c-2.5 0-4-1-4-2.6C8 3.8 8.9 3 10 3c1.6 0 2 1.4 2 4.5Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path>
        <path d="M12 7.5c2.5 0 4-1 4-2.6 0-1.1-.9-1.9-2-1.9-1.6 0-2 1.4-2 4.5Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path>
      </svg>
    {% when 'heart' %}
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M12 20.2 4.7 12.9a4.9 4.9 0 0 1 6.9-6.9L12 6.4l.4-.4a4.9 4.9 0 0 1 6.9 6.9L12 20.2Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path>
      </svg>
    {% when 'bag' %}
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M5 9h14l-1 11H6L5 9Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path>
        <path d="M9 9V7a3 3 0 0 1 6 0v2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
      </svg>
    {% when 'diamond' %}
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M7 4h10l4 5-9 11L3 9l4-5Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path>
        <path d="M9 4 6 9l6 11 6-11-3-5" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path>
      </svg>
    {% when 'star' %}
      <svg viewBox="0 0 24 24" fill="none">
        <path d="m12 3.8 2.5 5.1 5.7.8-4.1 4 1 5.7L12 16.7 6.9 19.4l1-5.7-4.1-4 5.7-.8L12 3.8Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path>
      </svg>
    {% when 'check' %}
      <svg viewBox="0 0 24 24" fill="none">
        <path d="m5.5 12.5 4.1 4.1L18.5 7.7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    {% when 'community' %}
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M8 12a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" stroke="currentColor" stroke-width="1.6"></path>
        <path d="M16.5 11a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z" stroke="currentColor" stroke-width="1.6"></path>
        <path d="M3.5 19.5a4.5 4.5 0 0 1 9 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
        <path d="M14 19.5a3.5 3.5 0 0 1 7 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
      </svg>
    {% when 'phone' %}
      <svg viewBox="0 0 24 24" fill="none">
        <rect x="7" y="2.5" width="10" height="19" rx="2.5" stroke="currentColor" stroke-width="1.6"></rect>
        <path d="M10 5.5h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
        <path d="M11 18.5h2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
      </svg>
    {% when 'points' %}
      <svg viewBox="0 0 24 24" fill="none">
        <circle cx="12" cy="12" r="8.5" stroke="currentColor" stroke-width="1.6"></circle>
        <path d="m9.5 12 1.6 1.6 3.8-4.2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    {% when 'arrow-right' %}
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M5 12h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
        <path d="m13 6 6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    {% else %}
      <svg viewBox="0 0 24 24" fill="none">
        <circle cx="12" cy="12" r="8.5" stroke="currentColor" stroke-width="1.6"></circle>
      </svg>
  {% endcase %}
</span>

{% stylesheet %}
  .aura-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
  }

  .aura-icon svg {
    width: 100%;
    height: 100%;
  }
{% endstylesheet %}
